import Langlib.Grammars.RightRegular.Definition

/-! # Regular Languages

This file defines the class of regular languages via right-regular grammars.
-/

variable {T : Type}

/-- A language is regular if it is generated by some right-regular grammar. -/
def is_RG (L : Language T) : Prop :=
  ∃ g : RG_grammar T, RG_language g = L

/-- The class of regular languages. -/
def RG : Set (Language T) :=
  setOf is_RG
