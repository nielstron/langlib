module

public import Langlib.Classes.Regular.Definition
public import Langlib.Grammars.LR.Definition
import Langlib.Automata.FiniteState.Equivalence.Regular
import Langlib.Classes.Regular.Inclusion.ContextFree

/-!
# Regular languages are LR(0)

Every regular language is generated by an LR(0) grammar, hence is an LR language.

The construction stays entirely inside this development's own grammars.  In this
repository a regular language is, by definition, one generated by a right-regular
grammar (`is_RG`); the repository proves these coincide with the DFA languages
(`is_RG_iff_isRegular`, built from `RG_of_DFA` / `RG_language = M.accepts`).  Given a
regular language we take the DFA `M` it equals and use the *deterministic* right-regular
grammar `RG_of_DFA M`, whose generated language (`RG_of_DFA_language`) and reachable
sentential forms (`RG_of_DFA_derives_inv`) are already established.  We reinterpret that
right-regular grammar as a context-free grammar via `CF_grammar_of_RG` (the rules are
unchanged) and show it is LR(0).

Because the DFA is deterministic, every rightmost sentential form is `w·q` — terminals
`w` followed by the single state-nonterminal reached after reading `w` — so the prefix
already built determines the handle and rule with no lookahead.  The reachable-form
content is borrowed wholesale from the right-regular development; the only new ingredient
is that a rightmost context-free step is a special case of a general one, so a rightmost
derivation of the wrapped grammar is in particular a right-regular derivation.

## Main results

- `is_LRk_zero_of_isRegular` — every regular language is LR(0)
- `is_LR_of_is_RG` — every regular language is an LR language
- `RG_subclass_LR` — `RG ⊆ LR`
-/

open CF_grammar

variable {T : Type}

namespace Langlib.RegularLR

/-! ### List helpers -/

/-- A nonterminal symbol never occurs in a list of terminals. -/
private lemma nonterminal_not_mem_map_terminal {N : Type} {Y : N} {wt : List T} :
    symbol.nonterminal Y ∉ wt.map symbol.terminal := by
  simp

/-- The terminal-symbol constructor is injective on lists. -/
private lemma map_terminal_inj {N : Type} {w₁ w₂ : List T}
    (h : w₁.map (symbol.terminal (N := N)) = w₂.map symbol.terminal) : w₁ = w₂ := by
  refine List.map_injective_iff.mpr ?_ h
  intro a b hab
  simpa using hab

/-- If `l₁ ++ [N X] ++ l₂` equals a list of terminals followed by a single trailing
nonterminal `N Y`, then the trailing nonterminal is the one we singled out: `l₂` is
empty, `l₁` is exactly the terminal prefix, and `X = Y`. -/
private lemma eq_map_terminal_append_nt {N : Type} {l₁ l₂ : List (symbol T N)} {X Y : N}
    {wt : List T}
    (h : l₁ ++ [symbol.nonterminal X] ++ l₂ = wt.map symbol.terminal ++ [symbol.nonterminal Y]) :
    l₂ = [] ∧ l₁ = wt.map symbol.terminal ∧ X = Y := by
  induction wt generalizing l₁ with
  | nil =>
    simp only [List.map_nil, List.nil_append] at h
    cases l₁ with
    | nil =>
      simp only [List.nil_append, List.cons_append, List.append_assoc, List.cons.injEq,
        symbol.nonterminal.injEq] at h
      exact ⟨h.2, rfl, h.1⟩
    | cons c l₁' => simp at h
  | cons t wt' ih =>
    simp only [List.map_cons, List.cons_append] at h
    cases l₁ with
    | nil => simp at h
    | cons c l₁' =>
      simp only [List.cons_append, List.cons.injEq] at h
      obtain ⟨hc, hrest⟩ := h
      obtain ⟨h2, h3, h4⟩ := ih hrest
      exact ⟨h2, by rw [hc, h3]; simp, h4⟩

variable [Fintype T] {σ : Type} [Fintype σ] (M : DFA T σ)

/-- The LR(0) grammar for a DFA: the right-regular grammar `RG_of_DFA M`, viewed as a
context-free grammar (same rules). -/
private noncomputable def lrGrammar : CF_grammar T := CF_grammar_of_RG (RG_of_DFA M)

private lemma lrGrammar_initial : (lrGrammar M).initial = M.start := rfl

/-- Every rule in `RG_of_DFA M` is a transition rule `q → a·(M.step q a)` or an
acceptance rule `q → ε` for an accepting `q`. -/
private lemma RG_of_DFA_rule_cases {rr : RG_rule T σ} (h : rr ∈ (RG_of_DFA M).rules) :
    (∃ q a, rr = RG_rule.cons q a (M.step q a)) ∨ (∃ q, q ∈ M.accept ∧ rr = RG_rule.epsilon q) := by
  simp only [RG_of_DFA] at h
  rw [List.mem_append] at h
  rcases h with h | h
  · rw [List.mem_map] at h
    obtain ⟨qa, _, rfl⟩ := h
    exact Or.inl ⟨qa.1, qa.2, rfl⟩
  · rw [List.mem_filterMap] at h
    obtain ⟨q, _, hq⟩ := h
    by_cases hacc : q ∈ M.accept
    · rw [if_pos hacc] at hq
      obtain rfl := Option.some.inj hq
      exact Or.inr ⟨q, hacc, rfl⟩
    · rw [if_neg hacc] at hq
      exact absurd hq (by simp)

/-- The rules of `lrGrammar M` are exactly the DFA's transition rules
`q → a·(M.step q a)` and the acceptance rules `q → ε` for accepting `q`. -/
private lemma rule_shape {rule : σ × List (symbol T σ)} (hr : rule ∈ (lrGrammar M).rules) :
    (∃ a, rule = (rule.1, [symbol.terminal a, symbol.nonterminal (M.step rule.1 a)])) ∨
      (rule.1 ∈ M.accept ∧ rule = (rule.1, [])) := by
  simp only [lrGrammar, CF_grammar_of_RG, List.mem_map] at hr
  obtain ⟨rr, hrr, rfl⟩ := hr
  rcases RG_of_DFA_rule_cases M hrr with ⟨q, a, rfl⟩ | ⟨q, hq, rfl⟩
  · exact Or.inl ⟨a, by simp [RG_rule.lhs, RG_rule.output]⟩
  · exact Or.inr ⟨by simpa [RG_rule.lhs] using hq, by simp [RG_rule.lhs, RG_rule.output]⟩

/-- A rightmost context-free step of the wrapped grammar is, in particular, a
right-regular derivation step of the underlying grammar, so a rightmost derivation is a
right-regular derivation. -/
private lemma derivesRightmost_RG_derives {u v : List (symbol T σ)}
    (h : (lrGrammar M).DerivesRightmost u v) : RG_derives (RG_of_DFA M) u v := by
  refine (RG_derives_iff_CF_derives (RG_of_DFA M) u v).mpr ?_
  refine Relation.ReflTransGen.mono ?_ h
  intro a b hab
  obtain ⟨r, hr, p, la, hu, hv⟩ := hab
  exact ⟨r, p, la.map symbol.terminal, hr, hu, hv⟩

/-- Reachable rightmost sentential forms: borrowed directly from the right-regular
characterisation `RG_of_DFA_derives_inv`. -/
private lemma formsR {q : σ} {v : List (symbol T σ)}
    (h : (lrGrammar M).DerivesRightmost [symbol.nonterminal q] v) :
    (∃ w : List T, v = w.map symbol.terminal ++ [symbol.nonterminal (M.evalFrom q w)]) ∨
      (∃ w : List T, v = w.map symbol.terminal ∧ M.evalFrom q w ∈ M.accept) :=
  RG_of_DFA_derives_inv M q v (derivesRightmost_RG_derives M h)

/-- A derived configuration carrying a marked handle `p ++ [N rule.1] ++ s` must have empty
terminal suffix, terminal prefix, and handle nonterminal equal to the reached DFA state. -/
private lemma config_extract {rule : σ × List (symbol T σ)} {p : List (symbol T σ)} {s : List T}
    (h : (lrGrammar M).DerivesRightmost [symbol.nonterminal (lrGrammar M).initial]
      (p ++ [symbol.nonterminal rule.1] ++ s.map symbol.terminal)) :
    s = [] ∧ ∃ w, p = w.map symbol.terminal ∧ rule.1 = M.evalFrom (lrGrammar M).initial w := by
  rcases formsR M h with ⟨w, hw⟩ | ⟨w, hw, _⟩
  · obtain ⟨hl₂, hp, hX⟩ := eq_map_terminal_append_nt hw
    exact ⟨by simpa using hl₂, w, hp, hX⟩
  · exfalso
    have : symbol.nonterminal rule.1 ∈ (w.map symbol.terminal) := by rw [← hw]; simp
    exact nonterminal_not_mem_map_terminal this

/-- The DFA-derived grammar is LR(0). -/
private theorem lrGrammar_isLR0 : (lrGrammar M).IsLRk 0 := by
  intro r₁ r₂ hr₁ hr₂ p₁ p₂ core s₁ s₂ hd₁ hd₂ hc₁ hc₂ _
  obtain ⟨hs₁, w₁, hp₁, hin₁⟩ := config_extract M hd₁
  obtain ⟨hs₂, w₂, hp₂, hin₂⟩ := config_extract M hd₂
  have hcore : w₁.map symbol.terminal ++ r₁.2 = w₂.map symbol.terminal ++ r₂.2 := by
    rw [← hp₁, ← hp₂, hc₁, hc₂]
  suffices h : r₁ = r₂ ∧ w₁ = w₂ by
    exact ⟨by rw [hp₁, hp₂, h.2], h.1⟩
  rcases rule_shape M hr₁ with ⟨a₁, hrule₁⟩ | ⟨hacc₁, hrule₁⟩ <;>
    rcases rule_shape M hr₂ with ⟨a₂, hrule₂⟩ | ⟨hacc₂, hrule₂⟩
  · -- shift / shift
    rw [hrule₁, hrule₂] at hcore
    have hlen : (w₁.map symbol.terminal).length = (w₂.map symbol.terminal).length := by
      have := congrArg List.length hcore; simpa using this
    obtain ⟨hw, hsuf⟩ := List.append_inj hcore hlen
    have hww : w₁ = w₂ := map_terminal_inj hw
    have h1 : r₁.1 = r₂.1 := by rw [hin₁, hin₂, hww]
    simp only [List.cons.injEq] at hsuf
    have ha : a₁ = a₂ := by simpa using hsuf.1
    exact ⟨by rw [hrule₁, hrule₂, h1, ha], hww⟩
  · -- shift / eps : contradiction (handle ends in a nonterminal, target is all terminals)
    exfalso
    rw [hrule₁, hrule₂] at hcore
    simp only [List.append_nil] at hcore
    have hmem : symbol.nonterminal (M.step r₁.1 a₁) ∈ w₂.map symbol.terminal := by
      rw [← hcore]; simp
    exact nonterminal_not_mem_map_terminal hmem
  · -- eps / shift : symmetric contradiction
    exfalso
    rw [hrule₁, hrule₂] at hcore
    simp only [List.append_nil] at hcore
    have hmem : symbol.nonterminal (M.step r₂.1 a₂) ∈ w₁.map symbol.terminal := by
      rw [hcore]; simp
    exact nonterminal_not_mem_map_terminal hmem
  · -- eps / eps
    rw [hrule₁, hrule₂] at hcore
    simp only [List.append_nil] at hcore
    have hww : w₁ = w₂ := map_terminal_inj hcore
    have h1 : r₁.1 = r₂.1 := by rw [hin₁, hin₂, hww]
    exact ⟨by rw [hrule₁, hrule₂, h1], hww⟩

/-- The language of the DFA-derived grammar is the DFA's language. -/
private lemma lrGrammar_language : CF_language (lrGrammar M) = M.accepts := by
  have hcf : CF_language (lrGrammar M) = RG_language (RG_of_DFA M) := by
    ext w
    simp only [lrGrammar, CF_language, RG_language]
    exact (RG_derives_iff_CF_derives (RG_of_DFA M) _ _).symm
  rw [hcf, RG_of_DFA_language]

end Langlib.RegularLR

/-! ### The inclusion -/

open Langlib.RegularLR

/-- Every regular (right-regular-generated) language is generated by an LR(0) grammar. -/
public theorem is_LRk_zero_of_is_RG [Fintype T] {L : Language T} (h : is_RG L) : is_LRk 0 L := by
  obtain ⟨σ, hσ, M, hML⟩ := is_RG_iff_isRegular.mp h
  haveI := hσ
  exact ⟨lrGrammar M, lrGrammar_isLR0 M, (lrGrammar_language M).trans hML⟩

/-- Every regular language is an LR language. -/
public theorem is_LR_of_is_RG [Fintype T] {L : Language T} (h : is_RG L) : is_LR L :=
  ⟨0, is_LRk_zero_of_is_RG h⟩

/-- The class of regular languages is contained in the class of LR languages. -/
public theorem RG_subclass_LR [Fintype T] :
    (RG : Set (Language T)) ⊆ (LR : Set (Language T)) :=
  fun _L hL => is_LR_of_is_RG hL
