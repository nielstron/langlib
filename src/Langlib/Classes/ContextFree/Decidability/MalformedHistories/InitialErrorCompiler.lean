module

public import Langlib.Classes.ContextFree.Decidability.EncodedOperations
public import Langlib.Classes.ContextFree.Decidability.MalformedHistories.FixedSystem

@[expose]
public section

/-!
# An effective grammar for the varying initial-history error

The fixed-system reduction changes only the marked unary word expected on the
first row.  This file gives a literal right-regular grammar for histories whose
first row fails that test.  Its state indices are numeric and its rule list is
generated by `List.range`, so the construction is primitive recursive in the
source program.  Applying the encoded positive-part construction removes the
single accepting epsilon rule while preserving the (already positive) history
language.
-/

open ContextFree.EncodedCFG

namespace ContextFree.MalformedHistories.InitialErrorCompiler

abbrev RowAlphabet (Γ Λ : Type) :=
  LBA.RowCell (Option Bool) (Option ((Option Bool) ⊕ Γ)) Λ

abbrev CellAlphabet (Γ Λ : Type) :=
  BundledCell (RowAlphabet Γ Λ) LBA.RowCert

abbrev HistoryAlphabet (Γ Λ : Type) :=
  Symbol (CellAlphabet Γ Λ)

variable {Γ Λ : Type} [DecidableEq Γ] [DecidableEq Λ]

/-- The unique padding cell allowed on a valid initial bundled row. -/
def paddingCell : CellAlphabet Γ Λ :=
  (LBA.RowCell.raw none, none)

/-- The unique marked-`true` cell allowed on a valid initial bundled row. -/
def markerCell : CellAlphabet Γ Λ :=
  (LBA.RowCell.raw (some true), none)

/-- The unique unary-`false` cell allowed on a valid initial bundled row. -/
def unaryCell : CellAlphabet Γ Λ :=
  (LBA.RowCell.raw (some false), none)

/-- Embed an optional source symbol as an unannotated raw bundled cell. -/
def rawBundledCell (a : Option Bool) : CellAlphabet Γ Λ :=
  (LBA.RowCell.raw a, none)

/-- The source suffix still expected after `q` non-padding symbols have been
matched.  The side condition `q ≤ n + 1` is used in its characterization. -/
def expectedSuffix (n q : Nat) : List Bool :=
  if q = 0 then true :: List.replicate n false
  else List.replicate (n + 1 - q) false

/-- Progress through `true :: false^n`, ignoring padding.  State `n + 2` is
the bad-row sink. -/
def rowProgress (n q : Nat) (a : CellAlphabet Γ Λ) : Nat :=
  if a = paddingCell then q
  else if a = markerCell ∧ q = 0 then 1
  else if a = unaryCell ∧ 0 < q ∧ q ≤ n then q + 1
  else n + 2

@[simp] theorem rowProgress_bad (n : Nat) (a : CellAlphabet Γ Λ) :
    rowProgress n (n + 2) a = n + 2 := by
  simp [rowProgress]

@[simp] theorem foldl_rowProgress_bad (n : Nat)
    (row : List (CellAlphabet Γ Λ)) :
    row.foldl (rowProgress n) (n + 2) = n + 2 := by
  induction row with
  | nil => rfl
  | cons a row ih => simpa using ih

/-- Finishing in the unique good scan state is exactly successful decoding of
the remaining marked-unary suffix. -/
theorem foldl_rowProgress_eq_good_iff (n q : Nat)
    (hq : q ≤ n + 1) (row : List (CellAlphabet Γ Λ)) :
    row.foldl (rowProgress n) q = n + 1 ↔
      ∃ padded : List (Option Bool),
        row = padded.map rawBundledCell ∧
          padded.flatMap Grammar.ErasingImage.erasePadding =
            expectedSuffix n q := by
  induction row generalizing q with
  | nil =>
      simp only [List.foldl_nil, List.map_eq_nil_iff, List.flatMap_nil]
      constructor
      · intro h
        subst q
        refine ⟨[], rfl, ?_⟩
        simp [expectedSuffix]
      · rintro ⟨padded, hpadded, herase⟩
        have hpadded' : padded = [] := by simpa using hpadded.symm
        subst padded
        simp only [expectedSuffix] at herase
        split at herase
        · simp at herase
        · have : n + 1 - q = 0 := by
            simpa using (congrArg List.length herase).symm
          omega
  | cons a row ih =>
      rcases a with ⟨cell, cert⟩
      rcases cert with _ | cert
      · rcases cell with input | ⟨symbol, head, state⟩
        · rcases input with _ | b
          · simp only [List.foldl_cons]
            rw [show rowProgress n q (LBA.RowCell.raw none, none) = q by
              simp [rowProgress, paddingCell]]
            rw [ih q hq]
            constructor
            · rintro ⟨padded, hrow, herase⟩
              exact ⟨none :: padded, by simp [rawBundledCell, hrow], by
                simpa [Grammar.ErasingImage.erasePadding, expectedSuffix] using herase⟩
            · rintro ⟨padded, hpadded, herase⟩
              cases padded with
              | nil => simp [rawBundledCell] at hpadded
              | cons x padded =>
                  have hx : x = none := by
                    simpa [rawBundledCell] using (congrArg List.head? hpadded).symm
                  subst x
                  have hrow : row = padded.map rawBundledCell := by
                    simpa [rawBundledCell] using List.tail_eq_of_cons_eq hpadded
                  refine ⟨padded, hrow, ?_⟩
                  simpa [Grammar.ErasingImage.erasePadding, expectedSuffix] using herase
          · cases b
            · simp only [List.foldl_cons]
              by_cases hq0 : q = 0
              · subst q
                rw [show rowProgress n 0 (LBA.RowCell.raw (some false), none) = n + 2 by
                  simp [rowProgress, paddingCell, markerCell, unaryCell]]
                rw [foldl_rowProgress_bad]
                constructor
                · omega
                · rintro ⟨padded, hpadded, herase⟩
                  cases padded with
                  | nil => simp [rawBundledCell] at hpadded
                  | cons x padded =>
                      have hx : x = some false := by
                        simpa [rawBundledCell] using
                          (congrArg List.head? hpadded).symm
                      subst x
                      simp [Grammar.ErasingImage.erasePadding, expectedSuffix] at herase
              · have hqpos : 0 < q := Nat.pos_of_ne_zero hq0
                by_cases hqn : q ≤ n
                · rw [show rowProgress n q (LBA.RowCell.raw (some false), none) = q + 1 by
                    simp [rowProgress, paddingCell, markerCell, unaryCell,
                      hq0, hqpos, hqn]]
                  have hqsucc : q + 1 ≤ n + 1 := by omega
                  rw [ih (q + 1) hqsucc]
                  constructor
                  · rintro ⟨padded, hrow, herase⟩
                    refine ⟨some false :: padded,
                      by simp [rawBundledCell, hrow], ?_⟩
                    simp only [List.flatMap_cons,
                      Grammar.ErasingImage.erasePadding, List.singleton_append]
                    rw [expectedSuffix, if_neg hq0,
                      show n + 1 - q = (n - q) + 1 by omega,
                      List.replicate_succ]
                    congr 1
                    simpa [expectedSuffix,
                      show q + 1 ≠ 0 by omega,
                      show n + 1 - (q + 1) = n - q by omega] using herase
                  · rintro ⟨padded, hpadded, herase⟩
                    cases padded with
                    | nil => simp [rawBundledCell] at hpadded
                    | cons x padded =>
                        have hx : x = some false := by
                          simpa [rawBundledCell] using
                            (congrArg List.head? hpadded).symm
                        subst x
                        have hrow : row = padded.map rawBundledCell := by
                          simpa [rawBundledCell] using List.tail_eq_of_cons_eq hpadded
                        refine ⟨padded, hrow, ?_⟩
                        have herase' := herase
                        simp only [List.flatMap_cons,
                          Grammar.ErasingImage.erasePadding,
                          List.singleton_append] at herase'
                        rw [expectedSuffix, if_neg hq0,
                          show n + 1 - q = (n - q) + 1 by omega,
                          List.replicate_succ] at herase'
                        have htailErase := (List.cons.inj herase').2
                        simpa [expectedSuffix,
                          show q + 1 ≠ 0 by omega,
                          show n + 1 - (q + 1) = n - q by omega] using htailErase
                · have hqeq : q = n + 1 := by omega
                  subst q
                  rw [show rowProgress n (n + 1)
                      (LBA.RowCell.raw (some false), none) = n + 2 by
                    simp [rowProgress, paddingCell, markerCell, unaryCell]]
                  rw [foldl_rowProgress_bad]
                  constructor
                  · omega
                  · rintro ⟨padded, hpadded, herase⟩
                    cases padded with
                    | nil => simp [rawBundledCell] at hpadded
                    | cons x padded =>
                        have hx : x = some false := by
                          simpa [rawBundledCell] using
                            (congrArg List.head? hpadded).symm
                        subst x
                        simp [Grammar.ErasingImage.erasePadding, expectedSuffix] at herase
            · simp only [List.foldl_cons]
              by_cases hq0 : q = 0
              · subst q
                rw [show rowProgress n 0 (LBA.RowCell.raw (some true), none) = 1 by
                  simp [rowProgress, paddingCell, markerCell]]
                have hone : 1 ≤ n + 1 := by omega
                rw [ih 1 hone]
                constructor
                · rintro ⟨padded, hrow, herase⟩
                  refine ⟨some true :: padded,
                    by simp [rawBundledCell, hrow], ?_⟩
                  simpa [Grammar.ErasingImage.erasePadding, expectedSuffix] using herase
                · rintro ⟨padded, hpadded, herase⟩
                  cases padded with
                  | nil => simp [rawBundledCell] at hpadded
                  | cons x padded =>
                      have hx : x = some true := by
                        simpa [rawBundledCell] using
                          (congrArg List.head? hpadded).symm
                      subst x
                      have hrow : row = padded.map rawBundledCell := by
                        simpa [rawBundledCell] using List.tail_eq_of_cons_eq hpadded
                      refine ⟨padded, hrow, ?_⟩
                      simpa [Grammar.ErasingImage.erasePadding, expectedSuffix] using herase
              · rw [show rowProgress n q (LBA.RowCell.raw (some true), none) = n + 2 by
                  simp [rowProgress, paddingCell, markerCell, unaryCell, hq0]]
                rw [foldl_rowProgress_bad]
                constructor
                · omega
                · rintro ⟨padded, hpadded, herase⟩
                  cases padded with
                  | nil => simp [rawBundledCell] at hpadded
                  | cons x padded =>
                      have hx : x = some true := by
                        simpa [rawBundledCell] using
                          (congrArg List.head? hpadded).symm
                      subst x
                      simp only [List.flatMap_cons,
                        Grammar.ErasingImage.erasePadding,
                        List.singleton_append, expectedSuffix,
                        if_neg hq0] at herase
                      cases hlen : n + 1 - q with
                      | zero => simpa [hlen] using herase
                      | succ k =>
                          rw [hlen, List.replicate_succ] at herase
                          exact Bool.noConfusion (List.cons.inj herase).1
        · simp only [List.foldl_cons]
          rw [show rowProgress n q (LBA.RowCell.cfg symbol head state, none) = n + 2 by
            simp [rowProgress, paddingCell, markerCell, unaryCell]]
          rw [foldl_rowProgress_bad]
          constructor
          · omega
          · rintro ⟨padded, hpadded, -⟩
            cases padded <;> simp [rawBundledCell] at hpadded
      · simp only [List.foldl_cons]
        rw [show rowProgress n q (cell, some cert) = n + 2 by
          simp [rowProgress, paddingCell, markerCell, unaryCell]]
        rw [foldl_rowProgress_bad]
        constructor
        · omega
        · rintro ⟨padded, hpadded, -⟩
          cases padded <;> simp [rawBundledCell] at hpadded

/-- A bundled first row is reconstructed from its underlying row by adding
`none` certificates. -/
theorem eq_map_underlying_of_isFirst {row : List (CellAlphabet Γ Λ)}
    (hfirst : IsFirstBundledRow row) :
    row = (underlyingRow row).map fun a => (a, none) := by
  induction row with
  | nil => rfl
  | cons a row ih =>
      have hnone : a.2 = none :=
        (isFirstBundledRow_iff_forall (a :: row)).mp hfirst a (by simp)
      have htail : IsFirstBundledRow row := by
        rw [isFirstBundledRow_iff_forall]
        intro b hb
        exact (isFirstBundledRow_iff_forall (a :: row)).mp hfirst b (by simp [hb])
      rcases a with ⟨a, cert⟩
      simp only at hnone
      subst cert
      change (a, none) :: row =
        ((a :: underlyingRow row).map fun b => (b, none))
      simp only [List.map_cons, List.cons.injEq, true_and]
      exact ih htail

/-- The scan state is good precisely for the initial predicate used by the
fixed-system reduction. -/
theorem foldl_rowProgress_zero_iff_initialRow (n : Nat)
    (row : List (CellAlphabet Γ Λ)) :
    row.foldl (rowProgress n) 0 = n + 1 ↔
      IsFirstBundledRow row ∧
        FixedSystem.InitialRow (Γ := Γ) (Λ := Λ)
          (true :: List.replicate n false) (underlyingRow row) := by
  rw [foldl_rowProgress_eq_good_iff n 0 (by omega)]
  simp only [expectedSuffix, if_pos]
  constructor
  · rintro ⟨padded, rfl, herase⟩
    refine ⟨?_, ⟨padded, ?_, herase⟩⟩
    · rw [isFirstBundledRow_iff_forall]
      intro cell hcell
      obtain ⟨a, -, rfl⟩ := List.mem_map.mp hcell
      rfl
    · simp [underlyingRow, rawBundledCell]
  · rintro ⟨hfirst, ⟨padded, hrow, herase⟩⟩
    refine ⟨padded, ?_, herase⟩
    rw [eq_map_underlying_of_isFirst hfirst, hrow]
    simp [rawBundledCell]

theorem rowProgress_le (n q : Nat) (a : CellAlphabet Γ Λ)
    (hq : q ≤ n + 2) : rowProgress n q a ≤ n + 2 := by
  simp only [rowProgress]
  split_ifs <;> omega

/-- The finite verifier whose sole accepting state is successful completion of
the marked-unary first row. -/
def initialRowVerifier (n : Nat) :
    RowVerifier (CellAlphabet Γ Λ) (Fin (n + 3)) where
  start := ⟨0, by omega⟩
  step q a := ⟨rowProgress n q.val a, by
    have := rowProgress_le n q.val a (by omega)
    omega⟩
  done q := decide (q.val = n + 1)

private theorem initialRowVerifier_foldl_val (n : Nat)
    (q : Fin (n + 3)) (row : List (CellAlphabet Γ Λ)) :
    (row.foldl (initialRowVerifier n).step q).val =
      row.foldl (rowProgress n) q.val := by
  induction row generalizing q with
  | nil => rfl
  | cons a row ih =>
      simpa [initialRowVerifier] using
        (ih ((initialRowVerifier n).step q a))

theorem initialRowVerifier_accepts_iff (n : Nat)
    (row : List (CellAlphabet Γ Λ)) :
    (initialRowVerifier n).Accepts row ↔
      row.foldl (rowProgress n) 0 = n + 1 := by
  unfold RowVerifier.Accepts RowVerifier.eval
  change decide ((row.foldl (initialRowVerifier n).step
    (initialRowVerifier n).start).val = n + 1) = true ↔ _
  rw [decide_eq_true_iff]
  rw [initialRowVerifier_foldl_val (Γ := Γ) (Λ := Λ) n
    (initialRowVerifier (Γ := Γ) (Λ := Λ) n).start row]
  rfl

/-- Numeric control-state transition on a row separator.

The state layout is
`start`, `scan 0`, ..., `scan (n+2)`, `accept`, `dead`.
-/
def separatorStep (n state : Nat) : Nat :=
  if state = 0 then 1
  else if state ≤ n + 3 then
    if state - 1 = n + 1 then n + 5 else n + 4
  else n + 5

/-- Numeric control-state transition on a bundled row cell. -/
def cellStep (n state : Nat) (a : CellAlphabet Γ Λ) : Nat :=
  if state = 0 then n + 5
  else if state ≤ n + 3 then rowProgress n (state - 1) a + 1
  else n + 5

theorem separatorStep_lt (n state : Nat) (hstate : state < n + 6) :
    separatorStep n state < n + 6 := by
  simp only [separatorStep]
  split_ifs <;> omega

theorem cellStep_lt (n state : Nat) (a : CellAlphabet Γ Λ)
    (hstate : state < n + 6) : cellStep n state a < n + 6 := by
  simp only [cellStep]
  split_ifs with hzero hscan
  all_goals try omega
  have hq : state - 1 ≤ n + 2 := by omega
  have hp := rowProgress_le n (state - 1) a hq
  omega

/-- The DFA implemented literally by `rejectedInitialRG`. -/
def rejectedInitialDFA (n : Nat) :
    DFA (HistoryAlphabet Γ Λ) (Fin (n + 6)) where
  start := ⟨0, by omega⟩
  step q
    | .separator => ⟨separatorStep n q.val, separatorStep_lt n q.val q.isLt⟩
    | .cell a => ⟨cellStep n q.val a, cellStep_lt n q.val a q.isLt⟩
  accept := {q | q.val = n + 4}

/-- Numeric evaluation of the wrapper DFA. -/
def historyEvalFrom (n state : Nat) : List (HistoryAlphabet Γ Λ) → Nat
  | [] => state
  | .separator :: w => historyEvalFrom n (separatorStep n state) w
  | .cell a :: w => historyEvalFrom n (cellStep n state a) w

@[simp] theorem historyEvalFrom_nil (n state : Nat) :
    historyEvalFrom (Γ := Γ) (Λ := Λ) n state [] = state := rfl

@[simp] theorem historyEvalFrom_separator (n state : Nat)
    (w : List (HistoryAlphabet Γ Λ)) :
    historyEvalFrom n state (Symbol.separator :: w) =
      historyEvalFrom n (separatorStep n state) w := rfl

@[simp] theorem historyEvalFrom_cell (n state : Nat)
    (a : CellAlphabet Γ Λ) (w : List (HistoryAlphabet Γ Λ)) :
    historyEvalFrom n state (Symbol.cell a :: w) =
      historyEvalFrom n (cellStep n state a) w := rfl

private theorem rejectedInitialDFA_evalFrom_val (n : Nat)
    (q : Fin (n + 6)) (w : List (HistoryAlphabet Γ Λ)) :
    ((rejectedInitialDFA n).evalFrom q w).val =
      historyEvalFrom n q.val w := by
  induction w generalizing q with
  | nil => rfl
  | cons s w ih =>
      cases s with
      | separator =>
          simpa [DFA.evalFrom, rejectedInitialDFA] using
            ih ((rejectedInitialDFA n).step q
              (Symbol.separator : HistoryAlphabet Γ Λ))
      | cell a =>
          simpa [DFA.evalFrom, rejectedInitialDFA] using
            ih ((rejectedInitialDFA n).step q (Symbol.cell a))

theorem separatorStep_scan (n q : Nat) (hq : q ≤ n + 2) :
    separatorStep n (q + 1) =
      if q = n + 1 then n + 5 else n + 4 := by
  simp [separatorStep]
  omega

theorem cellStep_scan (n q : Nat) (a : CellAlphabet Γ Λ)
    (hq : q ≤ n + 2) :
    cellStep n (q + 1) a = rowProgress n q a + 1 := by
  simp [cellStep]
  omega

@[simp] theorem separatorStep_dead (n : Nat) :
    separatorStep n (n + 5) = n + 5 := by
  simp [separatorStep]

@[simp] theorem cellStep_dead (n : Nat) (a : CellAlphabet Γ Λ) :
    cellStep n (n + 5) a = n + 5 := by
  simp [cellStep]

@[simp] theorem separatorStep_accept (n : Nat) :
    separatorStep n (n + 4) = n + 5 := by
  simp [separatorStep]

@[simp] theorem cellStep_accept (n : Nat) (a : CellAlphabet Γ Λ) :
    cellStep n (n + 4) a = n + 5 := by
  simp [cellStep]

@[simp] theorem historyEvalFrom_dead (n : Nat)
    (w : List (HistoryAlphabet Γ Λ)) :
    historyEvalFrom n (n + 5) w = n + 5 := by
  induction w with
  | nil => rfl
  | cons s w ih => cases s <;> simpa using ih

theorem historyEvalFrom_accept_iff_nil (n : Nat)
    (w : List (HistoryAlphabet Γ Λ)) :
    historyEvalFrom n (n + 4) w = n + 4 ↔ w = [] := by
  cases w with
  | nil => simp
  | cons s w =>
      cases s <;> simp

/-- Starting in a scan state, the block DFA accepts exactly one cell-only row
followed by a separator, and exactly when the row verifier rejects it. -/
theorem historyEvalFrom_scan_iff (n q : Nat) (hq : q ≤ n + 2)
    (w : List (HistoryAlphabet Γ Λ)) :
    historyEvalFrom n (q + 1) w = n + 4 ↔
      ∃ row : List (CellAlphabet Γ Λ),
        w = row.map Symbol.cell ++ [Symbol.separator] ∧
          row.foldl (rowProgress n) q ≠ n + 1 := by
  induction w generalizing q with
  | nil =>
      constructor
      · intro h
        simp only [historyEvalFrom_nil] at h
        omega
      · rintro ⟨row, hrow, -⟩
        have := congrArg List.length hrow
        simp at this
  | cons s w ih =>
      cases s with
      | separator =>
          rw [historyEvalFrom_separator, separatorStep_scan n q hq]
          by_cases hgood : q = n + 1
          · rw [if_pos hgood]
            constructor
            · intro h
              rw [historyEvalFrom_dead] at h
              omega
            · rintro ⟨row, hrow, hreject⟩
              cases row with
              | nil =>
                  simp only [List.map_nil, List.nil_append,
                    List.cons.injEq] at hrow
                  exact (hreject (by simpa [hgood])).elim
              | cons a row => simp at hrow
          · simp only [if_neg hgood]
            rw [historyEvalFrom_accept_iff_nil]
            constructor
            · intro hw
              subst w
              exact ⟨[], by simp, hgood⟩
            · rintro ⟨row, hrow, hreject⟩
              cases row with
              | nil => simpa using hrow
              | cons a row => simp at hrow
      | cell a =>
          rw [historyEvalFrom_cell, cellStep_scan n q a hq]
          have hnext : rowProgress n q a ≤ n + 2 :=
            rowProgress_le n q a hq
          rw [ih (rowProgress n q a) hnext]
          constructor
          · rintro ⟨row, hrow, hreject⟩
            refine ⟨a :: row, ?_, ?_⟩
            · simp [hrow]
            · simpa using hreject
          · rintro ⟨row, hrow, hreject⟩
            cases row with
            | nil => simp at hrow
            | cons b row =>
                simp only [List.map_cons, List.cons_append,
                  List.cons.injEq] at hrow
                have hab : a = b := Symbol.cell.inj hrow.1
                subst b
                exact ⟨row, hrow.2, by simpa using hreject⟩

/-- Acceptance by the numeric DFA is the rejected block realization of the
finite first-row verifier. -/
theorem rejectedInitialDFA_accepts [Fintype Γ] [Fintype Λ] (n : Nat) :
    (rejectedInitialDFA (Γ := Γ) (Λ := Λ) n).accepts =
      ({[Symbol.separator]} : Language (HistoryAlphabet Γ Λ)) *
        (initialRowVerifier (Γ := Γ) (Λ := Λ) n).rejectBlockLanguage := by
  ext w
  change (rejectedInitialDFA n).eval w ∈
      ({q : Fin (n + 6) | q.val = n + 4} : Set (Fin (n + 6))) ↔ _
  rw [show ((rejectedInitialDFA n).eval w ∈
      ({q : Fin (n + 6) | q.val = n + 4} : Set (Fin (n + 6)))) ↔
      historyEvalFrom n 0 w = n + 4 by
    change ((rejectedInitialDFA n).evalFrom
      (rejectedInitialDFA n).start w).val = n + 4 ↔ _
    rw [rejectedInitialDFA_evalFrom_val]
    rfl]
  rw [Language.mem_mul]
  constructor
  · intro hw
    cases w with
    | nil => simp at hw
    | cons s w =>
        cases s with
        | cell a =>
            rw [historyEvalFrom_cell,
              show cellStep n 0 a = n + 5 by simp [cellStep],
              historyEvalFrom_dead] at hw
            omega
        | separator =>
            simp only [historyEvalFrom_separator] at hw
            have hstart : separatorStep n 0 = 1 := by simp [separatorStep]
            rw [hstart, historyEvalFrom_scan_iff n 0 (by omega)] at hw
            obtain ⟨row, hrow, hreject⟩ := hw
            refine ⟨[Symbol.separator], Set.mem_singleton _,
              row.map Symbol.cell ++ [Symbol.separator], ?_, by simp [hrow]⟩
            rw [(initialRowVerifier n).mem_rejectBlockLanguage_iff]
            exact ⟨row, rfl, fun haccept =>
              hreject ((initialRowVerifier_accepts_iff n row).mp haccept)⟩
  · rintro ⟨pre, hpre, suffix, hsuffix, rfl⟩
    change pre = [Symbol.separator] at hpre
    subst pre
    obtain ⟨row, rfl, hreject⟩ :=
      ((initialRowVerifier n).mem_rejectBlockLanguage_iff suffix).mp hsuffix
    simp only [List.singleton_append, historyEvalFrom_separator]
    rw [show separatorStep n 0 = 1 by simp [separatorStep],
      historyEvalFrom_scan_iff n 0 (by omega)]
    exact ⟨row, rfl, fun hgood =>
      hreject ((initialRowVerifier_accepts_iff n row).mpr hgood)⟩

/-- All transition rules from one numeric state. -/
noncomputable def stateRules [Fintype Γ] [Fintype Λ]
    (n state : Nat) : List (Nat × Option (HistoryAlphabet Γ Λ × Option Nat)) :=
  (state, some (Symbol.separator, some (separatorStep n state))) ::
    (Finset.univ.toList : List (CellAlphabet Γ Λ)).map fun a =>
      (state, some (Symbol.cell a, some (cellStep n state a)))

/-- Literal right-regular code for a leading separator and one rejected first
row block.  The only epsilon rule belongs to its final accepting state. -/
noncomputable def rejectedInitialRG [Fintype Γ] [Fintype Λ]
    (n : Nat) : Regular.EncodedRG (HistoryAlphabet Γ Λ) :=
  (n + 5, 0,
    (List.range (n + 6)).flatMap (stateRules (Γ := Γ) (Λ := Λ) n) ++
      [(n + 4, none)])

/-- Epsilon-free CFG code for the positive part of `rejectedInitialRG`. -/
noncomputable def rejectedInitialCFG [Fintype Γ] [Fintype Λ]
    (n : Nat) : EncodedCFG (HistoryAlphabet Γ Λ) :=
  Regular.EncodedRG.positivePart (rejectedInitialRG (Γ := Γ) (Λ := Λ) n)

private theorem rejectedInitial_toNT_eq [Fintype Γ] [Fintype Λ]
    (n i : Nat) (hi : i < n + 6) :
    (Regular.EncodedRG.toCFG
      (rejectedInitialRG (Γ := Γ) (Λ := Λ) n)).toNT i = ⟨i, hi⟩ := by
  apply Fin.ext
  simp [Regular.EncodedRG.toCFG, rejectedInitialRG,
    EncodedCFG.toNT, EncodedCFG.ntCount, EncodedCFG.numNT,
    Nat.mod_eq_of_lt hi]

private theorem mem_stateRules_iff [Fintype Γ] [Fintype Λ]
    (n state : Nat)
    (raw : Nat × Option (HistoryAlphabet Γ Λ × Option Nat)) :
    raw ∈ stateRules (Γ := Γ) (Λ := Λ) n state ↔
      raw = (state, some (Symbol.separator, some (separatorStep n state))) ∨
        ∃ a : CellAlphabet Γ Λ,
          raw = (state, some (Symbol.cell a, some (cellStep n state a))) := by
  simp [stateRules, eq_comm]

private theorem mem_rejectedInitial_rawRules_iff [Fintype Γ] [Fintype Λ]
    (n : Nat) (raw : Nat × Option (HistoryAlphabet Γ Λ × Option Nat)) :
    raw ∈ (rejectedInitialRG (Γ := Γ) (Λ := Λ) n).2.2 ↔
      (∃ state < n + 6,
        raw ∈ stateRules (Γ := Γ) (Λ := Λ) n state) ∨
      raw = (n + 4, none) := by
  simp [rejectedInitialRG, eq_comm]

private theorem rejectedInitial_rules_iff [Fintype Γ] [Fintype Λ]
    (n : Nat) (r : RG_rule (HistoryAlphabet Γ Λ) (Fin (n + 6))) :
    r ∈ (Regular.EncodedRG.toRG
      (rejectedInitialRG (Γ := Γ) (Λ := Λ) n)).rules ↔
      r ∈ (RG_of_DFA (rejectedInitialDFA (Γ := Γ) (Λ := Λ) n)).rules := by
  let code := rejectedInitialRG (Γ := Γ) (Λ := Λ) n
  let machine := rejectedInitialDFA (Γ := Γ) (Λ := Λ) n
  cases r with
  | cons A symbol B =>
      constructor
      · intro hr
        change RG_rule.cons A symbol B ∈
          code.2.2.map (Regular.EncodedRG.rgRuleOf code) at hr
        obtain ⟨raw, hraw, heq⟩ := List.mem_map.mp hr
        have hraw' := (mem_rejectedInitial_rawRules_iff n raw).mp hraw
        rcases hraw' with ⟨state, hstate, hstateRule⟩ | hepsilon
        · rcases (mem_stateRules_iff n state raw).mp hstateRule with
            hseparator | ⟨a, hcell⟩
          · subst raw
            simp only [Regular.EncodedRG.rgRuleOf] at heq
            rw [rejectedInitial_toNT_eq n state hstate,
              rejectedInitial_toNT_eq n (separatorStep n state)
                (separatorStep_lt n state hstate)] at heq
            injection heq with hA hsymbol hB
            subst A
            subst symbol
            subst B
            exact RG_of_DFA_cons_mem machine
              ⟨state, hstate⟩ (Symbol.separator : HistoryAlphabet Γ Λ)
          · subst raw
            simp only [Regular.EncodedRG.rgRuleOf] at heq
            rw [rejectedInitial_toNT_eq n state hstate,
              rejectedInitial_toNT_eq n (cellStep n state a)
                (cellStep_lt n state a hstate)] at heq
            injection heq with hA hsymbol hB
            subst A
            subst symbol
            subst B
            exact RG_of_DFA_cons_mem machine
              ⟨state, hstate⟩ (Symbol.cell a)
        · subst raw
          simp [Regular.EncodedRG.rgRuleOf] at heq
      · intro hr
        have hstep : B = machine.step A symbol := by
          have hforward : machine.step A symbol = B := by
            simpa [RG_of_DFA, machine] using hr
          exact hforward.symm
        change RG_rule.cons A symbol B ∈
          code.2.2.map (Regular.EncodedRG.rgRuleOf code)
        apply List.mem_map.mpr
        cases symbol with
        | separator =>
            let raw : Nat × Option (HistoryAlphabet Γ Λ × Option Nat) :=
              (A.val, some (Symbol.separator, some (separatorStep n A.val)))
            refine ⟨raw, ?_, ?_⟩
            · exact (mem_rejectedInitial_rawRules_iff n raw).mpr
                (Or.inl ⟨A.val, A.isLt,
                  (mem_stateRules_iff n A.val raw).mpr (Or.inl rfl)⟩)
            · dsimp [code, raw]
              simp only [Regular.EncodedRG.rgRuleOf]
              rw [rejectedInitial_toNT_eq n A.val A.isLt,
                rejectedInitial_toNT_eq n (separatorStep n A.val)
                  (separatorStep_lt n A.val A.isLt)]
              dsimp [machine] at hstep
              rw [hstep]
              rfl
        | cell a =>
            let raw : Nat × Option (HistoryAlphabet Γ Λ × Option Nat) :=
              (A.val, some (Symbol.cell a, some (cellStep n A.val a)))
            refine ⟨raw, ?_, ?_⟩
            · exact (mem_rejectedInitial_rawRules_iff n raw).mpr
                (Or.inl ⟨A.val, A.isLt,
                  (mem_stateRules_iff n A.val raw).mpr (Or.inr ⟨a, rfl⟩)⟩)
            · dsimp [code, raw]
              simp only [Regular.EncodedRG.rgRuleOf]
              rw [rejectedInitial_toNT_eq n A.val A.isLt,
                rejectedInitial_toNT_eq n (cellStep n A.val a)
                  (cellStep_lt n A.val a A.isLt)]
              dsimp [machine] at hstep
              rw [hstep]
              rfl
  | single A symbol =>
      constructor
      · intro hr
        change RG_rule.single A symbol ∈
          code.2.2.map (Regular.EncodedRG.rgRuleOf code) at hr
        obtain ⟨raw, hraw, heq⟩ := List.mem_map.mp hr
        rcases (mem_rejectedInitial_rawRules_iff n raw).mp hraw with
            ⟨state, -, hstateRule⟩ | hepsilon
        · rcases (mem_stateRules_iff n state raw).mp hstateRule with
            hseparator | ⟨a, hcell⟩ <;> subst raw <;>
              simp [Regular.EncodedRG.rgRuleOf] at heq
        · subst raw
          simp [Regular.EncodedRG.rgRuleOf] at heq
      · intro hr
        exact (RG_of_DFA_no_single machine A symbol hr).elim
  | epsilon A =>
      rw [RG_of_DFA_epsilon_mem_iff]
      change RG_rule.epsilon A ∈
          code.2.2.map (Regular.EncodedRG.rgRuleOf code) ↔ A.val = n + 4
      constructor
      · intro hr
        obtain ⟨raw, hraw, heq⟩ := List.mem_map.mp hr
        rcases (mem_rejectedInitial_rawRules_iff n raw).mp hraw with
            ⟨state, -, hstateRule⟩ | hepsilon
        · rcases (mem_stateRules_iff n state raw).mp hstateRule with
            hseparator | ⟨a, hcell⟩ <;> subst raw <;>
              simp [Regular.EncodedRG.rgRuleOf] at heq
        · subst raw
          simp only [Regular.EncodedRG.rgRuleOf] at heq
          rw [rejectedInitial_toNT_eq n (n + 4) (by omega)] at heq
          exact congrArg Fin.val (RG_rule.epsilon.inj heq).symm
      · intro hA
        apply List.mem_map.mpr
        refine ⟨(n + 4, none), ?_, ?_⟩
        · exact (mem_rejectedInitial_rawRules_iff n _).mpr (Or.inr rfl)
        · simp only [Regular.EncodedRG.rgRuleOf]
          rw [rejectedInitial_toNT_eq n (n + 4) (by omega)]
          apply congrArg RG_rule.epsilon
          apply Fin.ext
          simpa using hA.symm

private theorem rejectedInitial_rgLanguage_eq_dfa [Fintype Γ] [Fintype Λ]
    (n : Nat) :
    RG_language (Regular.EncodedRG.toRG
      (rejectedInitialRG (Γ := Γ) (Λ := Λ) n)) =
      RG_language (RG_of_DFA
        (rejectedInitialDFA (Γ := Γ) (Λ := Λ) n)) := by
  let g := Regular.EncodedRG.toRG
    (rejectedInitialRG (Γ := Γ) (Λ := Λ) n)
  let h := RG_of_DFA (rejectedInitialDFA (Γ := Γ) (Λ := Λ) n)
  have hinit : g.initial = h.initial := by
    change (Regular.EncodedRG.toCFG
      (rejectedInitialRG (Γ := Γ) (Λ := Λ) n)).toNT 0 =
        (rejectedInitialDFA (Γ := Γ) (Λ := Λ) n).start
    rw [rejectedInitial_toNT_eq n 0 (by omega)]
    rfl
  ext w
  change RG_derives g [symbol.nonterminal g.initial]
      (List.map symbol.terminal w) ↔
    RG_derives h [symbol.nonterminal h.initial]
      (List.map symbol.terminal w)
  rw [hinit]
  constructor
  · intro hd
    apply hd.lift id
    intro u v hstep
    rcases hstep with ⟨r, hr, left, right, hu, hv⟩
    refine ⟨r, (rejectedInitial_rules_iff n r).mp hr,
      left, right, hu, hv⟩
  · intro hd
    apply hd.lift id
    intro u v hstep
    rcases hstep with ⟨r, hr, left, right, hu, hv⟩
    refine ⟨r, (rejectedInitial_rules_iff n r).mpr hr,
      left, right, hu, hv⟩

/-- The literal right-regular code denotes the leading separator followed by
one rejected row block. -/
theorem regularLanguageOf_rejectedInitialRG [Fintype Γ] [Fintype Λ]
    (n : Nat) :
    Regular.EncodedRG.regularLanguageOf
        (rejectedInitialRG (Γ := Γ) (Λ := Λ) n) =
      ({[Symbol.separator]} : Language (HistoryAlphabet Γ Λ)) *
        (initialRowVerifier (Γ := Γ) (Λ := Λ) n).rejectBlockLanguage := by
  rw [← Regular.EncodedRG.rgLanguage_toRG,
    rejectedInitial_rgLanguage_eq_dfa, RG_of_DFA_language,
    rejectedInitialDFA_accepts]

/-- The positive compiler preserves this block language exactly, since every
word in it begins with a separator. -/
theorem contextFreeLanguageOf_rejectedInitialCFG [Fintype Γ] [Fintype Λ]
    (n : Nat) :
    contextFreeLanguageOf (rejectedInitialCFG (Γ := Γ) (Λ := Λ) n) =
      ({[Symbol.separator]} : Language (HistoryAlphabet Γ Λ)) *
        (initialRowVerifier (Γ := Γ) (Λ := Λ) n).rejectBlockLanguage := by
  letI : DecidableEq (CellAlphabet Γ Λ) := inferInstance
  unfold rejectedInitialCFG
  rw [Regular.EncodedRG.contextFreeLanguageOf_positivePart,
    regularLanguageOf_rejectedInitialRG]
  ext w
  constructor
  · exact fun hw => hw.1
  · intro hw
    refine ⟨hw, ?_⟩
    rintro rfl
    rw [Language.mem_mul] at hw
    obtain ⟨pre, hpre, suffix, -, happend⟩ := hw
    change pre = [Symbol.separator] at hpre
    subst pre
    simp at happend

/-- Add the arbitrary sequence of later row blocks to the rejected first
block.  The first summand is needed because an epsilon-free code for
`blocksLanguage` denotes only its positive part. -/
noncomputable def initialErrorCFG [Fintype Γ] [Fintype Λ]
    (blocksCode : EncodedCFG (HistoryAlphabet Γ Λ))
    (n : Nat) : EncodedCFG (HistoryAlphabet Γ Λ) :=
  union (rejectedInitialCFG (Γ := Γ) (Λ := Λ) n)
    (concat (rejectedInitialCFG (Γ := Γ) (Λ := Λ) n) blocksCode)

/-- If `blocksCode` denotes the positive part of `blocksLanguage`, the
effective initial-error compiler denotes the full relaxed bad-initial
component, including histories consisting of just the rejected first row. -/
theorem contextFreeLanguageOf_initialErrorCFG [Fintype Γ] [Fintype Λ]
    (blocksCode : EncodedCFG (HistoryAlphabet Γ Λ))
    (hblocks : contextFreeLanguageOf blocksCode =
      blocksLanguage \ ({[]} : Set (List (HistoryAlphabet Γ Λ))))
    (n : Nat) :
    contextFreeLanguageOf
        (initialErrorCFG (Γ := Γ) (Λ := Λ) blocksCode n) =
      relaxedBadInitialLanguage
        (initialRowVerifier (Γ := Γ) (Λ := Λ) n).Accepts := by
  letI : DecidableEq (CellAlphabet Γ Λ) := inferInstance
  rw [initialErrorCFG, contextFreeLanguageOf_union,
    contextFreeLanguageOf_concat,
    contextFreeLanguageOf_rejectedInitialCFG, hblocks,
    ← (initialRowVerifier (Γ := Γ) (Λ := Λ) n).badInitialRealization_eq]
  ext w
  simp only [Language.mem_add]
  constructor
  · rintro (hfirst | hlong)
    · rw [Language.mem_mul] at hfirst
      obtain ⟨separator, hseparator, rejected, hrejected, rfl⟩ := hfirst
      rw [RowVerifier.badInitialRealization, Language.mem_mul]
      refine ⟨separator, hseparator, rejected, ?_, by simp⟩
      rw [Language.mem_mul]
      refine ⟨rejected, hrejected, [], ?_, by simp⟩
      rw [mem_blocksLanguage_iff]
      exact ⟨[], rfl⟩
    · rw [Language.mem_mul] at hlong
      obtain ⟨first, hfirst, tail, htail, rfl⟩ := hlong
      rw [Language.mem_mul] at hfirst
      obtain ⟨separator, hseparator, rejected, hrejected, rfl⟩ := hfirst
      rw [RowVerifier.badInitialRealization, Language.mem_mul]
      refine ⟨separator, hseparator, rejected ++ tail, ?_, by simp⟩
      rw [Language.mem_mul]
      exact ⟨rejected, hrejected, tail, htail.1, rfl⟩
  · intro hbad
    rw [RowVerifier.badInitialRealization, Language.mem_mul] at hbad
    obtain ⟨separator, hseparator, rest, hrest, rfl⟩ := hbad
    rw [Language.mem_mul] at hrest
    obtain ⟨rejected, hrejected, tail, htail, rfl⟩ := hrest
    by_cases htailNil : tail = []
    · left
      subst tail
      rw [Language.mem_mul]
      exact ⟨separator, hseparator, rejected, hrejected, by simp⟩
    · right
      rw [Language.mem_mul]
      refine ⟨separator ++ rejected, ?_, tail, ⟨htail, ?_⟩, by simp⟩
      · rw [Language.mem_mul]
        exact ⟨separator, hseparator, rejected, hrejected, rfl⟩
      · simpa using htailNil

section Computability

variable [Fintype Γ] [Fintype Λ]
  [DecidableEq Γ] [DecidableEq Λ]
  [Primcodable (CellAlphabet Γ Λ)]
  [Primcodable (HistoryAlphabet Γ Λ)]

private theorem paddingEq_primrec :
    Primrec (fun p : (Nat × Nat) × CellAlphabet Γ Λ =>
      decide (p.2 = paddingCell)) := by
  exact (PrimrecRel.decide Primrec.eq).comp Primrec.snd
    (Primrec.const paddingCell)

private theorem markerAndZero_primrec :
    Primrec (fun p : (Nat × Nat) × CellAlphabet Γ Λ =>
      decide (p.2 = markerCell ∧ p.1.2 = 0)) := by
  have ha : Primrec (fun p : (Nat × Nat) × CellAlphabet Γ Λ =>
      decide (p.2 = markerCell)) :=
    (PrimrecRel.decide Primrec.eq).comp Primrec.snd
      (Primrec.const markerCell)
  have hq : Primrec (fun p : (Nat × Nat) × CellAlphabet Γ Λ =>
      decide (p.1.2 = 0)) :=
    (PrimrecRel.decide Primrec.eq).comp
      (Primrec.snd.comp Primrec.fst) (Primrec.const 0)
  simpa only [Bool.decide_and] using Primrec.and.comp ha hq

private theorem unaryProgress_primrec :
    Primrec (fun p : (Nat × Nat) × CellAlphabet Γ Λ =>
      decide (p.2 = unaryCell ∧ 0 < p.1.2 ∧ p.1.2 ≤ p.1.1)) := by
  have ha : Primrec (fun p : (Nat × Nat) × CellAlphabet Γ Λ =>
      decide (p.2 = unaryCell)) :=
    (PrimrecRel.decide Primrec.eq).comp Primrec.snd
      (Primrec.const unaryCell)
  have hpos : Primrec (fun p : (Nat × Nat) × CellAlphabet Γ Λ =>
      decide (0 < p.1.2)) :=
    (PrimrecRel.decide Primrec.nat_lt).comp (Primrec.const 0)
      (Primrec.snd.comp Primrec.fst)
  have hle : Primrec (fun p : (Nat × Nat) × CellAlphabet Γ Λ =>
      decide (p.1.2 ≤ p.1.1)) :=
    (PrimrecRel.decide Primrec.nat_le).comp
      (Primrec.snd.comp Primrec.fst)
      (Primrec.fst.comp Primrec.fst)
  simpa only [Bool.decide_and, Bool.and_assoc] using
    Primrec.and.comp ha (Primrec.and.comp hpos hle)

theorem rowProgress_primrec :
    Primrec (fun p : (Nat × Nat) × CellAlphabet Γ Λ =>
      rowProgress p.1.1 p.1.2 p.2) := by
  have hq : Primrec (fun p : (Nat × Nat) × CellAlphabet Γ Λ => p.1.2) :=
    Primrec.snd.comp Primrec.fst
  have hone : Primrec (fun _ : (Nat × Nat) × CellAlphabet Γ Λ => (1 : Nat)) :=
    Primrec.const 1
  have hsucc : Primrec (fun p : (Nat × Nat) × CellAlphabet Γ Λ => p.1.2 + 1) :=
    Primrec.succ.comp hq
  have hbad : Primrec (fun p : (Nat × Nat) × CellAlphabet Γ Λ => p.1.1 + 2) :=
    (Primrec.nat_add.comp (Primrec.fst.comp Primrec.fst) (Primrec.const 2))
  simpa only [rowProgress, Bool.cond_decide] using
    Primrec.cond paddingEq_primrec hq
      (Primrec.cond markerAndZero_primrec hone
        (Primrec.cond unaryProgress_primrec hsucc hbad))

theorem separatorStep_primrec :
    Primrec (fun p : Nat × Nat => separatorStep p.1 p.2) := by
  have hzero : Primrec (fun p : Nat × Nat => decide (p.2 = 0)) :=
    (PrimrecRel.decide Primrec.eq).comp Primrec.snd (Primrec.const 0)
  have hscan : Primrec (fun p : Nat × Nat => decide (p.2 ≤ p.1 + 3)) := by
    apply (PrimrecRel.decide Primrec.nat_le).comp Primrec.snd
    exact Primrec.nat_add.comp Primrec.fst (Primrec.const 3)
  have hgood : Primrec (fun p : Nat × Nat =>
      decide (p.2 - 1 = p.1 + 1)) := by
    apply (PrimrecRel.decide Primrec.eq).comp
    · exact Primrec.nat_sub.comp Primrec.snd (Primrec.const 1)
    · exact Primrec.nat_add.comp Primrec.fst (Primrec.const 1)
  have hone : Primrec (fun _ : Nat × Nat => (1 : Nat)) := Primrec.const 1
  have hboundaryState : Primrec (fun p : Nat × Nat => p.1 + 4) :=
    Primrec.nat_add.comp Primrec.fst (Primrec.const 4)
  have hdead : Primrec (fun p : Nat × Nat => p.1 + 5) :=
    Primrec.nat_add.comp Primrec.fst (Primrec.const 5)
  simpa only [separatorStep, Bool.cond_decide] using
    Primrec.cond hzero hone
      (Primrec.cond hscan (Primrec.cond hgood hdead hboundaryState) hdead)

theorem cellStep_primrec :
    Primrec (fun p : (Nat × Nat) × CellAlphabet Γ Λ =>
      cellStep p.1.1 p.1.2 p.2) := by
  -- The branch structure is arithmetic; spelling it through primitive
  -- recursive conditionals keeps the emitted code visibly uniform in `n`.
  have hzero : Primrec (fun p : (Nat × Nat) × CellAlphabet Γ Λ =>
      decide (p.1.2 = 0)) :=
    (PrimrecRel.decide Primrec.eq).comp
      (Primrec.snd.comp Primrec.fst) (Primrec.const 0)
  have hscan : Primrec (fun p : (Nat × Nat) × CellAlphabet Γ Λ =>
      decide (p.1.2 ≤ p.1.1 + 3)) := by
    apply (PrimrecRel.decide Primrec.nat_le).comp
      (Primrec.snd.comp Primrec.fst)
    exact Primrec.nat_add.comp (Primrec.fst.comp Primrec.fst) (Primrec.const 3)
  have hdead : Primrec (fun p : (Nat × Nat) × CellAlphabet Γ Λ => p.1.1 + 5) :=
    Primrec.nat_add.comp (Primrec.fst.comp Primrec.fst) (Primrec.const 5)
  have hprogress : Primrec (fun p : (Nat × Nat) × CellAlphabet Γ Λ =>
      rowProgress p.1.1 (p.1.2 - 1) p.2 + 1) := by
    have hinput : Primrec (fun p : (Nat × Nat) × CellAlphabet Γ Λ =>
        ((p.1.1, p.1.2 - 1), p.2)) :=
      Primrec.pair
        (Primrec.pair (Primrec.fst.comp Primrec.fst)
          (Primrec.nat_sub.comp (Primrec.snd.comp Primrec.fst)
            (Primrec.const 1)))
        Primrec.snd
    exact Primrec.succ.comp (rowProgress_primrec.comp hinput)
  simpa only [cellStep, Bool.cond_decide] using
    Primrec.cond hzero hdead (Primrec.cond hscan hprogress hdead)

private theorem stateRules_primrec :
    Primrec (fun p : Nat × Nat =>
      stateRules (Γ := Γ) (Λ := Λ) p.1 p.2) := by
  let allCells : List (CellAlphabet Γ Λ) := Finset.univ.toList
  have hseparator : Primrec (fun p : Nat × Nat =>
      ((p.2, some (Symbol.separator, some (separatorStep p.1 p.2))) :
        Nat × Option (HistoryAlphabet Γ Λ × Option Nat))) := by
    exact Primrec.pair Primrec.snd
      (Primrec.option_some.comp
        (Primrec.pair (Primrec.const Symbol.separator)
          (Primrec.option_some.comp separatorStep_primrec)))
  have hcellSymbol : Primrec
      (Symbol.cell : CellAlphabet Γ Λ → HistoryAlphabet Γ Λ) :=
    Primrec.dom_finite _
  have hcellRule : Primrec₂ (fun (p : Nat × Nat) (a : CellAlphabet Γ Λ) =>
      ((p.2, some (Symbol.cell a, some (cellStep p.1 p.2 a))) :
        Nat × Option (HistoryAlphabet Γ Λ × Option Nat))) := by
    show Primrec (fun q : (Nat × Nat) × CellAlphabet Γ Λ =>
      ((q.1.2, some (Symbol.cell q.2,
        some (cellStep q.1.1 q.1.2 q.2))) :
          Nat × Option (HistoryAlphabet Γ Λ × Option Nat)))
    exact Primrec.pair (Primrec.snd.comp Primrec.fst)
      (Primrec.option_some.comp
        (Primrec.pair (hcellSymbol.comp Primrec.snd)
          (Primrec.option_some.comp cellStep_primrec)))
  have hmapped : Primrec (fun p : Nat × Nat =>
      allCells.map fun a =>
        ((p.2, some (Symbol.cell a, some (cellStep p.1 p.2 a))) :
          Nat × Option (HistoryAlphabet Γ Λ × Option Nat))) :=
    Primrec.list_map (Primrec.const allCells) hcellRule
  have hcons := Primrec.list_cons.comp hseparator hmapped
  simpa only [stateRules, allCells] using hcons

theorem rejectedInitialRG_primrec :
    Primrec (rejectedInitialRG (Γ := Γ) (Λ := Λ) :
      Nat → Regular.EncodedRG (HistoryAlphabet Γ Λ)) := by
  have hrange : Primrec (fun n : Nat => List.range (n + 6)) :=
    Primrec.list_range.comp
      (Primrec.nat_add.comp Primrec.id (Primrec.const 6))
  have hstate : Primrec₂ (fun n state =>
      stateRules (Γ := Γ) (Λ := Λ) n state) := by
    exact stateRules_primrec.to₂
  have htransitions : Primrec (fun n : Nat =>
      (List.range (n + 6)).flatMap
        (stateRules (Γ := Γ) (Λ := Λ) n)) :=
    Primrec.list_flatMap hrange hstate
  have hepsilon : Primrec (fun n : Nat =>
      [((n + 4, none) :
        Nat × Option (HistoryAlphabet Γ Λ × Option Nat))]) :=
    Primrec.list_cons.comp
      (Primrec.pair
        (Primrec.nat_add.comp Primrec.id (Primrec.const 4))
        (Primrec.const none))
      (Primrec.const [])
  have hrules : Primrec (fun n : Nat =>
      (List.range (n + 6)).flatMap
          (stateRules (Γ := Γ) (Λ := Λ) n) ++
        [((n + 4, none) :
          Nat × Option (HistoryAlphabet Γ Λ × Option Nat))]) :=
    Primrec.list_append.comp htransitions hepsilon
  exact Primrec.pair
    (Primrec.nat_add.comp Primrec.id (Primrec.const 5))
    (Primrec.pair (Primrec.const 0) hrules)

theorem rejectedInitialCFG_primrec :
    Primrec (rejectedInitialCFG (Γ := Γ) (Λ := Λ) :
      Nat → EncodedCFG (HistoryAlphabet Γ Λ)) :=
  Regular.EncodedRG.positivePart_primrec.comp rejectedInitialRG_primrec

theorem rejectedInitialCFG_computable :
    Computable (rejectedInitialCFG (Γ := Γ) (Λ := Λ) :
      Nat → EncodedCFG (HistoryAlphabet Γ Λ)) :=
  rejectedInitialCFG_primrec.to_comp

omit [Primcodable (CellAlphabet Γ Λ)]
  [Primcodable (HistoryAlphabet Γ Λ)] in
theorem rejectedInitialCFG_noEmptyRHS (n : Nat) :
    NoEmptyRHS (rejectedInitialCFG (Γ := Γ) (Λ := Λ) n) :=
  Regular.EncodedRG.positivePart_noEmptyRHS _

theorem initialErrorCFG_primrec
    (blocksCode : EncodedCFG (HistoryAlphabet Γ Λ)) :
    Primrec (initialErrorCFG (Γ := Γ) (Λ := Λ) blocksCode) := by
  have hrejected := rejectedInitialCFG_primrec (Γ := Γ) (Λ := Λ)
  have hconcat : Primrec (fun n => concat
      (rejectedInitialCFG (Γ := Γ) (Λ := Λ) n) blocksCode) :=
    concat_primrec.comp
      (Primrec.pair hrejected (Primrec.const blocksCode))
  exact union_primrec.comp (Primrec.pair hrejected hconcat)

omit [Primcodable (CellAlphabet Γ Λ)]
  [Primcodable (HistoryAlphabet Γ Λ)] in
theorem initialErrorCFG_noEmptyRHS
    {blocksCode : EncodedCFG (HistoryAlphabet Γ Λ)}
    (hblocks : NoEmptyRHS blocksCode) (n : Nat) :
    NoEmptyRHS
      (initialErrorCFG (Γ := Γ) (Λ := Λ) blocksCode n) :=
  noEmptyRHS_union (rejectedInitialCFG_noEmptyRHS n)
    (noEmptyRHS_concat (rejectedInitialCFG_noEmptyRHS n) hblocks)

end Computability

end ContextFree.MalformedHistories.InitialErrorCompiler
