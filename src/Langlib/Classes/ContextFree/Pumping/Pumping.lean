/-!
# Pumping Lemma for Context-Free Grammars

This file contains the proof of the pumping lemma for context-free grammars

## Main theorems
* `Language.IsContextFree.pumping`: A language generated by a contextfree grammar can be pumped.

## References
* [John E. Hopcroft, Rajeev Motwani, and Jeffrey D. Ullman. 2006. Introduction to Automata Theory,
   Languages, and Computation (3rd Edition). Addison-Wesley Longman Publishing Co., Inc., USA.]
   [Hopcroft et al. 2006]
-/

public theorem pidgeonhole {╬▒ ╬▓ : Type*} {A : Finset ╬▒} {B : Finset ╬▓} {f : A έΗΤ B} (hf : f.Injective) : A.card έΚν B.card := by
  if emptiness : A = έΙΖ then
    simp_all
  else
    obtain έθρaέΓΑ, haέΓΑέθσ := Finset.nonempty_iff_ne_empty.mpr emptiness
    clear emptiness
    classical
    let f' : ╬▒ έΗΤ ╬▓ := fun a => f (if ha : a έΙΙ A then έθρa, haέθσ else έθρaέΓΑ, haέΓΑέθσ)
    apply Finset.card_le_card_of_injOn f'
    ┬╖ intro a ha
      rw [Finset.mem_coe] at ha
      simp only [f', ha, dite_true, Finset.mem_coe]
      exact (f έθρa, haέθσ).property
    ┬╖ intro aέΓΒ haέΓΒ aέΓΓ haέΓΓ haa
      have haa' : f έθρaέΓΒ, haέΓΒέθσ = f έθρaέΓΓ, haέΓΓέθσ := by
        rw [Finset.mem_coe] at haέΓΒ haέΓΓ
        simp only [f', haέΓΒ, haέΓΓ] at haa
        exact Subtype.eq haa
      simpa using hf haa'

universe uT uN

variable {T : Type uT}

namespace ChomskyNormalFormGrammar

/-- `generators g` is the set of nonterminals that appear in the left hand side of rules of `g` -/
@[expose]
public noncomputable def generators (g : ChomskyNormalFormGrammar.{uN, uT} T) [DecidableEq g.NT] :
    Finset g.NT :=
  (g.rules.toList.map ChomskyNormalFormRule.input).toFinset

variable {g : ChomskyNormalFormGrammar.{uN, uT} T}

public lemma pumping_string {u v : List (Symbol T g.NT)} {n : g.NT}
    (hg : g.Derives [Symbol.nonterminal n] (u ++ [Symbol.nonterminal n] ++ v)) (i : έΕΧ):
    g.Derives [Symbol.nonterminal n] (u^+^i ++ [Symbol.nonterminal n] ++ v^+^i) := by
  induction i with
  | zero =>
    simpa using Derives.refl [Symbol.nonterminal n]
  | succ n ih =>
    apply ih.trans
    apply ((hg.append_left _).append_right _).trans
    rw [List.append_assoc, List.append_assoc, έΗΡ nTimes_succ_l, έΗΡ List.append_assoc, έΗΡ List.append_assoc, έΗΡ nTimes_succ_r]

public lemma subtree_height_le {nέΓΒ nέΓΓ : g.NT} {pέΓΒ : parseTree nέΓΒ} {pέΓΓ : parseTree nέΓΓ} (hpp : pέΓΓ.IsSubtreeOf pέΓΒ) :
    pέΓΓ.height έΚν pέΓΒ.height := by
  induction hpp with
  | eq => rfl
  | left_sub _ _ _ _ _ ih => exact Nat.le_add_right_of_le (le_sup_of_le_left ih)
  | right_sub _ _ _ _ _ ih => exact Nat.le_add_right_of_le (le_sup_of_le_right ih)

variable [DecidableEq g.NT]

public lemma input_mem_generators {r : ChomskyNormalFormRule T g.NT} (hrg : r έΙΙ g.rules) :
    r.input έΙΙ g.generators := by
  unfold generators
  rw [έΗΡ Finset.mem_toList] at hrg
  revert hrg
  induction g.rules.toList with
  | nil => simp
  | cons _ _ ih => aesop

variable [DecidableEq (╬μ _n : g.NT, parseTree _n)]

public lemma subtree_repeat_root_height_ind {n : g.NT} {p : parseTree n}
    (s : Finset (╬μ _n : g.NT, parseTree _n)) (hs : έΙΑ eέΓΒ έΙΙ s, έΙΑ eέΓΓ έΙΙ s, eέΓΒ.fst = eέΓΓ.fst έΗΤ eέΓΒ = eέΓΓ)
    (hp : g.generators.card.succ έΚν p.height + s.card) (hps : έΙΑ pέΓδ έΙΙ s, p.IsSubtreeOf pέΓδ.snd) :
    (έΙΔ n' : g.NT, έΙΔ p' p'' : parseTree n',
      p'.IsSubtreeOf p έΙπ p''.IsSubtreeOf p' έΙπ p' έΚι p'') έΙρ
    (έΙΔ nέΓΑ, έΙΔ t t' : parseTree nέΓΑ, έθρnέΓΑ, tέθσ έΙΙ s έΙπ t'.IsSubtreeOf p) := by
  induction p generalizing s with
  | @leaf n t hnt =>
    rw [Nat.succ_eq_add_one, parseTree.height, add_comm, Nat.add_le_add_iff_left] at hp
    by_contra! was_goal
    have pidgeon : ┬υ(έΙΔ f : { q // q έΙΙ (insert έθρn, parseTree.leaf t hntέθσ s) } έΗΤ g.generators, f.Injective) := by
      push_neg
      intro f hf
      have := pidgeonhole hf
      have : (insert έθρn, parseTree.leaf t hntέθσ s).card = s.card + 1 :=
        Finset.card_insert_of_notMem (was_goal.right n (.leaf t hnt) (.leaf t hnt) ┬╖
          (parseTree.IsSubtreeOf.refl))
      omega
    apply pidgeon
    use fun z =>
      έθρz.val.fst, by
        cases z.val.snd with
        | leaf _ hnt =>
          exact input_mem_generators hnt
        | node tέΓΒ tέΓΓ hnc =>
          exact input_mem_generators hnc
      έθσ
    intro x y hxy
    have hx := x.property
    have hy := y.property
    rw [Finset.mem_insert] at hx hy
    cases hx with
    | inl hxt =>
      simp only [hxt, Subtype.mk.injEq] at hxy
      cases hy with
      | inl hyt =>
        apply Subtype.eq
        rw [hxt, hyt]
      | inr hys =>
        exfalso
        exact was_goal.right n (hxy έΨ╕ y.val.snd) (parseTree.leaf t hnt) (by convert hys; aesop)
          (parseTree.IsSubtreeOf.refl)
    | inr hxs =>
      cases hy with
      | inl hyt =>
        simp only [hyt, Subtype.mk.injEq] at hxy
        exfalso
        exact was_goal.right n (hxy έΨ╕ x.val.snd) (parseTree.leaf t hnt) (by convert hxs <;> aesop)
          (parseTree.IsSubtreeOf.refl)
      | inr hys =>
        exact Subtype.eq (hs x hxs y hys (by simp_all))
  | @node nέΓΑ _ _ tέΓΒ tέΓΓ hnc ihέΓΒ ihέΓΓ =>
    if hnέΓΑ : έΙΔ tέΓΑ : parseTree nέΓΑ, έθρnέΓΑ, tέΓΑέθσ έΙΙ s then
      right
      obtain έθρtέΓΑ, htέΓΑέθσ := hnέΓΑ
      refine έθρ_, tέΓΑ, parseTree.node tέΓΒ tέΓΓ hnc, htέΓΑ, parseTree.IsSubtreeOf.reflέθσ
    else
      have hcard : (insert έθρnέΓΑ, parseTree.node tέΓΒ tέΓΓ hncέθσ s).card = 1 + s.card := by
        rw [add_comm]
        exact Finset.card_insert_of_notMem (hnέΓΑ έθρ_, ┬╖έθσ)
      specialize ihέΓΒ (insert έθρnέΓΑ, parseTree.node tέΓΒ tέΓΓ hncέθσ s)
      specialize ihέΓΓ (insert έθρnέΓΑ, parseTree.node tέΓΒ tέΓΓ hncέθσ s)
      simp only [parseTree.height] at hp
      rw [add_assoc, έΗΡhcard, max_add, le_max_iff] at hp
      have hes :
        έΙΑ eέΓΒ έΙΙ insert έθρnέΓΑ, tέΓΒ.node tέΓΓ hncέθσ s,
        έΙΑ eέΓΓ έΙΙ insert έθρnέΓΑ, tέΓΒ.node tέΓΓ hncέθσ s,
          eέΓΒ.fst = eέΓΓ.fst έΗΤ eέΓΒ = eέΓΓ := by
        intro eέΓΒ heέΓΒ eέΓΓ heέΓΓ hee
        rw [Finset.mem_insert] at heέΓΒ heέΓΓ
        cases heέΓΒ with
        | inl heέΓΒ =>
          cases heέΓΓ with
          | inl heέΓΓ =>
            rw [heέΓΒ, heέΓΓ]
          | inr heέΓΓ =>
            exfalso
            apply hnέΓΑ
            rw [heέΓΒ] at hee
            dsimp only at hee
            rw [hee]
            use eέΓΓ.snd
        | inr heέΓΒ =>
          cases heέΓΓ with
          | inl heέΓΓ =>
            exfalso
            apply hnέΓΑ
            rw [heέΓΓ] at hee
            dsimp only at hee
            rw [έΗΡhee]
            use eέΓΒ.snd
          | inr heέΓΓ =>
            exact hs _ heέΓΒ _ heέΓΓ hee
      cases hp with
      | inl hcardέΓΒ =>
        have hstέΓΒ : έΙΑ e έΙΙ insert έθρnέΓΑ, tέΓΒ.node tέΓΓ hncέθσ s, tέΓΒ.IsSubtreeOf e.snd := by
          intro e he
          rw [Finset.mem_insert] at he
          cases he with
          | inl he => exact he έΨ╕ parseTree.IsSubtreeOf.left_sub tέΓΒ tέΓΓ tέΓΒ hnc parseTree.IsSubtreeOf.refl
          | inr he => exact (parseTree.IsSubtreeOf.left_sub tέΓΒ tέΓΓ tέΓΒ hnc parseTree.IsSubtreeOf.refl).trans (hps _ he)
        cases ihέΓΒ hes hcardέΓΒ hstέΓΒ with
        | inl hp =>
          left
          obtain έθρn', p', p'', hp', hp'', hpέθσ := hp
          exact έθρn', p', p'', parseTree.IsSubtreeOf.left_sub tέΓΒ tέΓΓ p' hnc hp', hp'', hpέθσ
        | inr ht =>
          obtain έθρnέΓΑ, t, t', ht, ht'έθσ := ht
          rw [Finset.mem_insert] at ht
          cases ht with
          | inr hts =>
            right
            exact έθρnέΓΑ, t, t', hts, parseTree.IsSubtreeOf.left_sub tέΓΒ tέΓΓ t' hnc ht'έθσ
          | inl httt =>
            rw [Sigma.mk.inj_iff] at httt
            obtain έθρhnέΓΑ, htέθσ := httt
            left
            use nέΓΑ, tέΓΒ.node tέΓΓ (hnέΓΑ έΨ╕ hnc), t', hnέΓΑ έΨ╕ @parseTree.IsSubtreeOf.eq _ _ _ (tέΓΒ.node tέΓΓ hnc) , parseTree.IsSubtreeOf.left_sub _ _ _ _ ht'
            intro ht
            obtain htt' := parseTree.subtree_height ht'
            rw [έΗΡ ht] at htt'
            simp only [parseTree.height] at htt'
            omega
      | inr hcardέΓΓ =>
        -- This entire branch is the same as `inl hcardέΓΒ` except for `left_sub`/`right_sub` and `tέΓΒ`/`tέΓΓ` :/
        have hstέΓΓ : έΙΑ e έΙΙ insert έθρnέΓΑ, tέΓΒ.node tέΓΓ hncέθσ s, tέΓΓ.IsSubtreeOf e.snd := by
          intro e he
          rw [Finset.mem_insert] at he
          cases he with
          | inl he => exact he έΨ╕ parseTree.IsSubtreeOf.right_sub tέΓΒ tέΓΓ tέΓΓ hnc parseTree.IsSubtreeOf.refl
          | inr he => exact (parseTree.IsSubtreeOf.right_sub tέΓΒ tέΓΓ tέΓΓ hnc parseTree.IsSubtreeOf.refl).trans (hps _ he)
        cases ihέΓΓ hes hcardέΓΓ hstέΓΓ with
        | inl hp =>
          left
          obtain έθρn', p', p'', hp', hp'', hpέθσ := hp
          exact έθρn', p', p'', parseTree.IsSubtreeOf.right_sub tέΓΒ tέΓΓ p' hnc hp', hp'', hpέθσ
        | inr ht =>
          obtain έθρnέΓΑ, t, t', ht, ht'έθσ := ht
          rw [Finset.mem_insert] at ht
          cases ht with
          | inr hts =>
            right
            exact έθρnέΓΑ, t, t', hts, parseTree.IsSubtreeOf.right_sub tέΓΒ tέΓΓ t' hnc ht'έθσ
          | inl httt =>
            rw [Sigma.mk.inj_iff] at httt
            obtain έθρhnέΓΑ, htέθσ := httt
            left
            use nέΓΑ, tέΓΒ.node tέΓΓ (hnέΓΑ έΨ╕ hnc), t', hnέΓΑ έΨ╕ @parseTree.IsSubtreeOf.eq _ _ _ (tέΓΒ.node tέΓΓ hnc) , parseTree.IsSubtreeOf.right_sub _ _ _ _ ht'
            intro ht
            obtain htt' := parseTree.subtree_height ht'
            rw [έΗΡ ht] at htt'
            simp only [parseTree.height] at htt'
            omega

public lemma subtree_repeat_root_height_aux_aux_aux {n : g.NT} {p : parseTree n}
    (hp : g.generators.card.succ = p.height) :
    έΙΔ n' : g.NT, έΙΔ p' p'' : parseTree n',
      p'.IsSubtreeOf p έΙπ p''.IsSubtreeOf p' έΙπ p' έΚι p'' := by
  cases subtree_repeat_root_height_ind έΙΖ (by simp) (le_of_eq (by simpa using hp)) (by simp) with
  | inl hp' => exact hp'
  | inr hp' => simp at hp'

public lemma subtree_repeat_root_height_aux_aux {n : g.NT} {p : parseTree n}
    (hgp : g.generators.card.succ = p.height) :
    έΙΔ n' : g.NT, έΙΔ p' p'' : parseTree n',
      p'.IsSubtreeOf p έΙπ p''.IsSubtreeOf p' έΙπ p'.height έΚν g.generators.card.succ έΙπ p' έΚι p'' := by
  obtain έθρn', p', p'', hp', hp'', hpέθσ := subtree_repeat_root_height_aux_aux_aux hgp
  exact έθρn', p', p'', hp', hp'', hgp έΨ╕ subtree_height_le hp', hpέθσ

public lemma subtree_repeat_root_height_aux {n : g.NT} {p : parseTree n}
    (hgp : g.generators.card.succ έΚν p.height) :
    έΙΔ n' : g.NT, έΙΔ p' p'' : parseTree n',
      p'.IsSubtreeOf p έΙπ p''.IsSubtreeOf p' έΙπ p'.height έΚν g.generators.card.succ έΙπ p' έΚι p'' := by
  induction p with
  | @leaf n t =>
    exfalso
    have hn : n έΙΙ g.generators := by
      simp [generators]
      use ChomskyNormalFormRule.leaf n t
    simp [parseTree.height] at hgp
    rw [hgp] at hn
    simp at hn
  | node tέΓΒ tέΓΓ hnc ihέΓΒ ihέΓΓ =>
    rw [Nat.le_iff_lt_or_eq] at hgp
    cases hgp with
    | inr hp => exact subtree_repeat_root_height_aux_aux hp
    | inl hp =>
      simp [parseTree.height] at hp
      cases hp with
      | inl hpέΓΒ =>
        obtain έθρn', p', p'', hp', hp'', hpg, hppέθσ := ihέΓΒ hpέΓΒ
        exact έθρn', p', p'', parseTree.IsSubtreeOf.left_sub tέΓΒ tέΓΓ p' hnc hp', hp'', hpg, hppέθσ
      | inr hpέΓΓ =>
        obtain έθρn', p', p'', hp', hp'', hpg, hppέθσ := ihέΓΓ hpέΓΓ
        exact έθρn', p', p'', parseTree.IsSubtreeOf.right_sub tέΓΒ tέΓΓ p' hnc hp', hp'', hpg, hppέθσ

public lemma subtree_repeat_root_height {n : g.NT} {p : parseTree n}
    (hp : p.yield.length έΚξ 2 ^ g.generators.card) :
    έΙΔ n' : g.NT, έΙΔ p' p'' : parseTree n',
      p'.IsSubtreeOf p έΙπ p''.IsSubtreeOf p' έΙπ p'.height έΚν g.generators.card.succ έΙπ p' έΚι p'' := by
  apply subtree_repeat_root_height_aux
  have hp1 := p.height_pos
  have hp2 := hp.trans p.yield_length_le_two_pow_height
  rw [Nat.pow_le_pow_iff_right] at hp2 <;> omega

public lemma pumping {w : List T} (hwg : w έΙΙ g.language) (hw : w.length έΚξ 2 ^ g.generators.card) :
    έΙΔ u v x y z : List T,
      w = u ++ v ++ x ++ y ++ z έΙπ
      (v ++ y).length > 0       έΙπ
      (v ++ x ++ y).length έΚν 2 ^ g.generators.card  έΙπ
      έΙΑ i : έΕΧ, u ++ v^+^i ++ x ++ y^+^i ++ z έΙΙ g.language := by
  obtain έθρp, rflέθσ := hwg.yield
  obtain έθρn, pέΓΒ, pέΓΓ, hpέΓΒ, hpέΓΓ, hpg, hppέθσ := subtree_repeat_root_height hw
  obtain έθρv, y, hpvy, hvy, hgpvyέθσ := parseTree.strict_subtree_decomposition hpέΓΓ hpp
  obtain έθρu, z, hpuz, hguzέθσ := parseTree.subtree_decomposition hpέΓΒ
  refine έθρu, v, pέΓΓ.yield, y, z, ?_, hvy, ?_, ?_έθσ
  ┬╖ simp_rw [hpuz, hpvy, List.append_assoc]
  ┬╖ rw [έΗΡ hpvy]
    apply le_trans pέΓΒ.yield_length_le_two_pow_height
    apply Nat.pow_le_pow_right <;> omega
  ┬╖ intro k
    apply hguz.trans
    repeat rw [List.map_append]
    apply Derives.append_right
    repeat rw [List.append_assoc]
    apply Derives.append_left
    apply (pumping_string hgpvy k).trans
    apply ((Derives.append_left pέΓΓ.yield_derives _).append_right _).trans
    simpa [nTimes] using Derives.refl _

end ChomskyNormalFormGrammar

public theorem Language.IsContextFree.pumping {T : Type} {L : Language T} (hL : L.IsContextFree) :
    έΙΔ p : έΕΧ, έΙΑ w έΙΙ L, w.length έΚξ p έΗΤ έΙΔ u v x y z : List T,
      w = u ++ v ++ x ++ y ++ z έΙπ
      (v ++ y).length > 0       έΙπ
      (v ++ x ++ y).length έΚν p  έΙπ
      έΙΑ i : έΕΧ, u ++ v^+^i ++ x ++ y^+^i ++ z έΙΙ L := by
  obtain έθρg, rflέθσ := hL
  classical
  use 2 ^ g.toCNF.generators.card
  intro w hwg hw2
  by_cases hw : w = []
  ┬╖ simp [hw] at hw2
  ┬╖ obtain έθρu, v, x, y, z, hw, hvy, hvxy, hLέθσ := g.toCNF.pumping (g.toCNF_correct έΨ╕ έθρhwg, hwέθσ) hw2
    exact έθρu, v, x, y, z, hw, hvy, hvxy, fun i => Set.diff_subset (g.toCNF_correct έΨ╕ hL i)έθσ
