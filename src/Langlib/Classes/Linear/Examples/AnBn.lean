/-! # `a^n b^n` as a Linear Language

This file constructs a linear grammar for `{a^n b^n}` and proves that the
language is linear.

## Main results

- `linear_grammar_anbn_language` έΑΦ the grammar generates exactly `anbn`
- `anbn_is_Linear`               έΑΦ `{a^n b^n}` is linear
-/

open Language List Relation Classical

noncomputable section

/-- An unrestricted grammar for the language `{aέΒ┐bέΒ┐ | n έΙΙ έΕΧ}` with linear rules.
Rules:
  S έΗΤ aSb   (i.e., [] S [] έΗΤ [a, S, b])
  S έΗΤ ╬╡     (i.e., [] S [] έΗΤ [])
-/
@[expose]
public def linear_grammar_anbn : grammar Bool where
  nt := Unit
  initial := ()
  rules := [
    έθρ[], (), [], [symbol.terminal false, symbol.nonterminal (), symbol.terminal true]έθσ,
    έθρ[], (), [], []έθσ
  ]

/-- The grammar `linear_grammar_anbn` is linear. -/
public theorem linear_grammar_anbn_is_linear :
    grammar_linear linear_grammar_anbn := by
  intro r hr
  simp [linear_grammar_anbn] at hr
  rcases hr with rfl | rfl <;> refine έθρrfl, rfl, ?_έθσ
  ┬╖ exact Or.inr έθρ[false], (), [true], by simpέθσ
  ┬╖ exact Or.inl (by simp)

/-- Derivation in `linear_grammar_anbn` can produce `aέΒ┐SbέΒ┐`. -/
public lemma linear_grammar_anbn_derives_n (n : έΕΧ) :
    grammar_derives linear_grammar_anbn
      [symbol.nonterminal ()]
      (List.replicate n (symbol.terminal false) ++
        [symbol.nonterminal ()] ++
        List.replicate n (symbol.terminal true)) := by
  induction n with
  | zero => simp; exact ReflTransGen.refl
  | succ n ih =>
    apply ReflTransGen.trans ih
    apply ReflTransGen.single
    refine έθρέθρ[], (), [], [symbol.terminal false, symbol.nonterminal (), symbol.terminal true]έθσ,
      ?_, List.replicate n (symbol.terminal false), List.replicate n (symbol.terminal true), ?_, ?_έθσ
    ┬╖ simp [linear_grammar_anbn]
    ┬╖ simp
    ┬╖ simp [List.replicate_succ']
      rw [έΗΡ List.replicate_succ, έΗΡ List.replicate_succ']

/-- Derivation in `linear_grammar_anbn`: apply ╬╡-rule to get `aέΒ┐bέΒ┐`. -/
public lemma linear_grammar_anbn_derives_final (n : έΕΧ) :
    grammar_derives linear_grammar_anbn
      (List.replicate n (symbol.terminal false) ++
        [symbol.nonterminal ()] ++
        List.replicate n (symbol.terminal true))
      (List.replicate n (symbol.terminal false) ++
        List.replicate n (symbol.terminal true)) := by
  apply ReflTransGen.single
  refine έθρέθρ[], (), [], []έθσ, ?_,
    List.replicate n (symbol.terminal false),
    List.replicate n (symbol.terminal true), ?_, ?_έθσ
  ┬╖ simp [linear_grammar_anbn]
  ┬╖ simp
  ┬╖ simp

/-- Every word in `anbn` is generated by `linear_grammar_anbn`. -/
public lemma anbn_sub_linear_grammar_anbn_language :
    έΙΑ w, w έΙΙ anbn έΗΤ w έΙΙ grammar_language linear_grammar_anbn := by
  intro w hw
  obtain έθρn, rflέθσ := hw
  show grammar_generates linear_grammar_anbn _
  unfold grammar_generates
  have h1 := linear_grammar_anbn_derives_n n
  have h2 := linear_grammar_anbn_derives_final n
  apply ReflTransGen.trans h1
  simp only [List.map_append, List.map_replicate]
  exact h2

/-- A sentential form of `linear_grammar_anbn` is either `aέΒ┐SbέΒ┐` or `aέΒ┐bέΒ┐`. -/
private def anbn_sentential (w : List (symbol Bool Unit)) : Prop :=
  (έΙΔ n : έΕΧ, w = List.replicate n (symbol.terminal false) ++
    [symbol.nonterminal ()] ++
    List.replicate n (symbol.terminal true)) έΙρ
  (έΙΔ n : έΕΧ, w = List.map symbol.terminal
    (List.replicate n false ++ List.replicate n true))

/-
One step of derivation preserves `anbn_sentential` form.
-/
private lemma anbn_sentential_step (w w' : List (symbol Bool Unit))
    (hw : anbn_sentential w) (ht : grammar_transforms linear_grammar_anbn w w') :
    anbn_sentential w' := by
      rcases ht with έθρ r, hr, u, v, hwέΓΒ, hwέΓΓ έθσ;
      rcases hw with ( έθρ n, rfl έθσ | έθρ n, rfl έθσ ) <;> simp_all +decide [ List.append_assoc ];
      ┬╖ rcases r with έθρ L, N, R, S έθσ ; simp_all +decide [ linear_grammar_anbn ];
        rcases hr with ( έθρ rfl, rfl, rfl, rfl έθσ | έθρ rfl, rfl, rfl, rfl έθσ ) <;> simp_all +decide [ anbn_sentential ];
        ┬╖ rw [ List.append_eq_append_iff ] at hwέΓΒ;
          rcases hwέΓΒ with ( έθρ as, rfl, h έθσ | έθρ bs, hέΓΒ, hέΓΓ έθσ ) <;> simp_all +decide [ List.append_eq_append_iff ];
          ┬╖ rcases as with ( _ | έθρ a, as έθσ ) <;> simp_all +decide [  ];
            ┬╖ refine' Or.inl έθρ n + 1, Or.inl έθρ [ symbol.terminal false ], _, _ έθσ έθσ <;> simp +decide [ *, List.replicate ];
              exact Nat.recOn n ( by trivial ) fun n ih => by simp +decide [ List.replicate ] at * ; aesop;
            ┬╖ replace h := congr_arg List.toFinset h.2; rw [ Finset.ext_iff ] at h; specialize h ( symbol.nonterminal () ) ; aesop;
          ┬╖ rcases bs with ( _ | έθρ a, bs έθσ ) <;> simp_all +decide [  ];
            ┬╖ refine Or.inl έθρ n + 1, ?_ έθσ ; simp_all +decide [ List.replicate ];
              exact Or.inl έθρ [ symbol.terminal false ], by rw [ έΗΡ hέΓΒ ] ; exact Nat.recOn n ( by simp +decide ) fun n ihn => by simp +decide [ List.replicate ] at * ; aesop έθσ;
            ┬╖ no_nonterminal (a) at hέΓΒ
        ┬╖ rw [ List.append_eq_append_iff ] at hwέΓΒ;
          rcases hwέΓΒ with ( έθρ as, rfl, h έθσ | έθρ bs, hέΓΒ, hέΓΓ έθσ ) <;> simp_all +decide [ List.append_eq_append_iff ];
          ┬╖ rcases as with ( _ | έθρ a, as έθσ ) <;> simp_all +decide [  ];
            ┬╖ exact Or.inr έθρ n, Or.inl έθρ [ ], by simp +decide [ h.symm ] έθσ έθσ;
            ┬╖ replace h := congr_arg List.toFinset h.2; rw [ Finset.ext_iff ] at h; specialize h ( symbol.nonterminal () ) ; aesop;
          ┬╖ rcases bs with ( _ | έθρ a, bs έθσ ) <;> simp_all +decide [  ];
            ┬╖ exact Or.inr έθρ n, Or.inl έθρ [ ], by aesop έθσ έθσ;
            ┬╖ no_nonterminal (a) at hέΓΒ
      ┬╖ no_nonterminal (symbol.nonterminal r.input_N) at hwέΓΒ

/-- Derivation preserves `anbn_sentential` form. -/
private lemma anbn_sentential_of_derives (w : List (symbol Bool Unit))
    (hd : grammar_derives linear_grammar_anbn [symbol.nonterminal ()] w) :
    anbn_sentential w := by
  induction hd with
  | refl => exact Or.inl έθρ0, by simpέθσ
  | tail _ ht ih => exact anbn_sentential_step _ _ ih ht

/-- Every word generated by `linear_grammar_anbn` is in `anbn`. -/
public lemma linear_grammar_anbn_language_sub_anbn :
    έΙΑ w, w έΙΙ grammar_language linear_grammar_anbn έΗΤ w έΙΙ anbn := by
  intro w hw
  have hsf := anbn_sentential_of_derives (List.map symbol.terminal w) hw
  rcases hsf with έθρn, hnέθσ | έθρn, hnέθσ
  ┬╖ no_nonterminal (symbol.nonterminal ())
  ┬╖ have hinj : Function.Injective (symbol.terminal (T := Bool) (N := Unit)) := by
      intro a b h; cases h; rfl
    exact έθρn, hinj.list_map hnέθσ

/-- The grammar `linear_grammar_anbn` generates exactly `{aέΒ┐bέΒ┐}`. -/
public theorem linear_grammar_anbn_language :
    grammar_language linear_grammar_anbn = anbn := by
  ext w
  exact έθρfun h => linear_grammar_anbn_language_sub_anbn w h,
         fun h => anbn_sub_linear_grammar_anbn_language w hέθσ

/-- The language `{aέΒ┐bέΒ┐}` is linear. -/
public theorem anbn_is_Linear : is_Linear anbn :=
  έθρlinear_grammar_anbn, linear_grammar_anbn_is_linear,
   linear_grammar_anbn_languageέθσ

end
