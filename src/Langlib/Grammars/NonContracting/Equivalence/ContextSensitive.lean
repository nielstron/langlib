        refine ⟨pre + 1, rest, spre, spost, simRi, grule, j, ?_,
          NC_locked_derives_n.step hstep hpre, hremove, hsuf, hpair, hri, hj,
          hmark_spre, hmark_spost, hout⟩
        omega
      · obtain ⟨simRi, grule, j, hpair, hri, hj, hout⟩ :=
          nc_locked_transform_removed_mark_adds_out g hg hstep hsrc hmid
        exact ⟨0, n, s₁, smid, simRi, grule, j, by omega,
          NC_locked_derives_n.zero s₁, hstep, htail, hpair, hri, hj, hsrc,
          hmid, hout⟩

