                ∃ grule,
                  (targetRi, grule) ∈ (List.range g.rules.length).zip g.rules ∧
                    targetK = 0 ∧
                    (let pattern := grule.input_L ++ [symbol.nonterminal grule.input_N] ++
                        grule.input_R
                     targetK < pattern.length))) := by
  obtain ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
      htail, hadded, hcase⟩ :=
    nc_locked_dirty_interval_first_step_emit_shape_or_macro_prefix_with_added_mark_shape
      g hg hstart hclean_start hdirty_after hmid hdirty hreturn hclean
  refine ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
    htail, ?_⟩
  cases hcase with
  | inr hmacro =>
      exact Or.inl hmacro
  | inl hretained =>
      obtain ⟨hmark0, _pre, _rest, _spre, _spost, _j, _hlen, _hpre, _hremove,
