      by_cases hone : nc_locked_mark (g := g) ri 1 ∈ smid
      · have hu : nc_locked_is_clean g u := by
          refine nc_locked_is_clean_of_subset g hclean_start ?_
          intro x hx
          rw [hshape.1]
          simp [List.mem_append, hx]
        have hv : nc_locked_is_clean g v := by
          refine nc_locked_is_clean_of_subset g hclean_start ?_
          intro x hx
