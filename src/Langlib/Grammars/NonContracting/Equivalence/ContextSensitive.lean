        (let dflt : symbol T g.nt := symbol.nonterminal grule.input_N
         s₁ = u ++ [nc_locked_out (g := g) simRi k (grule.output_string.getD k dflt)] ++ v ∧
           s₂ = u ++ [nc_locked_liftSym (grule.output_string.getD k dflt)] ++ v) ∧
        (∀ ri j, nc_locked_mark (g := g) ri j ∉ s₁) ∧
        (∀ ri j a, nc_locked_out (g := g) ri j a ∈ s₁ ↔
          (ri = simRi ∧ j = k ∧ a = grule.output_string.getD k (symbol.nonterminal grule.input_N))) := by
  obtain ⟨simRi, grule, k, u, v, hpair, hk, hshape⟩ :=
    nc_locked_dirty_step_clean_cleanup_shape g hg h hdirty hclean
  dsimp only at hshape
  rcases hshape with ⟨hs₁, hs₂⟩
  let dflt : symbol T g.nt := symbol.nonterminal grule.input_N
  have hu : nc_locked_is_clean g u := by
    refine nc_locked_is_clean_of_subset g hclean ?_
    intro x hx
    rw [hs₂]
    simp [List.mem_append, hx]
  have hv : nc_locked_is_clean g v := by
    refine nc_locked_is_clean_of_subset g hclean ?_
    intro x hx
    rw [hs₂]
    simp [List.mem_append, hx]
  refine ⟨simRi, grule, k, u, v, hpair, hk, hu, hv, ?_, ?_, ?_⟩
  · dsimp only
    exact ⟨hs₁, hs₂⟩
  · intro ri j hmem
    rw [hs₁] at hmem
    simp [List.mem_append] at hmem
    rcases hmem with hmem | hmem | hmem
    · exact ((hu (nc_locked_mark (g := g) ri j) hmem).1 ri j rfl).elim
    · simp [nc_locked_mark, nc_locked_out] at hmem
    · exact ((hv (nc_locked_mark (g := g) ri j) hmem).1 ri j rfl).elim
  · intro ri j a
    constructor
    · intro hmem
      rw [hs₁] at hmem
      simp [List.mem_append] at hmem
      rcases hmem with hmem | hmem | hmem
      · exact ((hu (nc_locked_out (g := g) ri j a) hmem).2 ri j a rfl).elim
      · simp [nc_locked_out] at hmem
        exact hmem
      · exact ((hv (nc_locked_out (g := g) ri j a) hmem).2 ri j a rfl).elim
    · rintro ⟨rfl, rfl, rfl⟩
      rw [hs₁]
      simp [List.mem_append, nc_locked_out]

/-! ### Counted locked derivations -/

/-- Step-counted derivations for the locked construction.  This is equivalent to
`CS_derives`, but exposes split points needed by the dirty-phase grouping proof. -/
inductive NC_locked_derives_n (g : grammar T) (hg : grammar_noncontracting g) :
    ℕ → List (symbol T (NC_LockedNT g)) →
      List (symbol T (NC_LockedNT g)) → Prop
  | zero (s) :
      NC_locked_derives_n g hg 0 s s
  | step {n s₁ s₂ s₃} :
      CS_transforms (locked_csg_of_noncontracting g hg) s₁ s₂ →
      NC_locked_derives_n g hg n s₂ s₃ →
      NC_locked_derives_n g hg (n + 1) s₁ s₃

lemma nc_locked_derives_n_to_derives (g : grammar T)
    (hg : grammar_noncontracting g)
    {n : ℕ} {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : NC_locked_derives_n g hg n s₁ s₂) :
    CS_derives (locked_csg_of_noncontracting g hg) s₁ s₂ := by
  induction h with
  | zero _ =>
      exact CS_deri_self
  | step hstep _ ih =>
      exact CS_deri_of_tran_deri hstep ih

lemma nc_locked_derives_n_append (g : grammar T)
    (hg : grammar_noncontracting g)
    {n : ℕ} {s₁ s₂ s₃ : List (symbol T (NC_LockedNT g))}
    (h : NC_locked_derives_n g hg n s₁ s₂)
    (hstep : CS_transforms (locked_csg_of_noncontracting g hg) s₂ s₃) :
    NC_locked_derives_n g hg (n + 1) s₁ s₃ := by
  induction h generalizing s₃ with
  | zero _ =>
      exact NC_locked_derives_n.step hstep (NC_locked_derives_n.zero s₃)
  | step hfirst _ ih =>
      exact NC_locked_derives_n.step hfirst (ih hstep)

lemma nc_locked_derives_to_derives_n (g : grammar T)
    (hg : grammar_noncontracting g)
    {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : CS_derives (locked_csg_of_noncontracting g hg) s₁ s₂) :
    ∃ n, NC_locked_derives_n g hg n s₁ s₂ := by
  induction h with
  | refl =>
      exact ⟨0, NC_locked_derives_n.zero s₁⟩
  | tail _ hstep ih =>
      obtain ⟨n, hn⟩ := ih
      exact ⟨n + 1, nc_locked_derives_n_append g hg hn hstep⟩

lemma nc_locked_derives_n_tail (g : grammar T)
    (hg : grammar_noncontracting g)
    {n : ℕ} {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : NC_locked_derives_n g hg (n + 1) s₁ s₂) :
    ∃ s_last, NC_locked_derives_n g hg n s₁ s_last ∧
      CS_transforms (locked_csg_of_noncontracting g hg) s_last s₂ := by
  induction n generalizing s₁ s₂ with
  | zero =>
      cases h with
      | step hstep hrest =>
          cases hrest
          exact ⟨s₁, NC_locked_derives_n.zero s₁, hstep⟩
  | succ n ih =>
      cases h with
      | step hstep hrest =>
          obtain ⟨s_last, hprefix, hlast⟩ := ih hrest
          exact ⟨s_last, NC_locked_derives_n.step hstep hprefix, hlast⟩

lemma nc_locked_derives_n_split (g : grammar T)
    (hg : grammar_noncontracting g)
    {m n : ℕ} {s₁ s₃ : List (symbol T (NC_LockedNT g))}
    (h : NC_locked_derives_n g hg (m + n) s₁ s₃) :
    ∃ s₂, NC_locked_derives_n g hg m s₁ s₂ ∧
      NC_locked_derives_n g hg n s₂ s₃ := by
  induction m generalizing s₁ s₃ with
  | zero =>
      exact ⟨s₁, NC_locked_derives_n.zero s₁, by simpa using h⟩
  | succ m ih =>
      rw [Nat.succ_add] at h
      cases h with
      | step hstep hrest =>
          obtain ⟨s₂, hleft, hright⟩ := ih hrest
          exact ⟨s₂, NC_locked_derives_n.step hstep hleft, hright⟩

lemma nc_locked_derives_n_removed_mark_event (g : grammar T)
    (hg : grammar_noncontracting g)
    {n : ℕ} {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : NC_locked_derives_n g hg n s₁ s₂)
    {ri k : ℕ}
    (hsrc : nc_locked_mark (g := g) ri k ∈ s₁)
    (htgt : nc_locked_mark (g := g) ri k ∉ s₂) :
    ∃ m rest smid simRi grule j,
      n = m + rest ∧
        NC_locked_derives_n g hg m s₁ smid ∧
        NC_locked_derives_n g hg rest smid s₂ ∧
        (simRi, grule) ∈ (List.range g.rules.length).zip g.rules ∧
        ri = simRi ∧ j < grule.output_string.length ∧
        nc_locked_out (g := g) simRi j
          (grule.output_string.getD j (symbol.nonterminal grule.input_N)) ∈ smid := by
  induction h with
  | zero s =>
      exact (htgt hsrc).elim
  | step hstep htail ih =>
      rename_i n s₁ smid s₂
      by_cases hmid : nc_locked_mark (g := g) ri k ∈ smid
      · obtain ⟨m, rest, sevent, simRi, grule, j, hn, hpre, hsuf, hpair,
          hri, hj, hout⟩ := ih hmid htgt
        refine ⟨m + 1, rest, sevent, simRi, grule, j, ?_,
          NC_locked_derives_n.step hstep hpre, hsuf, hpair, hri, hj, hout⟩
        omega
      · obtain ⟨simRi, grule, j, hpair, hri, hj, hout⟩ :=
          nc_locked_transform_removed_mark_adds_out g hg hstep hsrc hmid
        exact ⟨1, n, smid, simRi, grule, j, by omega,
          NC_locked_derives_n.step hstep (NC_locked_derives_n.zero smid),
          htail, hpair, hri, hj, hout⟩

lemma nc_locked_derives_n_removed_mark_step_event (g : grammar T)
    (hg : grammar_noncontracting g)
    {n : ℕ} {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : NC_locked_derives_n g hg n s₁ s₂)
    {ri k : ℕ}
    (hsrc : nc_locked_mark (g := g) ri k ∈ s₁)
    (htgt : nc_locked_mark (g := g) ri k ∉ s₂) :
    ∃ pre rest spre spost simRi grule j,
      n = pre + 1 + rest ∧
        NC_locked_derives_n g hg pre s₁ spre ∧
        CS_transforms (locked_csg_of_noncontracting g hg) spre spost ∧
        NC_locked_derives_n g hg rest spost s₂ ∧
        (simRi, grule) ∈ (List.range g.rules.length).zip g.rules ∧
        ri = simRi ∧ j < grule.output_string.length ∧
        nc_locked_mark (g := g) ri k ∈ spre ∧
        nc_locked_mark (g := g) ri k ∉ spost ∧
        nc_locked_out (g := g) simRi j
          (grule.output_string.getD j (symbol.nonterminal grule.input_N)) ∈ spost := by
  induction h with
  | zero s =>
