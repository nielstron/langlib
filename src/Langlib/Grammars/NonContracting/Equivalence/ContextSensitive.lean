@[expose] public section

/-! # Non-Contracting and Context-Sensitive

This file contains class-level comparison results between non-contracting
grammars and context-sensitive grammars.

main results
- `grammar_context_sensitive_noncontracting` — every default CS grammar is non-contracting
- `CS_is_noncontracting` — every CS grammar induces a non-contracting unrestricted grammar
- `noncontracting_transforms_length_le` — non-contracting steps don't decrease length
- `csg_of_noncontracting` — translate a non-contracting grammar into a context-sensitive grammar
- `grammar_language_subset_csg_of_noncontracting` — forward correctness of the translation
-/

/-- Every grammar satisfying the default context-sensitive rule-shape predicate is
non-contracting. -/
theorem grammar_context_sensitive_noncontracting (g : grammar T)
    (hg : grammar_context_sensitive g) :
    grammar_noncontracting g := by
  intro r hr
  obtain ⟨γ, hγ, hout⟩ := hg r hr
  rw [hout]
  simp [List.length_append]
  have hγpos : 0 < γ.length := List.length_pos_of_ne_nil hγ
  omega

/-- The unrestricted grammar obtained from a context-sensitive grammar (via `grammar_of_csg`)
    is non-contracting. -/
theorem CS_is_noncontracting (g : CS_grammar T) :
    grammar_noncontracting (grammar_of_csg g) := by
  intro r hr
  simp [grammar_of_csg] at hr
  obtain ⟨cr, hcr, rfl⟩ := hr
  simp
  have hne := g.output_nonempty cr hcr
  have : cr.output_string.length ≥ 1 := List.length_pos_of_ne_nil hne
  omega

/-- Every context-sensitive language is generated by a non-contracting grammar. -/
theorem is_CS_implies_is_noncontracting {L : Language T} (h : is_CS L) :
    is_noncontracting L := by
  obtain ⟨g, hg, hL⟩ := h
  exact ⟨g, grammar_context_sensitive_noncontracting g hg, hL⟩

/-- A single transformation step in a non-contracting grammar does not decrease the length
    of the sentential form. -/
lemma noncontracting_transforms_length_le (g : grammar T)
    (hg : grammar_noncontracting g)
    {w₁ w₂ : List (symbol T g.nt)}
    (h : grammar_transforms g w₁ w₂) : w₁.length ≤ w₂.length := by
  obtain ⟨r, hr, u, v, rfl, rfl⟩ := h
  simp_all [List.length_append]
  linarith [hg r hr]

/-- In a non-contracting grammar, derivation does not decrease the length. -/
lemma noncontracting_derives_length_le (g : grammar T)
    (hg : grammar_noncontracting g)
    {w₁ w₂ : List (symbol T g.nt)}
    (h : grammar_derives g w₁ w₂) : w₁.length ≤ w₂.length := by
  induction h with
  | refl => exact le_refl _
  | tail h₁ h₂ ih => exact le_trans ih (noncontracting_transforms_length_le g hg h₂)

/-! ## Non-contracting → CS

The conversion from a non-contracting grammar to a context-sensitive grammar is a classical
construction. Given a non-contracting rule `L ++ [A] ++ R → output` with
`|output| ≥ |L| + 1 + |R|`, we simulate it using context-sensitive rules with fresh
auxiliary nonterminals.

### Construction

The nonterminal type of the constructed CS grammar is `g.nt ⊕ (T ⊕ (ℕ × ℕ))`:
- `Sum.inl n`: original nonterminal `n`
- `Sum.inr (Sum.inl t)`: a "lifted" nonterminal representing terminal `t`
- `Sum.inr (Sum.inr (i, j))`: auxiliary nonterminal for rule index `i`, step `j`

The sentential forms in the CS grammar always consist entirely of nonterminals
(either `Sum.inl n` or `Sum.inr (Sum.inl t)`), except at the very end when
un-lifting rules convert `Sum.inr (Sum.inl t)` to `terminal t`.

The rules are:
1. **Un-lifting rules**: `Sum.inr (Sum.inl t) → [terminal t]`
2. **Direct rules** (n = 1): `Sum.inl A → map liftSym output`
3. **Phase 1** (n ≥ 2, marking): Replace pattern symbols with auxiliaries left-to-right
4. **Phase 2** (n ≥ 2, output): Replace auxiliaries with output symbols right-to-left
-/

section NoncontractingToCS

variable {T : Type}

/-- Nonterminal type for the CS grammar constructed from a non-contracting grammar. -/
abbrev NC_NT (g : grammar T) := g.nt ⊕ (T ⊕ (ℕ × ℕ))

/-- Convert a symbol to a nonterminal in the new grammar (lifting terminals). -/
def nc_symToNT {g : grammar T} : symbol T g.nt → NC_NT g
  | .terminal t => .inr (.inl t)
  | .nonterminal n => .inl n

/-- Lift a symbol: all symbols become `nonterminal` symbols in the new grammar. -/
def nc_liftSym {g : grammar T} (s : symbol T g.nt) : symbol T (NC_NT g) :=
  .nonterminal (nc_symToNT s)

/-- Auxiliary nonterminal symbol for rule index `ri`, step `k`. -/
def nc_aux {g : grammar T} (ri k : ℕ) : symbol T (NC_NT g) :=
  .nonterminal (.inr (.inr (ri, k)))

/-- Collect all terminals from a list of symbols. -/
def nc_collectTerminals {N : Type} : List (symbol T N) → List T
  | [] => []
  | (.terminal t) :: rest => t :: nc_collectTerminals rest
  | (.nonterminal _) :: rest => nc_collectTerminals rest

/-- All terminals appearing in the grammar's rules (inputs and outputs). -/
def nc_grammarTerminals (g : grammar T) : List T :=
  g.rules.flatMap fun r =>
    nc_collectTerminals (r.input_L ++ r.input_R ++ r.output_string)

/-- Un-lifting rules: convert lifted terminal nonterminals back to actual terminals. -/
def nc_unliftRules (g : grammar T) : List (csrule T (NC_NT g)) :=
  (nc_grammarTerminals g).map fun t =>
    { context_left := [],
      input_nonterminal := .inr (.inl t),
      context_right := [],
      output_string := [.terminal t] }

/-- Generate CS rules for simulating one grammar rule at index `ri`. -/
def nc_simRules {g : grammar T} (ri : ℕ) (r : grule T g.nt) :
    List (csrule T (NC_NT g)) :=
  let pattern := r.input_L ++ [.nonterminal r.input_N] ++ r.input_R
  let n := pattern.length
  let out := r.output_string
  let dflt : symbol T g.nt := .nonterminal r.input_N
  if n ≤ 1 then
    [{ context_left := [],
       input_nonterminal := .inl r.input_N,
       context_right := [],
       output_string := out.map nc_liftSym }]
  else
    let phase1 := (List.range (n - 1)).map fun k =>
      { context_left := (List.range k).map (nc_aux ri),
        input_nonterminal := nc_symToNT (pattern.getD k dflt),
        context_right := ((pattern.drop (k + 1)).map nc_liftSym),
        output_string := [nc_aux ri k] }
    let phase2_0 : csrule T (NC_NT g) :=
      { context_left := (List.range (n - 1)).map (nc_aux ri),
        input_nonterminal := nc_symToNT (pattern.getD (n - 1) dflt),
        context_right := [],
        output_string := (out.drop (n - 1)).map nc_liftSym }
    let phase2_rest := ((List.range (n - 1)).reverse).map fun j =>
      { context_left := (List.range j).map (nc_aux ri),
        input_nonterminal := .inr (.inr (ri, j)),
        context_right := (out.drop (j + 1)).map nc_liftSym,
        output_string := [nc_liftSym (out.getD j dflt)] }
    phase1 ++ [phase2_0] ++ phase2_rest

/-- All CS rules: un-lifting rules plus simulation rules for each grammar rule. -/
def nc_allRules (g : grammar T) : List (csrule T (NC_NT g)) :=
  nc_unliftRules g ++ ((List.range g.rules.length).zip g.rules).flatMap
    fun ⟨i, r⟩ => nc_simRules i r

/-- Every rule in `nc_unliftRules` has nonempty output. -/
lemma nc_unliftRules_output_nonempty (g : grammar T)
    (r : csrule T (NC_NT g)) (hr : r ∈ nc_unliftRules g) :
    r.output_string ≠ [] := by
  simp [nc_unliftRules, nc_grammarTerminals] at hr
  obtain ⟨_, _, _, rfl⟩ := hr
  exact List.cons_ne_nil _ _

/-- Every rule in `nc_simRules` has nonempty output, provided the non-contracting property. -/
lemma nc_simRules_output_nonempty (g : grammar T) (hg : grammar_noncontracting g)
    (ri : ℕ) (grule : grule T g.nt) (hgrule : grule ∈ g.rules)
    (r : csrule T (NC_NT g)) (hr : r ∈ nc_simRules ri grule) :
    r.output_string ≠ [] := by
  unfold nc_simRules at hr
  norm_num +zetaDelta at *
  split_ifs at hr <;> simp_all +decide [List.mem_append, List.mem_map]
  · have := hg grule hgrule; aesop
  · rcases hr with (⟨a, ha, rfl⟩ | rfl | ⟨a, ha, rfl⟩) <;>
      simp +decide [List.length_pos_iff] at *
    linarith [hg grule hgrule]

/-- Construct a context-sensitive grammar equivalent to a given non-contracting grammar. -/
noncomputable def csg_of_noncontracting (g : grammar T) (hg : grammar_noncontracting g) :
    CS_grammar T where
  nt := NC_NT g
  initial := .inl g.initial
  rules := nc_allRules g
  output_nonempty := by
    intro r hr
    simp [nc_allRules] at hr
    rcases hr with hr_unlift | ⟨ri, grule, hgrule, hr_sim⟩
    · exact nc_unliftRules_output_nonempty g r hr_unlift
    · have hmem : grule ∈ g.rules := (List.of_mem_zip hgrule).2
      exact nc_simRules_output_nonempty g hg ri grule hmem r hr_sim

/-! ### Helper lemmas for language equivalence -/

/-
PROBLEM
CS derivation with additional context (pref and suffix).

PROVIDED SOLUTION
By induction on the CS_derives derivation h. Base case (refl): trivial. Step case (tail): if CS_derives g w₁ w₃ and CS_transforms g w₃ w₂, by IH CS_derives g (p ++ w₁ ++ s) (p ++ w₃ ++ s). For the single transform CS_transforms g w₃ w₂, we have r, u, v with w₃ = u ++ CL ++ [nt A] ++ CR ++ v and w₂ = u ++ CL ++ OS ++ CR ++ v. Then p ++ w₃ ++ s = (p ++ u) ++ CL ++ [nt A] ++ CR ++ (v ++ s), and p ++ w₂ ++ s = (p ++ u) ++ CL ++ OS ++ CR ++ (v ++ s). So CS_transforms g (p ++ w₃ ++ s) (p ++ w₂ ++ s) with u' = p ++ u, v' = v ++ s. Then CS_deri_of_deri_tran gives the result.
-/
lemma CS_deri_with_context {g : CS_grammar T}
    {w₁ w₂ : List (symbol T g.nt)}
    (p s : List (symbol T g.nt))
    (h : CS_derives g w₁ w₂) :
    CS_derives g (p ++ w₁ ++ s) (p ++ w₂ ++ s) := by
  induction h;
  · constructor;
  · rename_i h₁ h₂ h₃;
    obtain ⟨ r, u, v, hr, rfl, rfl ⟩ := h₂;
    exact h₃.tail ⟨ r, p ++ u, v ++ s, hr, by simp +decide [ ← List.append_assoc ], by simp +decide [ ← List.append_assoc ] ⟩

lemma CS_transform_removed_symbol_is_input_general {g : CS_grammar T}
    {s₁ s₂ : List (symbol T g.nt)} {x : symbol T g.nt}
    (h : CS_transforms g s₁ s₂) (hx₁ : x ∈ s₁) (hx₂ : x ∉ s₂) :
    ∃ r : csrule T g.nt, r ∈ g.rules ∧ x = symbol.nonterminal r.input_nonterminal := by
  obtain ⟨r, u, v, hr, hs₁, hs₂⟩ := h
  subst hs₁
  subst hs₂
  simp [List.mem_append] at hx₁ hx₂
  rcases hx₁ with hx | hx | hx | hx | hx
  · exact (hx₂.1 hx).elim
  · exact (hx₂.2.1 hx).elim
  · exact ⟨r, hr, hx⟩
  · exact (hx₂.2.2.2.1 hx).elim
  · exact (hx₂.2.2.2.2 hx).elim

lemma CS_transform_removed_symbol_actual_input {g : CS_grammar T}
    {s₁ s₂ : List (symbol T g.nt)} {x : symbol T g.nt}
    (h : CS_transforms g s₁ s₂) (hx₁ : x ∈ s₁) (hx₂ : x ∉ s₂) :
    ∃ (r : csrule T g.nt) (u v : List (symbol T g.nt)),
      r ∈ g.rules ∧
        s₁ = u ++ r.context_left ++ [x] ++ r.context_right ++ v ∧
        s₂ = u ++ r.context_left ++ r.output_string ++ r.context_right ++ v ∧
        x = symbol.nonterminal r.input_nonterminal := by
  obtain ⟨r, u, v, hr, hs₁, hs₂⟩ := h
  rw [hs₁] at hx₁
  rw [hs₂] at hx₂
  simp [List.mem_append] at hx₁ hx₂
  rcases hx₁ with hx | hx | hx | hx | hx
  · exact (hx₂.1 hx).elim
  · exact (hx₂.2.1 hx).elim
  · refine ⟨r, u, v, hr, ?_, hs₂, hx⟩
    rw [hs₁, hx]
  · exact (hx₂.2.2.2.1 hx).elim
  · exact (hx₂.2.2.2.2 hx).elim

lemma CS_transform_removed_symbol_is_input_with_output_mem
    {g : CS_grammar T}
    {s₁ s₂ : List (symbol T g.nt)} {x : symbol T g.nt}
    (h : CS_transforms g s₁ s₂) (hx₁ : x ∈ s₁) (hx₂ : x ∉ s₂) :
    ∃ r : csrule T g.nt, r ∈ g.rules ∧
      x = symbol.nonterminal r.input_nonterminal ∧
        ∀ y, y ∈ r.output_string → y ∈ s₂ := by
  obtain ⟨r, u, v, hr, hs₁, hs₂⟩ := h
  subst hs₁
  subst hs₂
  simp [List.mem_append] at hx₁ hx₂
  have hout : ∀ y : symbol T g.nt, y ∈ r.output_string →
      y ∈ u ++ r.context_left ++ r.output_string ++ r.context_right ++ v := by
    intro y hy
    simp [List.mem_append, hy]
  rcases hx₁ with hx | hx | hx | hx | hx
  · exact (hx₂.1 hx).elim
  · exact (hx₂.2.1 hx).elim
  · exact ⟨r, hr, hx, hout⟩
  · exact (hx₂.2.2.2.1 hx).elim
  · exact (hx₂.2.2.2.2 hx).elim

lemma CS_transform_added_symbol_is_output_general {g : CS_grammar T}
    {s₁ s₂ : List (symbol T g.nt)} {x : symbol T g.nt}
    (h : CS_transforms g s₁ s₂) (hx₂ : x ∈ s₂) (hx₁ : x ∉ s₁) :
    ∃ r : csrule T g.nt, r ∈ g.rules ∧ x ∈ r.output_string := by
  obtain ⟨r, u, v, hr, hs₁, hs₂⟩ := h
  subst hs₁
  subst hs₂
  simp [List.mem_append] at hx₁ hx₂
  rcases hx₂ with hx | hx | hx | hx | hx
  · exact (hx₁.1 hx).elim
  · exact (hx₁.2.1 hx).elim
  · exact ⟨r, hr, hx⟩
  · exact (hx₁.2.2.2.1 hx).elim
  · exact (hx₁.2.2.2.2 hx).elim

lemma CS_transform_added_symbol_is_output_with_input_mem {g : CS_grammar T}
    {s₁ s₂ : List (symbol T g.nt)} {x : symbol T g.nt}
    (h : CS_transforms g s₁ s₂) (hx₂ : x ∈ s₂) (hx₁ : x ∉ s₁) :
    ∃ r : csrule T g.nt, r ∈ g.rules ∧ x ∈ r.output_string ∧
      symbol.nonterminal r.input_nonterminal ∈ s₁ := by
  obtain ⟨r, u, v, hr, hs₁, hs₂⟩ := h
  subst hs₁
  subst hs₂
  simp [List.mem_append] at hx₁ hx₂ ⊢
  rcases hx₂ with hx | hx | hx | hx | hx
  · exact (hx₁.1 hx).elim
  · exact (hx₁.2.1 hx).elim
  · exact ⟨r, hr, hx, by simp⟩
  · exact (hx₁.2.2.2.1 hx).elim
  · exact (hx₁.2.2.2.2 hx).elim

/-
PROBLEM
Un-lifting a single terminal in the CS grammar.

PROVIDED SOLUTION
We need to show CS_transforms (csg_of_noncontracting g hg) (u ++ [nt (inr (inl t))] ++ v) (u ++ [terminal t] ++ v).

Construct the witness: use the CS rule { context_left := [], input_nonterminal := .inr (.inl t), context_right := [], output_string := [.terminal t] }, with u and v as the pref and suffix.

This rule is in (csg_of_noncontracting g hg).rules because:
- t ∈ nc_grammarTerminals g (by ht)
- So the rule is in nc_unliftRules g (by definition, it's in the map)
- nc_unliftRules g is a pref of nc_allRules g
- nc_allRules g = (csg_of_noncontracting g hg).rules

The matching:
- u ++ [] ++ [nt (inr (inl t))] ++ [] ++ v = u ++ [nt (inr (inl t))] ++ v ✓
- u ++ [] ++ [terminal t] ++ [] ++ v = u ++ [terminal t] ++ v ✓

Use exists with the rule, u, and v.
-/
lemma nc_unlift_one (g : grammar T) (hg : grammar_noncontracting g) (t : T)
    (ht : t ∈ nc_grammarTerminals g)
    (u v : List (symbol T (NC_NT g))) :
    CS_transforms (csg_of_noncontracting g hg)
      (u ++ [.nonterminal (.inr (.inl t))] ++ v)
      (u ++ [.terminal t] ++ v) := by
  use ⟨ [ ], Sum.inr ( Sum.inl t ), [ ], [ symbol.terminal t ] ⟩;
  refine' ⟨ u, v, _, _, _ ⟩ <;> simp +decide [ csg_of_noncontracting ];
  exact List.mem_append_left _ ( List.mem_map.mpr ⟨ t, ht, rfl ⟩ )

/-
PROBLEM
Un-lifting all terminals in a list.

PROVIDED SOLUTION
By induction on w.

Base case (w = []): Both sides are [], so CS_deri_self.

Step case (w = t :: w'):
The source is [nt (inr (inl t))] ++ (w'.map (fun t => nt (inr (inl t)))).
The target is [terminal t] ++ (w'.map terminal).

Step 1: Apply nc_unlift_one with u = [] and v = w'.map (fun t => nt (inr (inl t))) to get:
CS_transforms g' ([nt (inr (inl t))] ++ v) ([terminal t] ++ v)
where v = w'.map (fun t => nt (inr (inl t)))

Step 2: By IH (with hw restricted to w'), CS_derives g' (w'.map (fun t => nt (inr (inl t)))) (w'.map terminal).

Step 3: Use CS_deri_with_context (or grammar_deri_with_prefix) with pref [terminal t] to get:
CS_derives g' ([terminal t] ++ w'.map (fun t => nt (inr (inl t)))) ([terminal t] ++ w'.map terminal)

Step 4: Combine steps 1 and 3 by transitivity.

Use hw t (List.mem_cons_self t w') for the base terminal t, and (fun t' ht' => hw t' (List.mem_cons_of_mem t ht')) for the IH.
-/
lemma nc_unlift_all (g : grammar T) (hg : grammar_noncontracting g) (w : List T)
    (hw : ∀ t ∈ w, t ∈ nc_grammarTerminals g) :
    CS_derives (csg_of_noncontracting g hg)
      (w.map (fun t => symbol.nonterminal (.inr (.inl t) : NC_NT g)))
      (w.map symbol.terminal) := by
  -- We proceed by induction on the length of the list `w`.
  induction' w with t w ih;
  · constructor;
  · -- Apply the `nc_unlift_one` lemma to transform `[nt (inr (inl t))]` to `[terminal t]`.
    have h_transform : CS_transforms (csg_of_noncontracting g hg)
      ([.nonterminal (.inr (.inl t))] ++ (w.map (fun t => .nonterminal (.inr (.inl t))))) ([.terminal t] ++ (w.map (fun t => .nonterminal (.inr (.inl t))))) := by
        simpa using
          nc_unlift_one g hg t (hw t (by simp +decide)) []
            (w.map (fun t => symbol.nonterminal (Sum.inr (Sum.inl t))));
    -- Apply the induction hypothesis to transform `w.map (fun t => nt (inr (inl t)))` to `w.map terminal`.
    have h_ind : CS_derives (csg_of_noncontracting g hg)
      ([symbol.terminal t] ++ (w.map (fun t => .nonterminal (.inr (.inl t))))) ([symbol.terminal t] ++ (w.map symbol.terminal)) := by
        simpa using
          CS_deri_with_context [symbol.terminal t] []
            (ih (fun t ht => hw t (List.mem_cons_of_mem _ ht)))
    exact .single h_transform |> Relation.ReflTransGen.trans <| h_ind

/-
PROBLEM
A terminal appearing in a rule's output is in nc_grammarTerminals.

PROVIDED SOLUTION
By definition, nc_grammarTerminals g = g.rules.flatMap (fun r => nc_collectTerminals (r.input_L ++ r.input_R ++ r.output_string)). Since r ∈ g.rules, the contribution of r is included. We need t ∈ nc_collectTerminals (r.input_L ++ r.input_R ++ r.output_string). Since terminal t ∈ r.output_string, and r.output_string is a suffix of r.input_L ++ r.input_R ++ r.output_string, terminal t appears in the combined list. Then nc_collectTerminals extracts t from terminal t. So t ∈ nc_collectTerminals (r.input_L ++ r.input_R ++ r.output_string), and by flatMap membership, t ∈ nc_grammarTerminals g.
-/
lemma terminal_in_output_mem_grammarTerminals (g : grammar T)
    (r : grule T g.nt) (hr : r ∈ g.rules) (t : T)
    (ht : symbol.terminal t ∈ r.output_string) :
    t ∈ nc_grammarTerminals g := by
  unfold nc_grammarTerminals;
  -- By definition of `nc_collectTerminals`, we know that `t ∈ nc_collectTerminals (r.input_L ++ (r.input_R ++ r.output_string))` if and only if `t ∈ r.output_string`.
  have h_nc_collectTerminals : ∀ (l : List (symbol T g.nt)), t ∈ nc_collectTerminals l ↔ symbol.terminal t ∈ l := by
    intro l
    induction' l with s l ih;
    · simp +decide [ nc_collectTerminals ];
    · cases s <;> simp_all +decide [ nc_collectTerminals ];
  aesop

/-
PROBLEM
A simulation rule for rule index ri is in the CS grammar's rules.

PROVIDED SOLUTION
The rules of csg_of_noncontracting g hg are nc_allRules g = nc_unliftRules g ++ ((List.range g.rules.length).zip g.rules).flatMap (fun ⟨i, r⟩ => nc_simRules i r).

cr ∈ nc_simRules ri r, and (ri, r) ∈ (List.range g.rules.length).zip g.rules (since ri < g.rules.length and g.rules[ri] = r).

So cr is in the flatMap part, hence in nc_allRules g, hence in (csg_of_noncontracting g hg).rules.

Use List.mem_append_right, List.mem_flatMap, and the fact that (ri, r) ∈ (List.range g.rules.length).zip g.rules.
-/
lemma nc_simRule_mem (g : grammar T) (hg : grammar_noncontracting g)
    (ri : ℕ) (r : grule T g.nt) (hri : ri < g.rules.length)
    (hr : g.rules[ri] = r)
    (cr : csrule T (NC_NT g)) (hcr : cr ∈ nc_simRules ri r) :
    cr ∈ (csg_of_noncontracting g hg).rules := by
  have h_zip : (ri, r) ∈ (List.range g.rules.length).zip g.rules := by
    rw [ List.mem_iff_get ];
    use ⟨ ri, by simpa using hri ⟩ ; aesop;
  exact List.mem_append_right _ ( List.mem_flatMap.mpr ⟨ _, h_zip, hcr ⟩ )

/-- Membership in the zipped rule-index list recovers the indexed rule. -/
lemma nc_rule_zip_mem_get (g : grammar T) {ri : ℕ} {r : grule T g.nt}
    (hpair : (ri, r) ∈ (List.range g.rules.length).zip g.rules) :
    ∃ hri : ri < g.rules.length, g.rules[ri] = r := by
  rw [List.mem_iff_get] at hpair
  obtain ⟨idx, hidx⟩ := hpair
  have hidxlt : idx.1 < g.rules.length := by
    have := idx.2
    simpa [List.length_zip] using this
  have hpair' : (idx.1, g.rules[idx.1]) = (ri, r) := by
    simpa [List.getElem_zip, List.getElem_range] using hidx
  have hidx_eq_ri : idx.1 = ri := congrArg Prod.fst hpair'
  have hr_idx : g.rules[idx.1] = r := congrArg Prod.snd hpair'
  have hri : ri < g.rules.length := by
    simpa [hidx_eq_ri] using hidxlt
  refine ⟨hri, ?_⟩
  simpa [hidx_eq_ri] using hr_idx

/-- The rule component for a fixed simulation-rule index is unique. -/
lemma nc_rule_zip_rule_unique (g : grammar T) {ri : ℕ}
    {r₁ r₂ : grule T g.nt}
    (h₁ : (ri, r₁) ∈ (List.range g.rules.length).zip g.rules)
    (h₂ : (ri, r₂) ∈ (List.range g.rules.length).zip g.rules) :
    r₁ = r₂ := by
  obtain ⟨_, hr₁⟩ := nc_rule_zip_mem_get g h₁
  obtain ⟨_, hr₂⟩ := nc_rule_zip_mem_get g h₂
  exact hr₁.symm.trans hr₂

/-- A list decomposition around the first occurrence of a marker is unique. -/
lemma list_append_singleton_eq_of_not_mem {α : Type} {x : α}
    {a b c d : List α} (ha : x ∉ a) (hc : x ∉ c)
    (h : a ++ [x] ++ b = c ++ [x] ++ d) :
    a = c ∧ b = d := by
  induction a generalizing c with
  | nil =>
      cases c with
      | nil =>
          simp at h
          exact ⟨rfl, h⟩
      | cons y ys =>
          simp at hc h
          exact (hc.1 h.1).elim
  | cons y ys ih =>
      cases c with
      | nil =>
          simp at ha h
          exact (ha.1 h.1.symm).elim
      | cons z zs =>
          simp at ha hc h ⊢
          obtain ⟨hyz, htail⟩ := h
          subst z
          have htail' : ys ++ [x] ++ b = zs ++ [x] ++ d := by
            simpa using htail
          obtain ⟨hys, hbd⟩ := ih ha.2 hc.2 htail'
          exact ⟨⟨rfl, hys⟩, hbd⟩

/-- If `u ++ [x] ++ w` has no `x` in `u` or `w`, then any decomposition of
the same list as `a ++ [x] ++ b` has no `x` in `a`. -/
lemma list_prefix_not_mem_of_unique_singleton_decomp {α : Type} {x : α}
    {u w a b : List α} (hu : x ∉ u) (hw : x ∉ w)
    (h : u ++ [x] ++ w = a ++ [x] ++ b) :
    x ∉ a := by
  induction u generalizing a with
  | nil =>
      cases a with
      | nil =>
          simp
      | cons y ys =>
          intro _hx
          simp at h
          have htail : w = ys ++ x :: b := h.2
          exact hw (by rw [htail]; simp)
  | cons y ys ih =>
      cases a with
      | nil =>
          simp
      | cons z zs =>
          intro hx
          simp at hu h hx ⊢
          obtain ⟨hyz, htail⟩ := h
          subst z
          rcases hx with hxy | hx
          · exact (hu.1 hxy).elim
          · exact ih hu.2 (by simpa using htail) hx

/-
PROBLEM
The core simulation: transforming the lifted pattern to lifted output.
    For n = 1 (input_L = [], input_R = []), this is a direct CS step.
    For n ≥ 2, this requires the Phase 1 + Phase 2 rule chain.

PROVIDED SOLUTION
Let pattern = r.input_L ++ [nonterminal r.input_N] ++ r.input_R, n = pattern.length, out = r.output_string.

Case 1: n ≤ 1 (so r.input_L = [] and r.input_R = []):
  The first rule in nc_simRules ri r is:
    { context_left := [], input_nonterminal := .inl r.input_N, context_right := [], output_string := out.map nc_liftSym }

  This is a single CS_transforms step:
  - Use this rule with u = [] and v = []
  - w₁ = [] ++ [] ++ [nt (inl r.input_N)] ++ [] ++ [] = [nt (inl r.input_N)]
  - w₂ = [] ++ [] ++ out.map nc_liftSym ++ [] ++ [] = out.map nc_liftSym

  And map nc_liftSym [nonterminal r.input_N] = [nonterminal (inl r.input_N)] = [nt (inl r.input_N)].
  So it works. Apply CS_deri_of_tran.

  The rule membership: it's in nc_simRules ri r (the first element of the list), hence in (csg_of_noncontracting g hg).rules by nc_simRule_mem.

Case 2: n ≥ 2

To handle both cases: split on whether r.input_L.length + 1 + r.input_R.length ≤ 1. For the n ≤ 1 case, r.input_L = [] and r.input_R = [] (since both are lists and their total length is 0). Use List.length_eq_zero to derive input_L = [] and input_R = []. Then simplify and construct the single CS step.
-/
lemma nc_sim_pattern (g : grammar T) (hg : grammar_noncontracting g)
    (ri : ℕ) (r : grule T g.nt) (hri : ri < g.rules.length) (hr : g.rules[ri] = r) :
    CS_derives (csg_of_noncontracting g hg)
      ((r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R).map nc_liftSym)
      (r.output_string.map nc_liftSym) := by
  -- Let's denote the pattern as $pattern$ and its length as $n$.
  set pattern : List (symbol T g.nt) := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
  set n := pattern.length
  set out := r.output_string;
  by_cases hn : n ≤ 1;
  · apply CS_deri_of_tran;
    use ⟨ [], .inl r.input_N, [], out.map nc_liftSym ⟩;
    use [], []
    simp [pattern, out];
    constructor;
    · apply nc_simRule_mem g hg ri r hri hr;
      unfold nc_simRules; aesop;
    · cases h : r.input_L <;> cases h' : r.input_R <;> aesop;
  · -- For the case when $n \geq 2$, we can use the phase1 and phase2 rules to transform the pattern into the output.
    have h_phase1 : CS_derives (csg_of_noncontracting g hg) (pattern.map nc_liftSym) ((List.range (n - 1)).map (nc_aux ri) ++ [nc_liftSym (pattern.getD (n - 1) (symbol.nonterminal r.input_N))]) := by
      have h_phase1 : ∀ (k : ℕ), k < n - 1 → CS_transforms (csg_of_noncontracting g hg) ((List.range k).map (nc_aux ri) ++ [nc_liftSym (pattern.getD k (symbol.nonterminal r.input_N))] ++ (pattern.drop (k + 1)).map nc_liftSym) ((List.range (k + 1)).map (nc_aux ri) ++ (pattern.drop (k + 1)).map nc_liftSym) := by
        intro k hk
        have h_phase1_rule : csrule.mk (List.map (nc_aux ri) (List.range k)) (nc_symToNT (pattern.getD k (symbol.nonterminal r.input_N))) (List.map nc_liftSym (pattern.drop (k + 1))) [nc_aux ri k] ∈ nc_simRules ri r := by
          grind +locals
        generalize_proofs at *; (
        use csrule.mk (List.map (nc_aux ri) (List.range k)) (nc_symToNT (pattern.getD k (symbol.nonterminal r.input_N))) (List.map nc_liftSym (pattern.drop (k + 1))) [nc_aux ri k];
        use [], [] ; simp_all +decide [ List.range_succ ] ;
        exact ⟨ nc_simRule_mem g hg ri r hri hr _ h_phase1_rule, rfl ⟩);
      have h_phase1_seq : ∀ (k : ℕ), k ≤ n - 1 → CS_derives (csg_of_noncontracting g hg) (pattern.map nc_liftSym) ((List.range k).map (nc_aux ri) ++ [nc_liftSym (pattern.getD k (symbol.nonterminal r.input_N))] ++ (pattern.drop (k + 1)).map nc_liftSym) := by
        intro k hk
        induction' k with k ih;
        · convert CS_deri_self using 1;
          cases h : r.input_L <;> aesop;
        · convert CS_deri_of_deri_deri ( ih ( Nat.le_of_succ_le hk ) ) ( CS_deri_of_tran ( h_phase1 k ( Nat.lt_of_succ_le hk ) ) ) using 1;
          rw [show List.drop (k + 1) pattern =
              [pattern.getD (k + 1) (symbol.nonterminal r.input_N)] ++ List.drop (k + 1 + 1) pattern from ?_]
          · simp +decide [List.map_append]
          · rw [List.drop_eq_getElem_cons]
            · rw [List.getD_eq_getElem]
              · simp
              · omega
            · omega
      grind;
    -- Apply the phase2_0 rule to transform the list.
    have h_phase2_0 : CS_derives (csg_of_noncontracting g hg) ((List.range (n - 1)).map (nc_aux ri) ++ [nc_liftSym (pattern.getD (n - 1) (symbol.nonterminal r.input_N))]) ((List.range (n - 1)).map (nc_aux ri) ++ (out.drop (n - 1)).map nc_liftSym) := by
      apply_rules [ CS_deri_of_tran ];
      have h_phase2_0 : ∃ cr ∈ nc_simRules ri r, cr.context_left = (List.range (n - 1)).map (nc_aux ri) ∧ cr.input_nonterminal = nc_symToNT (pattern.getD (n - 1) (symbol.nonterminal r.input_N)) ∧ cr.context_right = [] ∧ cr.output_string = (out.drop (n - 1)).map nc_liftSym := by
        simp +zetaDelta at *;
        unfold nc_simRules; simp +decide [ List.range_succ ] ;
        split_ifs <;> simp_all +decide [ List.range_succ ];
        · linarith;
        · exact ⟨ _, Or.inr <| Or.inl rfl, rfl, rfl, rfl, rfl ⟩;
      obtain ⟨ cr, hcr₁, hcr₂, hcr₃, hcr₄, hcr₅ ⟩ := h_phase2_0;
      use cr;
      use [], [];
      exact ⟨ nc_simRule_mem g hg ri r hri hr cr hcr₁, by aesop ⟩;
    -- Apply the phase2_rest rules to transform the list.
    have h_phase2_rest : ∀ k < n - 1, CS_derives (csg_of_noncontracting g hg) ((List.range (k + 1)).map (nc_aux ri) ++ (out.drop (k + 1)).map nc_liftSym) ((List.range k).map (nc_aux ri) ++ (out.drop k).map nc_liftSym) := by
      intro k hk
      have h_phase2_rest_step : CS_transforms (csg_of_noncontracting g hg) ((List.range (k + 1)).map (nc_aux ri) ++ (out.drop (k + 1)).map nc_liftSym) ((List.range k).map (nc_aux ri) ++ (out.drop k).map nc_liftSym) := by
        have hr_mem : r ∈ g.rules := by
          rw [List.mem_iff_get]
          exact ⟨⟨ri, hri⟩, by simpa using hr⟩
        have hk_out : k < out.length := by
          have hnc : n ≤ out.length := by
            simpa [n, pattern, out] using hg r hr_mem
          omega
        use ⟨ (List.range k).map (nc_aux ri), .inr (.inr (ri, k)), (out.drop (k + 1)).map nc_liftSym, [nc_liftSym (out.getD k (symbol.nonterminal r.input_N))] ⟩;
        refine' ⟨ [ ], [ ], _, _, _ ⟩ <;> simp +decide [ List.range_succ ];
        · apply_rules [ nc_simRule_mem ];
          simp +decide [ nc_simRules ];
          grind +splitIndPred;
        · rfl;
        · rw [List.drop_eq_getElem_cons (by simpa using hk_out : k < (List.map nc_liftSym out).length)]
          rw [List.getElem_map]
          have hget : out[k]?.getD (symbol.nonterminal r.input_N) = out[k] := by
            rw [List.getElem?_eq_getElem hk_out]
            simp
          simp [hget]
      exact .single h_phase2_rest_step;
    have h_phase2_rest_seq : ∀ k ≤ n - 1, CS_derives (csg_of_noncontracting g hg) ((List.range (n - 1)).map (nc_aux ri) ++ (out.drop (n - 1)).map nc_liftSym) ((List.range k).map (nc_aux ri) ++ (out.drop k).map nc_liftSym) := by
      intro k hk;
      induction' hk : n - 1 - k with m ih generalizing k <;> simp_all +decide [ Nat.sub_sub ];
      · rw [ show k = n - 1 by omega ];
        constructor;
      · convert ih ( k + 1 ) ( by omega ) ( by omega ) |> fun h => h.trans ( h_phase2_rest k ( by omega ) ) using 1;
    exact h_phase1.trans ( h_phase2_0.trans ( h_phase2_rest_seq 0 bot_le ) ) |> fun h => h.trans ( by aesop )

/-- A single grammar step can be simulated by CS derivation on lifted forms. -/
lemma nc_sim_one_transform (g : grammar T) (hg : grammar_noncontracting g)
    {w₁ w₂ : List (symbol T g.nt)} (h : grammar_transforms g w₁ w₂) :
    CS_derives (csg_of_noncontracting g hg)
      (w₁.map nc_liftSym) (w₂.map nc_liftSym) := by
  obtain ⟨r, hr_mem, u, v, hw1, hw2⟩ := h
  subst hw1; subst hw2
  obtain ⟨⟨ri_val, hri_lt⟩, hri_eq⟩ := List.mem_iff_get.mp hr_mem
  have hsim := nc_sim_pattern g hg ri_val r hri_lt hri_eq
  have hctx := CS_deri_with_context (u.map nc_liftSym) (v.map nc_liftSym) hsim
  simp only [List.map_append, List.map_cons, List.map_nil] at hctx ⊢
  convert hctx using 1 <;> simp [List.append_assoc]

/-
PROBLEM
Multi-step grammar derivation lifts to CS derivation.

PROVIDED SOLUTION
By induction on the grammar_derives derivation h.

Base case (refl): CS_deri_self.

Step case (tail): grammar_derives g w₁ w₃ and grammar_transforms g w₃ w₂. By IH, CS_derives g' (w₁.map nc_liftSym) (w₃.map nc_liftSym). By nc_sim_one_transform, CS_derives g' (w₃.map nc_liftSym) (w₂.map nc_liftSym). By CS_deri_of_deri_deri (transitivity), CS_derives g' (w₁.map nc_liftSym) (w₂.map nc_liftSym).
-/
lemma nc_sim_derives (g : grammar T) (hg : grammar_noncontracting g)
    {w₁ w₂ : List (symbol T g.nt)} (h : grammar_derives g w₁ w₂) :
    CS_derives (csg_of_noncontracting g hg)
      (w₁.map nc_liftSym) (w₂.map nc_liftSym) := by
  induction h;
  · constructor;
  · exact CS_deri_of_deri_deri ‹_› ( nc_sim_one_transform g hg ‹_› )

/-
PROBLEM
Any terminal in a word derived by the grammar appears in nc_grammarTerminals.

PROVIDED SOLUTION
We need to show that any terminal t appearing in a word w derived by the grammar is in nc_grammarTerminals g.

By definition, grammar_language g w means grammar_derives g [nt g.initial] (map terminal w). We need to show t ∈ nc_grammarTerminals g.

Proceed by induction on the derivation. The initial sentential form [nt g.initial] has no terminals. Each grammar_transforms step introduces terminals only from rule outputs. By terminal_in_output_mem_grammarTerminals, any terminal in a rule output is in nc_grammarTerminals.

More precisely: induct on the derivation grammar_derives g [nt g.initial] (map terminal w). Show that every terminal symbol in the sentential form at each step is in nc_grammarTerminals. For the initial form, vacuously true (no terminals). For each step using rule r at position u, v: the new form is u ++ r.output_string ++ v. Terminals in u and v are inherited from the previous form (by IH, they're in nc_grammarTerminals). Terminals in r.output_string are in nc_grammarTerminals by terminal_in_output_mem_grammarTerminals. Since the final form map terminal w has all its symbols as terminals, every t ∈ w gives symbol.terminal t in the final form, hence t ∈ nc_grammarTerminals.

Actually, a simpler approach: since map terminal w is derived, there must be some step that introduces each terminal t. That step uses a rule r with terminal t ∈ r.output_string, so t ∈ nc_grammarTerminals by terminal_in_output_mem_grammarTerminals.

First prove a helper: for any grammar_derives g w₁ w₂, if all terminals in w₁ are in nc_grammarTerminals g, then all terminals in w₂ are also in nc_grammarTerminals g. This is by induction on the derivation. The base case is trivial. The step case: grammar_transforms g mid w₂ gives mid = u ++ L ++ [nt A] ++ R ++ v and w₂ = u ++ out ++ v. A terminal in w₂ is either in u (inherited from mid), in out (by terminal_in_output_mem_grammarTerminals), or in v (inherited from mid). Terminals in u and v are also in mid, so by IH they're in nc_grammarTerminals.

Then apply this helper with w₁ = [nt g.initial] (which has no terminals, so the base condition is vacuously true) and w₂ = map terminal w.
-/
lemma nc_derived_terminal_in_grammarTerminals (g : grammar T)
    (w : List T) (hw : w ∈ grammar_language g) (t : T) (ht : t ∈ w) :
    t ∈ nc_grammarTerminals g := by
  -- Apply induction on the derivation to show that every terminal in the sentential form at each step is in nc_grammarTerminals.
  have h_ind : ∀ {w₁ w₂ : List (symbol T g.nt)}, grammar_derives g w₁ w₂ → (∀ s ∈ w₁, ∀ t, s = .terminal t → t ∈ nc_grammarTerminals g) → (∀ s ∈ w₂, ∀ t, s = .terminal t → t ∈ nc_grammarTerminals g) := by
    intros w₁ w₂ h_deriv h_terminals_in_w₁
    induction' h_deriv with w₁ w₂ h_deriv h_terminals_in_w₁ ih;
    · assumption;
    · rcases h_terminals_in_w₁ with ⟨ r, hr, u, v, hw₁, hw₂ ⟩ ; simp_all +decide [ List.map_append, List.map_cons ] ;
      rintro s ( hs | hs | hs ) t rfl <;> [ exact ih _ ( Or.inl hs ) _ rfl; exact terminal_in_output_mem_grammarTerminals g r hr _ ( by aesop ) ; exact ih _ ( Or.inr <| Or.inr <| Or.inr <| Or.inr hs ) _ rfl ] ;
  specialize @h_ind [ symbol.nonterminal g.initial ] ( List.map symbol.terminal w ) hw ; aesop

/-
PROBLEM
Forward direction: grammar_language g ⊆ CS_language (csg_of_noncontracting g hg).

PROVIDED SOLUTION
Given hw : w ∈ grammar_language g, which means grammar_derives g [nt g.initial] (map terminal w).

Step 1: By nc_sim_derives, CS_derives g' (map nc_liftSym [nt g.initial]) (map nc_liftSym (map terminal w)).
  Note: map nc_liftSym [nt g.initial] = [nt (inl g.initial)] = [nt g'.initial]
  And: map nc_liftSym (map terminal w) = map (fun t => nt (inr (inl t))) w

Step 2: By nc_unlift_all (with hw' showing all terminals in w are in nc_grammarTerminals, which follows from nc_derived_terminal_in_grammarTerminals),
  CS_derives g' (map (fun t => nt (inr (inl t))) w) (map terminal w).

Step 3: By CS_deri_of_deri_deri (transitivity), CS_derives g' [nt g'.initial] (map terminal w).
  This is exactly w ∈ CS_language g'.

Key: show map nc_liftSym [nt g.initial] = [nt (Sum.inl g.initial)] by unfolding nc_liftSym and nc_symToNT.
And map nc_liftSym (map terminal w) = map (fun t => nt (Sum.inr (Sum.inl t))) w by unfolding nc_liftSym and nc_symToNT on terminal.
-/
lemma nc_forward (g : grammar T) (hg : grammar_noncontracting g)
    (w : List T) (hw : w ∈ grammar_language g) :
    w ∈ CS_language (csg_of_noncontracting g hg) := by
  obtain ⟨hw₁, hw₂⟩ : grammar_derives g [symbol.nonterminal g.initial] (w.map symbol.terminal) ∧ ∀ t ∈ w, t ∈ nc_grammarTerminals g := by
    exact ⟨ hw, fun t ht => nc_derived_terminal_in_grammarTerminals g w hw t ht ⟩;
  have h_map : CS_derives (csg_of_noncontracting g hg) (List.map symbol.nonterminal (List.cons (Sum.inl g.initial) [])) (List.map symbol.nonterminal (List.map (fun t => Sum.inr (Sum.inl t)) w)) := by
    convert nc_sim_derives g hg hw₁ using 1;
    unfold nc_liftSym; aesop;
  have h_unlift : CS_derives (csg_of_noncontracting g hg) (List.map symbol.nonterminal (List.map (fun t => Sum.inr (Sum.inl t)) w)) (List.map symbol.terminal w) := by
    convert nc_unlift_all g hg w hw₂ using 1;
    rw [ List.map_map ];
    rfl;
  exact Relation.ReflTransGen.trans h_map h_unlift

/-- Forward correctness of the non-contracting-to-CS construction.

Every terminal word generated by the original non-contracting unrestricted grammar is
generated by the constructed context-sensitive grammar.  The reverse containment is the
remaining hard direction because derivations in the constructed grammar may pass through
auxiliary nonterminals before returning to clean sentential forms. -/
theorem grammar_language_subset_csg_of_noncontracting (g : grammar T)
    (hg : grammar_noncontracting g) :
    ∀ w, w ∈ grammar_language g → w ∈ CS_language (csg_of_noncontracting g hg) :=
  fun w hw => nc_forward g hg w hw

/-! ### Locked non-contracting → CS construction

The first construction above is convenient for forward simulation, but its phase-2
cleanup rules use clean output symbols as right context.  That is too permissive
for the reverse direction: a cleanup rule can match symbols from the surrounding
sentential context and skip the locked output phase.  The locked construction below
uses fresh output markers for every produced output position, and only erases those
markers to clean lifted symbols after the simulated rule has completed.
-/

/-- Nonterminals for the locked CS construction. -/
inductive NC_LockedNT (g : grammar T) where
  | orig : g.nt → NC_LockedNT g
  | term : T → NC_LockedNT g
  | mark : ℕ → ℕ → NC_LockedNT g
  | out : ℕ → ℕ → symbol T g.nt → NC_LockedNT g

/-- Convert an original symbol to a locked-construction nonterminal. -/
def nc_locked_symToNT {g : grammar T} : symbol T g.nt → NC_LockedNT g
  | .terminal t => .term t
  | .nonterminal n => .orig n

lemma nc_locked_symToNT_ne_mark {g : grammar T} (s : symbol T g.nt)
    (ri k : ℕ) :
    nc_locked_symToNT s ≠ NC_LockedNT.mark ri k := by
  cases s <;> simp [nc_locked_symToNT]

lemma nc_locked_symToNT_ne_out {g : grammar T} (s : symbol T g.nt)
    (ri k : ℕ) (a : symbol T g.nt) :
    nc_locked_symToNT s ≠ NC_LockedNT.out ri k a := by
  cases s <;> simp [nc_locked_symToNT]

/-- Lift an original symbol into the locked construction. -/
def nc_locked_liftSym {g : grammar T} (s : symbol T g.nt) :
    symbol T (NC_LockedNT g) :=
  .nonterminal (nc_locked_symToNT s)

/-- Input-position marker for a simulated rule. -/
def nc_locked_mark {g : grammar T} (ri k : ℕ) :
    symbol T (NC_LockedNT g) :=
  .nonterminal (.mark ri k)

/-- Output-position marker for a simulated rule. -/
def nc_locked_out {g : grammar T} (ri k : ℕ) (s : symbol T g.nt) :
    symbol T (NC_LockedNT g) :=
  .nonterminal (.out ri k s)

/-- Marked output suffix beginning at position `k`. -/
def nc_locked_outputSuffix {g : grammar T} (ri : ℕ)
    (out : List (symbol T g.nt)) (dflt : symbol T g.nt) (k : ℕ) :
    List (symbol T (NC_LockedNT g)) :=
  (List.range (out.length - k)).map fun off =>
    nc_locked_out ri (k + off) (out.getD (k + off) dflt)

/-- Marked output suffix beginning at position `k`, forced syntactically nonempty.
For non-contracting rules the head index is in bounds; the default only keeps the
definition total. -/
def nc_locked_outputFrom {g : grammar T} (ri : ℕ)
    (out : List (symbol T g.nt)) (dflt : symbol T g.nt) (k : ℕ) :
    List (symbol T (NC_LockedNT g)) :=
  nc_locked_out ri k (out.getD k dflt) :: nc_locked_outputSuffix ri out dflt (k + 1)

/-- Un-lifting rules for the locked construction. -/
def nc_locked_unliftRules (g : grammar T) : List (csrule T (NC_LockedNT g)) :=
  (nc_grammarTerminals g).map fun t =>
    { context_left := [],
      input_nonterminal := .term t,
      context_right := [],
      output_string := [.terminal t] }

/-- Simulation rules for one original non-contracting rule in the locked construction. -/
def nc_locked_simRules {g : grammar T} (ri : ℕ) (r : grule T g.nt) :
    List (csrule T (NC_LockedNT g)) :=
  let pattern := r.input_L ++ [.nonterminal r.input_N] ++ r.input_R
  let n := pattern.length
  let out := r.output_string
  let dflt : symbol T g.nt := .nonterminal r.input_N
  let markInput := (List.range n).map fun k =>
    { context_left := (List.range k).map (nc_locked_mark ri),
      input_nonterminal := nc_locked_symToNT (pattern.getD k dflt),
      context_right := (pattern.drop (k + 1)).map nc_locked_liftSym,
      output_string := [nc_locked_mark ri k] }
  let emitLast : csrule T (NC_LockedNT g) :=
    { context_left := (List.range (n - 1)).map (nc_locked_mark ri),
      input_nonterminal := .mark ri (n - 1),
      context_right := [],
      output_string := nc_locked_outputFrom ri out dflt (n - 1) }
  let emitRest := ((List.range (n - 1)).reverse).map fun j =>
    { context_left := (List.range j).map (nc_locked_mark ri),
      input_nonterminal := .mark ri j,
      context_right := nc_locked_outputSuffix ri out dflt (j + 1),
      output_string := [nc_locked_out ri j (out.getD j dflt)] }
  let cleanup := (List.range out.length).map fun j =>
    { context_left := [],
      input_nonterminal := .out ri j (out.getD j dflt),
      context_right := [],
      output_string := [nc_locked_liftSym (out.getD j dflt)] }
  markInput ++ [emitLast] ++ emitRest ++ cleanup

/-- All locked-construction CS rules. -/
def nc_locked_allRules (g : grammar T) : List (csrule T (NC_LockedNT g)) :=
  nc_locked_unliftRules g ++ ((List.range g.rules.length).zip g.rules).flatMap
    fun ⟨i, r⟩ => nc_locked_simRules i r

lemma nc_locked_unliftRules_output_nonempty (g : grammar T)
    (r : csrule T (NC_LockedNT g)) (hr : r ∈ nc_locked_unliftRules g) :
    r.output_string ≠ [] := by
  simp [nc_locked_unliftRules, nc_grammarTerminals] at hr
  obtain ⟨_, _, _, rfl⟩ := hr
  exact List.cons_ne_nil _ _

lemma nc_locked_outputFrom_ne_nil (g : grammar T) (ri : ℕ)
    (out : List (symbol T g.nt)) (dflt : symbol T g.nt) (k : ℕ) :
    nc_locked_outputFrom ri out dflt k ≠ [] := by
  simp [nc_locked_outputFrom]

lemma nc_locked_simRules_output_nonempty (g : grammar T)
    (ri : ℕ) (grule : grule T g.nt)
    (r : csrule T (NC_LockedNT g)) (hr : r ∈ nc_locked_simRules ri grule) :
    r.output_string ≠ [] := by
  simp [nc_locked_simRules, nc_locked_outputFrom] at hr ⊢
  aesop

/-- Locked CS grammar for a non-contracting grammar. -/
noncomputable def locked_csg_of_noncontracting (g : grammar T)
    (_hg : grammar_noncontracting g) : CS_grammar T where
  nt := NC_LockedNT g
  initial := .orig g.initial
  rules := nc_locked_allRules g
  output_nonempty := by
    intro r hr
    simp [nc_locked_allRules] at hr
    rcases hr with hr_unlift | ⟨ri, grule, _hgrule, hr_sim⟩
    · exact nc_locked_unliftRules_output_nonempty g r hr_unlift
    · exact nc_locked_simRules_output_nonempty g ri grule r hr_sim

/-- A locked simulation rule is a rule of the locked constructed CS grammar. -/
lemma nc_locked_simRule_mem (g : grammar T) (hg : grammar_noncontracting g)
    (ri : ℕ) (r : grule T g.nt) (hri : ri < g.rules.length)
    (hr : g.rules[ri] = r)
    (cr : csrule T (NC_LockedNT g)) (hcr : cr ∈ nc_locked_simRules ri r) :
    cr ∈ (locked_csg_of_noncontracting g hg).rules := by
  have h_zip : (ri, r) ∈ (List.range g.rules.length).zip g.rules := by
    rw [List.mem_iff_get]
    use ⟨ri, by simpa using hri⟩
    aesop
  exact List.mem_append_right _ (List.mem_flatMap.mpr ⟨_, h_zip, hcr⟩)

/-- An un-lifting rule is a rule of the locked constructed CS grammar. -/
lemma nc_locked_unliftRule_mem (g : grammar T) (hg : grammar_noncontracting g)
    {t : T} (ht : t ∈ nc_grammarTerminals g) :
    { context_left := [],
      input_nonterminal := NC_LockedNT.term t,
      context_right := [],
      output_string := [symbol.terminal t] } ∈
      (locked_csg_of_noncontracting g hg).rules := by
  exact List.mem_append_left _ (List.mem_map.mpr ⟨t, ht, rfl⟩)

/-- Un-lift one locked terminal marker to the actual terminal. -/
lemma nc_locked_unlift_one (g : grammar T) (hg : grammar_noncontracting g)
    (t : T) (ht : t ∈ nc_grammarTerminals g)
    (u v : List (symbol T (NC_LockedNT g))) :
    CS_transforms (locked_csg_of_noncontracting g hg)
      (u ++ [.nonterminal (NC_LockedNT.term t)] ++ v)
      (u ++ [.terminal t] ++ v) := by
  refine ⟨{ context_left := [],
            input_nonterminal := NC_LockedNT.term t,
            context_right := [],
            output_string := [.terminal t] },
          u, v, ?_, ?_, ?_⟩
  · exact nc_locked_unliftRule_mem g hg ht
  · simp
  · simp

/-- Un-lift all locked terminal markers in a terminal word. -/
lemma nc_locked_unlift_all (g : grammar T) (hg : grammar_noncontracting g)
    (w : List T) (hw : ∀ t ∈ w, t ∈ nc_grammarTerminals g) :
    CS_derives (locked_csg_of_noncontracting g hg)
      (w.map (fun t => symbol.nonterminal (NC_LockedNT.term t)))
      (w.map symbol.terminal) := by
  induction w with
  | nil =>
      exact CS_deri_self
  | cons t w ih =>
      have hstep : CS_transforms (locked_csg_of_noncontracting g hg)
          ([symbol.nonterminal (NC_LockedNT.term t)] ++
            w.map (fun t => symbol.nonterminal (NC_LockedNT.term t)))
          ([symbol.terminal t] ++
            w.map (fun t => symbol.nonterminal (NC_LockedNT.term t))) := by
        simpa using nc_locked_unlift_one g hg t (hw t (by simp)) []
          (w.map (fun t => symbol.nonterminal (NC_LockedNT.term t)))
      have htail : CS_derives (locked_csg_of_noncontracting g hg)
          ([symbol.terminal t] ++
            w.map (fun t => symbol.nonterminal (NC_LockedNT.term t)))
          ([symbol.terminal t] ++ w.map symbol.terminal) := by
        simpa using CS_deri_with_context [symbol.terminal t] []
          (ih (fun t ht => hw t (List.mem_cons_of_mem _ ht)))
      exact CS_deri_of_tran_deri hstep htail

/-- Clean up one locked output marker into the corresponding lifted output symbol. -/
lemma nc_locked_cleanup_one (g : grammar T) (hg : grammar_noncontracting g)
    (ri : ℕ) (r : grule T g.nt) (hri : ri < g.rules.length)
    (hr : g.rules[ri] = r) (j : ℕ) (hj : j < r.output_string.length)
    (u v : List (symbol T (NC_LockedNT g))) :
    CS_transforms (locked_csg_of_noncontracting g hg)
      (u ++ [nc_locked_out ri j (r.output_string.getD j (symbol.nonterminal r.input_N))] ++ v)
      (u ++ [nc_locked_liftSym (r.output_string.getD j (symbol.nonterminal r.input_N))] ++ v) := by
  let cr : csrule T (NC_LockedNT g) :=
    { context_left := [],
      input_nonterminal := NC_LockedNT.out ri j
        (r.output_string.getD j (symbol.nonterminal r.input_N)),
      context_right := [],
      output_string :=
        [nc_locked_liftSym (r.output_string.getD j (symbol.nonterminal r.input_N))] }
  have hcr : cr ∈ nc_locked_simRules ri r := by
    simp [cr, nc_locked_simRules, List.mem_append, List.mem_map, hj]
  refine ⟨cr, u, v, nc_locked_simRule_mem g hg ri r hri hr cr hcr, ?_, ?_⟩
  · simp [cr, nc_locked_out]
  · simp [cr]

lemma nc_locked_outputSuffix_nil_of_len_le (g : grammar T)
    (ri : ℕ) (out : List (symbol T g.nt)) (dflt : symbol T g.nt) (k : ℕ)
    (hk : out.length ≤ k) :
    nc_locked_outputSuffix ri out dflt k = [] := by
  simp [nc_locked_outputSuffix, Nat.sub_eq_zero_of_le hk]

lemma nc_locked_outputSuffix_cons (g : grammar T)
    (ri : ℕ) (out : List (symbol T g.nt)) (dflt : symbol T g.nt) (k : ℕ)
    (hk : k < out.length) :
    nc_locked_outputSuffix ri out dflt k =
      [nc_locked_out ri k (out.getD k dflt)] ++
        nc_locked_outputSuffix ri out dflt (k + 1) := by
  unfold nc_locked_outputSuffix
  have hsub : out.length - k = (out.length - (k + 1)) + 1 := by
    omega
  rw [hsub, List.range_succ_eq_map]
  simp [Nat.add_comm, Nat.add_left_comm, Nat.add_assoc]

lemma nc_locked_outputFrom_eq_suffix (g : grammar T)
    (ri : ℕ) (out : List (symbol T g.nt)) (dflt : symbol T g.nt) (k : ℕ)
    (hk : k < out.length) :
    nc_locked_outputFrom ri out dflt k =
      nc_locked_outputSuffix ri out dflt k := by
  rw [nc_locked_outputSuffix_cons g ri out dflt k hk]
  rfl

lemma nc_locked_outputSuffix_mem_out_shape (g : grammar T)
    {ri ri' k k' : ℕ} {out : List (symbol T g.nt)}
    {dflt a : symbol T g.nt}
    (hmem :
      nc_locked_out (g := g) ri' k' a ∈
        nc_locked_outputSuffix ri out dflt k) :
    ri' = ri ∧ k ≤ k' ∧ k' < out.length ∧ a = out.getD k' dflt := by
  simp [nc_locked_outputSuffix, nc_locked_out, List.mem_map] at hmem
  obtain ⟨off, hoff, hshape⟩ := hmem
  rcases hshape with ⟨hri, hk, ha⟩
  subst ri'
  subst k'
  refine ⟨rfl, by omega, by omega, ?_⟩
  simpa using ha.symm

lemma nc_locked_outputFrom_mem_out_shape (g : grammar T)
    {ri ri' k k' : ℕ} {out : List (symbol T g.nt)}
    {dflt a : symbol T g.nt}
    (hk : k < out.length)
    (hmem :
      nc_locked_out (g := g) ri' k' a ∈
        nc_locked_outputFrom ri out dflt k) :
    ri' = ri ∧ k ≤ k' ∧ k' < out.length ∧ a = out.getD k' dflt := by
  simp [nc_locked_outputFrom, nc_locked_out] at hmem
  rcases hmem with hhead | htail
  · rcases hhead with ⟨hri, hk_eq, ha⟩
    subst ri'
    subst k'
    refine ⟨rfl, le_rfl, by simpa using hk, by simpa using ha⟩
  · obtain ⟨hri, hle, hlt, ha⟩ :=
      nc_locked_outputSuffix_mem_out_shape (g := g) htail
    exact ⟨hri, by omega, hlt, ha⟩

lemma nc_locked_outputSuffix_length (g : grammar T)
    (ri : ℕ) (out : List (symbol T g.nt)) (dflt : symbol T g.nt) (k : ℕ) :
    (nc_locked_outputSuffix ri out dflt k).length = out.length - k := by
  simp [nc_locked_outputSuffix]

lemma nc_locked_outputSuffix_head_mem (g : grammar T)
    (ri : ℕ) (out : List (symbol T g.nt)) (dflt : symbol T g.nt) (k : ℕ)
    (hk : k < out.length) :
    nc_locked_out (g := g) ri k (out.getD k dflt) ∈
      nc_locked_outputSuffix ri out dflt k := by
  unfold nc_locked_outputSuffix
  rw [List.mem_map]
  refine ⟨0, ?_, ?_⟩
  · simp [Nat.sub_pos_of_lt hk]
  · simp [nc_locked_out]

lemma nc_locked_take_succ_map (g : grammar T)
    (out : List (symbol T g.nt)) (dflt : symbol T g.nt) (k : ℕ)
    (hk : k < out.length) :
    (out.take (k + 1)).map nc_locked_liftSym =
      (out.take k).map nc_locked_liftSym ++
        [nc_locked_liftSym (out.getD k dflt)] := by
  rw [List.map_take, List.map_take]
  rw [List.take_add_one]
  simp [List.getElem?_eq_getElem (by simpa using hk), List.getD_eq_getElem]

lemma nc_locked_cleanup_suffix (g : grammar T) (hg : grammar_noncontracting g)
    (ri : ℕ) (r : grule T g.nt) (hri : ri < g.rules.length)
    (hr : g.rules[ri] = r) (k : ℕ) (hk : k ≤ r.output_string.length) :
    CS_derives (locked_csg_of_noncontracting g hg)
      ((r.output_string.take k).map nc_locked_liftSym ++
        nc_locked_outputSuffix ri r.output_string (symbol.nonterminal r.input_N) k)
      (r.output_string.map nc_locked_liftSym) := by
  induction' hm : r.output_string.length - k with m ih generalizing k
  · have hklen : r.output_string.length = k := by omega
    rw [← hklen]
    simp [nc_locked_outputSuffix_nil_of_len_le g ri r.output_string
      (symbol.nonterminal r.input_N) r.output_string.length (le_refl _)]
    exact CS_deri_self
  · have hklt : k < r.output_string.length := by omega
    have hcons := nc_locked_outputSuffix_cons g ri r.output_string
      (symbol.nonterminal r.input_N) k hklt
    have hstep : CS_transforms (locked_csg_of_noncontracting g hg)
        ((r.output_string.take k).map nc_locked_liftSym ++
          nc_locked_outputSuffix ri r.output_string (symbol.nonterminal r.input_N) k)
        ((r.output_string.take k).map nc_locked_liftSym ++
          [nc_locked_liftSym (r.output_string.getD k (symbol.nonterminal r.input_N))] ++
          nc_locked_outputSuffix ri r.output_string (symbol.nonterminal r.input_N) (k + 1)) := by
      rw [hcons]
      simpa [List.append_assoc] using
        nc_locked_cleanup_one g hg ri r hri hr k hklt
          ((r.output_string.take k).map nc_locked_liftSym)
          (nc_locked_outputSuffix ri r.output_string (symbol.nonterminal r.input_N) (k + 1))
    have htail : CS_derives (locked_csg_of_noncontracting g hg)
        ((r.output_string.take k).map nc_locked_liftSym ++
          [nc_locked_liftSym (r.output_string.getD k (symbol.nonterminal r.input_N))] ++
          nc_locked_outputSuffix ri r.output_string (symbol.nonterminal r.input_N) (k + 1))
        (r.output_string.map nc_locked_liftSym) := by
      have hih := ih (k + 1) (by omega) (by omega)
      simpa [nc_locked_take_succ_map g r.output_string (symbol.nonterminal r.input_N) k hklt,
        List.append_assoc] using hih
    exact CS_deri_of_tran_deri hstep htail

lemma nc_locked_cleanup_outputFrom_with_context (g : grammar T)
    (hg : grammar_noncontracting g)
    {ri : ℕ} {r : grule T g.nt}
    (hpair : (ri, r) ∈ (List.range g.rules.length).zip g.rules)
    (u v : List (symbol T (NC_LockedNT g))) :
    CS_derives (locked_csg_of_noncontracting g hg)
      (u ++ nc_locked_outputFrom ri r.output_string
        (symbol.nonterminal r.input_N) 0 ++ v)
      (u ++ r.output_string.map nc_locked_liftSym ++ v) := by
  obtain ⟨hri, hr⟩ := nc_rule_zip_mem_get g hpair
  let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
  have hpattern_pos : 0 < pattern.length := by
    simp [pattern, List.length_append]
  have hout_pos : 0 < r.output_string.length := by
    have hnc : pattern.length ≤ r.output_string.length := by
      simpa [pattern, List.length_append, Nat.add_assoc, Nat.add_comm,
        Nat.add_left_comm] using hg r (List.of_mem_zip hpair).2
    omega
  have hcleanup :=
    nc_locked_cleanup_suffix g hg ri r hri hr 0 (by simp)
  have hcleanup' : CS_derives (locked_csg_of_noncontracting g hg)
      (nc_locked_outputFrom ri r.output_string (symbol.nonterminal r.input_N) 0)
      (r.output_string.map nc_locked_liftSym) := by
    rw [nc_locked_outputFrom_eq_suffix g ri r.output_string
      (symbol.nonterminal r.input_N) 0 hout_pos]
    simpa using hcleanup
  simpa [List.append_assoc] using CS_deri_with_context u v hcleanup'

lemma nc_locked_sim_pattern (g : grammar T) (hg : grammar_noncontracting g)
    (ri : ℕ) (r : grule T g.nt) (hri : ri < g.rules.length) (hr : g.rules[ri] = r) :
    CS_derives (locked_csg_of_noncontracting g hg)
      ((r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R).map nc_locked_liftSym)
      (r.output_string.map nc_locked_liftSym) := by
  set pattern : List (symbol T g.nt) := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
  set n := pattern.length
  set out := r.output_string
  let dflt : symbol T g.nt := symbol.nonterminal r.input_N
  have hr_mem : r ∈ g.rules := by
    rw [List.mem_iff_get]
    exact ⟨⟨ri, hri⟩, by simpa using hr⟩
  have hn_pos : 0 < n := by
    simp [n, pattern, List.length_append]
  have hnc : n ≤ out.length := by
    simpa [n, pattern, out] using hg r hr_mem
  have h_mark_step : ∀ k : ℕ, k < n →
      CS_transforms (locked_csg_of_noncontracting g hg)
        ((List.range k).map (nc_locked_mark ri) ++
          [nc_locked_liftSym (pattern.getD k dflt)] ++
          (pattern.drop (k + 1)).map nc_locked_liftSym)
        ((List.range (k + 1)).map (nc_locked_mark ri) ++
          (pattern.drop (k + 1)).map nc_locked_liftSym) := by
    intro k hk
    let cr : csrule T (NC_LockedNT g) :=
      { context_left := (List.range k).map (nc_locked_mark ri),
        input_nonterminal := nc_locked_symToNT (pattern.getD k dflt),
        context_right := (pattern.drop (k + 1)).map nc_locked_liftSym,
        output_string := [nc_locked_mark ri k] }
    have hcr : cr ∈ nc_locked_simRules ri r := by
      simp [cr, nc_locked_simRules, pattern, n, dflt]
      refine Or.inl ⟨k, ?_, ?_⟩
      · simp [n, pattern, List.length_append] at hk
        omega
      · simp [cr, pattern, dflt]
    refine ⟨cr, [], [], nc_locked_simRule_mem g hg ri r hri hr cr hcr, ?_, ?_⟩
    · simp [cr, nc_locked_liftSym]
    · simp [cr, nc_locked_mark, List.range_succ, List.append_assoc]
  have h_mark_seq : ∀ k : ℕ, k ≤ n →
      CS_derives (locked_csg_of_noncontracting g hg)
        (pattern.map nc_locked_liftSym)
        ((List.range k).map (nc_locked_mark ri) ++
          (pattern.drop k).map nc_locked_liftSym) := by
    intro k hk
    induction k with
    | zero =>
        simpa using (CS_deri_self :
          CS_derives (locked_csg_of_noncontracting g hg)
            (pattern.map nc_locked_liftSym) (pattern.map nc_locked_liftSym))
    | succ k ih =>
        have hklt : k < n := Nat.lt_of_succ_le hk
        have hprev := ih (Nat.le_of_succ_le hk)
        have hsplit : (pattern.drop k).map nc_locked_liftSym =
            [nc_locked_liftSym (pattern.getD k dflt)] ++
              (pattern.drop (k + 1)).map nc_locked_liftSym := by
          rw [List.drop_eq_getElem_cons]
          · rw [List.getD_eq_getElem]
            · simp
            · simpa [n] using hklt
          · simpa [n] using hklt
        have hprev' : CS_derives (locked_csg_of_noncontracting g hg)
            (pattern.map nc_locked_liftSym)
            ((List.range k).map (nc_locked_mark ri) ++
              [nc_locked_liftSym (pattern.getD k dflt)] ++
              (pattern.drop (k + 1)).map nc_locked_liftSym) := by
          simpa [hsplit, List.append_assoc] using hprev
        exact CS_deri_of_deri_tran hprev' (h_mark_step k hklt)
  have h_mark : CS_derives (locked_csg_of_noncontracting g hg)
      (pattern.map nc_locked_liftSym)
      ((List.range n).map (nc_locked_mark ri)) := by
    have h := h_mark_seq n le_rfl
    simpa [List.drop_eq_nil_of_le (le_refl n), List.append_assoc] using h
  have hlast : n - 1 < out.length := by omega
  have h_emit_last : CS_transforms (locked_csg_of_noncontracting g hg)
      ((List.range n).map (nc_locked_mark ri))
      ((List.range (n - 1)).map (nc_locked_mark ri) ++
        nc_locked_outputSuffix ri out dflt (n - 1)) := by
    let cr : csrule T (NC_LockedNT g) :=
      { context_left := (List.range (n - 1)).map (nc_locked_mark ri),
        input_nonterminal := NC_LockedNT.mark ri (n - 1),
        context_right := [],
        output_string := nc_locked_outputFrom ri out dflt (n - 1) }
    have hcr : cr ∈ nc_locked_simRules ri r := by
      simp [cr, nc_locked_simRules, pattern, n, out, dflt]
    refine ⟨cr, [], [], nc_locked_simRule_mem g hg ri r hri hr cr hcr, ?_, ?_⟩
    · dsimp [cr]
      have hn_pred : n = (n - 1) + 1 := by omega
      rw [hn_pred, List.range_succ]
      simp [nc_locked_mark]
    · dsimp [cr]
      rw [nc_locked_outputFrom_eq_suffix g ri out dflt (n - 1) hlast]
      simp [List.append_assoc]
  have h_emit_rest_step : ∀ k : ℕ, k < n - 1 →
      CS_transforms (locked_csg_of_noncontracting g hg)
        ((List.range (k + 1)).map (nc_locked_mark ri) ++
          nc_locked_outputSuffix ri out dflt (k + 1))
        ((List.range k).map (nc_locked_mark ri) ++
          nc_locked_outputSuffix ri out dflt k) := by
    intro k hk
    have hkout : k < out.length := by omega
    let cr : csrule T (NC_LockedNT g) :=
      { context_left := (List.range k).map (nc_locked_mark ri),
        input_nonterminal := NC_LockedNT.mark ri k,
        context_right := nc_locked_outputSuffix ri out dflt (k + 1),
        output_string := [nc_locked_out ri k (out.getD k dflt)] }
    have hcr : cr ∈ nc_locked_simRules ri r := by
      have hk' : k < r.input_L.length + r.input_R.length := by
        simp [n, pattern, List.length_append] at hk
        omega
      simp [cr, nc_locked_simRules, pattern, n, out, dflt, hk']
    refine ⟨cr, [], [], nc_locked_simRule_mem g hg ri r hri hr cr hcr, ?_, ?_⟩
    · simp [cr, nc_locked_mark, List.range_succ, List.append_assoc]
    · rw [nc_locked_outputSuffix_cons g ri out dflt k hkout]
      simp [cr, nc_locked_mark, List.append_assoc]
  have h_emit_rest_seq : ∀ k : ℕ, k ≤ n - 1 →
      CS_derives (locked_csg_of_noncontracting g hg)
        ((List.range (n - 1)).map (nc_locked_mark ri) ++
          nc_locked_outputSuffix ri out dflt (n - 1))
        ((List.range k).map (nc_locked_mark ri) ++
          nc_locked_outputSuffix ri out dflt k) := by
    intro k hk
    induction' hm : n - 1 - k with m ih generalizing k
    · have hk_eq : k = n - 1 := by omega
      subst k
      exact CS_deri_self
    · have hklt : k < n - 1 := by omega
      have hih := ih (k + 1) (by omega) (by omega)
      exact CS_deri_of_deri_tran hih (h_emit_rest_step k hklt)
  have h_emit : CS_derives (locked_csg_of_noncontracting g hg)
      ((List.range n).map (nc_locked_mark ri))
      (nc_locked_outputSuffix ri out dflt 0) := by
    exact CS_deri_of_tran_deri h_emit_last (h_emit_rest_seq 0 (by omega))
  have h_cleanup : CS_derives (locked_csg_of_noncontracting g hg)
      (nc_locked_outputSuffix ri out dflt 0)
      (out.map nc_locked_liftSym) := by
    simpa [out, dflt] using nc_locked_cleanup_suffix g hg ri r hri hr 0 (by simp)
  have h := h_mark.trans (h_emit.trans h_cleanup)
  simpa [pattern, out] using h

lemma nc_locked_sim_one_transform (g : grammar T) (hg : grammar_noncontracting g)
    {w₁ w₂ : List (symbol T g.nt)} (h : grammar_transforms g w₁ w₂) :
    CS_derives (locked_csg_of_noncontracting g hg)
      (w₁.map nc_locked_liftSym) (w₂.map nc_locked_liftSym) := by
  obtain ⟨r, hr_mem, u, v, hw1, hw2⟩ := h
  subst hw1
  subst hw2
  obtain ⟨⟨ri, hri⟩, hr⟩ := List.mem_iff_get.mp hr_mem
  have hsim := nc_locked_sim_pattern g hg ri r hri hr
  have hctx := CS_deri_with_context
    (u.map nc_locked_liftSym) (v.map nc_locked_liftSym) hsim
  simp only [List.map_append, List.map_cons, List.map_nil] at hctx ⊢
  convert hctx using 1 <;> simp [List.append_assoc]

lemma nc_locked_sim_derives (g : grammar T) (hg : grammar_noncontracting g)
    {w₁ w₂ : List (symbol T g.nt)} (h : grammar_derives g w₁ w₂) :
    CS_derives (locked_csg_of_noncontracting g hg)
      (w₁.map nc_locked_liftSym) (w₂.map nc_locked_liftSym) := by
  induction h with
  | refl => exact CS_deri_self
  | tail h₁ h₂ ih =>
      exact CS_deri_of_deri_deri ih (nc_locked_sim_one_transform g hg h₂)

lemma nc_locked_forward (g : grammar T) (hg : grammar_noncontracting g)
    (w : List T) (hw : w ∈ grammar_language g) :
    w ∈ CS_language (locked_csg_of_noncontracting g hg) := by
  obtain ⟨hderive, hterms⟩ :
      grammar_derives g [symbol.nonterminal g.initial] (w.map symbol.terminal) ∧
        ∀ t ∈ w, t ∈ nc_grammarTerminals g :=
    ⟨hw, fun t ht => nc_derived_terminal_in_grammarTerminals g w hw t ht⟩
  have hmap : CS_derives (locked_csg_of_noncontracting g hg)
      [symbol.nonterminal (NC_LockedNT.orig g.initial)]
      (w.map (fun t => symbol.nonterminal (NC_LockedNT.term t))) := by
    convert nc_locked_sim_derives g hg hderive using 1 <;>
      simp [nc_locked_liftSym, nc_locked_symToNT, List.map_map]
  have hunlift : CS_derives (locked_csg_of_noncontracting g hg)
      (w.map (fun t => symbol.nonterminal (NC_LockedNT.term t)))
      (w.map symbol.terminal) :=
    nc_locked_unlift_all g hg w hterms
  exact hmap.trans hunlift

/-- Forward correctness of the locked non-contracting-to-CS construction. -/
theorem grammar_language_subset_locked_csg_of_noncontracting (g : grammar T)
    (hg : grammar_noncontracting g) :
    ∀ w, w ∈ grammar_language g → w ∈ CS_language (locked_csg_of_noncontracting g hg) :=
  fun w hw => nc_locked_forward g hg w hw

/-- Projection from locked-construction symbols back to original grammar symbols. -/
def nc_locked_proj_sym (g : grammar T) :
    symbol T (NC_LockedNT g) → symbol T g.nt
  | .terminal t => .terminal t
  | .nonterminal (.orig n) => .nonterminal n
  | .nonterminal (.term t) => .terminal t
  | .nonterminal (.mark _ _) => .nonterminal g.initial
  | .nonterminal (.out _ _ _) => .nonterminal g.initial

/-- Project a locked-construction sentential form back to original grammar symbols. -/
def nc_locked_proj (g : grammar T)
    (s : List (symbol T (NC_LockedNT g))) : List (symbol T g.nt) :=
  s.map (nc_locked_proj_sym g)

lemma nc_locked_proj_liftSym (g : grammar T) (s : symbol T g.nt) :
    nc_locked_proj_sym g (nc_locked_liftSym s) = s := by
  cases s <;> rfl

lemma nc_locked_proj_map_liftSym (g : grammar T)
    (l : List (symbol T g.nt)) :
    nc_locked_proj g (l.map nc_locked_liftSym) = l := by
  unfold nc_locked_proj
  rw [List.map_map]
  conv_rhs => rw [← List.map_id l]
  congr 1
  ext s
  exact nc_locked_proj_liftSym g s

lemma nc_locked_proj_initial (g : grammar T) :
    nc_locked_proj g [symbol.nonterminal (NC_LockedNT.orig g.initial)] =
      [symbol.nonterminal g.initial] := by
  simp [nc_locked_proj, nc_locked_proj_sym]

lemma nc_locked_proj_terminal (g : grammar T) (w : List T) :
    nc_locked_proj g (w.map symbol.terminal) = w.map symbol.terminal := by
  simp [nc_locked_proj, nc_locked_proj_sym, List.map_map]

/-- A locked sentential form is clean if it contains no input or output markers. -/
def nc_locked_is_clean (g : grammar T)
    (s : List (symbol T (NC_LockedNT g))) : Prop :=
  ∀ x ∈ s,
    (∀ ri k, x ≠ symbol.nonterminal (NC_LockedNT.mark ri k)) ∧
      (∀ ri k a, x ≠ symbol.nonterminal (NC_LockedNT.out ri k a))

lemma nc_locked_initial_clean (g : grammar T) :
    nc_locked_is_clean g [symbol.nonterminal (NC_LockedNT.orig g.initial)] := by
  intro x hx
  simp at hx
  subst x
  constructor <;> intro <;> simp

lemma nc_locked_terminal_clean (g : grammar T) (w : List T) :
    nc_locked_is_clean g (w.map symbol.terminal) := by
  intro x hx
  simp [List.mem_map] at hx
  obtain ⟨t, _, rfl⟩ := hx
  constructor <;> intro <;> simp

lemma nc_locked_liftSym_clean (g : grammar T) (s : symbol T g.nt) :
    nc_locked_is_clean g [nc_locked_liftSym s] := by
  intro x hx
  simp at hx
  subst x
  cases s <;> constructor <;> intro <;> simp [nc_locked_liftSym, nc_locked_symToNT]

lemma nc_locked_map_liftSym_clean (g : grammar T)
    (s : List (symbol T g.nt)) :
    nc_locked_is_clean g (s.map nc_locked_liftSym) := by
  intro x hx
  simp [List.mem_map] at hx
  obtain ⟨y, _hy, rfl⟩ := hx
  cases y <;> constructor <;> intro <;> simp [nc_locked_liftSym, nc_locked_symToNT]

lemma nc_locked_is_clean_of_subset (g : grammar T)
    {s t : List (symbol T (NC_LockedNT g))}
    (hclean : nc_locked_is_clean g t) (hsub : ∀ x, x ∈ s → x ∈ t) :
    nc_locked_is_clean g s := by
  intro x hx
  exact hclean x (hsub x hx)

lemma nc_locked_is_clean_append_left (g : grammar T)
    {s t : List (symbol T (NC_LockedNT g))}
    (hclean : nc_locked_is_clean g (s ++ t)) :
    nc_locked_is_clean g s :=
  nc_locked_is_clean_of_subset g hclean (by intro x hx; simp [List.mem_append, hx])

lemma nc_locked_is_clean_append_right (g : grammar T)
    {s t : List (symbol T (NC_LockedNT g))}
    (hclean : nc_locked_is_clean g (s ++ t)) :
    nc_locked_is_clean g t :=
  nc_locked_is_clean_of_subset g hclean (by intro x hx; simp [List.mem_append, hx])

lemma nc_locked_is_clean_append (g : grammar T)
    {s t : List (symbol T (NC_LockedNT g))}
    (hs : nc_locked_is_clean g s) (ht : nc_locked_is_clean g t) :
    nc_locked_is_clean g (s ++ t) := by
  intro x hx
  simp [List.mem_append] at hx
  cases hx with
  | inl hx => exact hs x hx
  | inr hx => exact ht x hx

lemma nc_locked_not_clean_iff_exists_marker (g : grammar T)
    (s : List (symbol T (NC_LockedNT g))) :
    ¬ nc_locked_is_clean g s ↔
      (∃ ri k, nc_locked_mark (g := g) ri k ∈ s) ∨
        ∃ ri k a, nc_locked_out (g := g) ri k a ∈ s := by
  classical
  constructor
  · intro hclean
    by_contra hnone
    apply hclean
    intro x hx
    constructor
    · intro ri k heq
      apply hnone
      exact Or.inl ⟨ri, k, by simpa [nc_locked_mark, heq] using hx⟩
    · intro ri k a heq
      apply hnone
      exact Or.inr ⟨ri, k, a, by simpa [nc_locked_out, heq] using hx⟩
  · intro hmarkers hclean
    rcases hmarkers with ⟨ri, k, hmem⟩ | ⟨ri, k, a, hmem⟩
    · exact (hclean (nc_locked_mark (g := g) ri k) hmem).1 ri k rfl
    · exact (hclean (nc_locked_out (g := g) ri k a) hmem).2 ri k a rfl

lemma nc_locked_clean_step_dirty_new_marker (g : grammar T)
    {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (hclean : nc_locked_is_clean g s₁) (hdirty : ¬ nc_locked_is_clean g s₂) :
    (∃ ri k, nc_locked_mark (g := g) ri k ∈ s₂ ∧
      nc_locked_mark (g := g) ri k ∉ s₁) ∨
      ∃ ri k a, nc_locked_out (g := g) ri k a ∈ s₂ ∧
        nc_locked_out (g := g) ri k a ∉ s₁ := by
  rcases (nc_locked_not_clean_iff_exists_marker g s₂).1 hdirty with
    ⟨ri, k, hmem⟩ | ⟨ri, k, a, hmem⟩
  · exact Or.inl ⟨ri, k, hmem,
      fun hsrc => (hclean (nc_locked_mark (g := g) ri k) hsrc).1 ri k rfl⟩
  · exact Or.inr ⟨ri, k, a, hmem,
      fun hsrc => (hclean (nc_locked_out (g := g) ri k a) hsrc).2 ri k a rfl⟩

lemma nc_locked_clean_step_proj_eq (g : grammar T) (hg : grammar_noncontracting g)
    {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : CS_transforms (locked_csg_of_noncontracting g hg) s₁ s₂)
    (hclean₁ : nc_locked_is_clean g s₁) (hclean₂ : nc_locked_is_clean g s₂) :
    nc_locked_proj g s₁ = nc_locked_proj g s₂ := by
  obtain ⟨cr, u, v, hcr, hs₁, hs₂⟩ := h
  unfold locked_csg_of_noncontracting at hcr
  simp [nc_locked_allRules] at hcr
  rcases hcr with hcr_unlift | ⟨simRi, grule, _hpair, hsim⟩
  · simp [nc_locked_unliftRules] at hcr_unlift
    obtain ⟨t, _ht, rfl⟩ := hcr_unlift
    rw [hs₁, hs₂]
    simp [nc_locked_proj, nc_locked_proj_sym, List.map_append]
  · unfold nc_locked_simRules at hsim
    simp [List.mem_append, List.mem_map] at hsim
    rcases hsim with hmark | hemitLast | hemitRest | hcleanup
    · obtain ⟨k, _hk, rfl⟩ := hmark
      have hmem : nc_locked_mark (g := g) simRi k ∈ s₂ := by
        rw [hs₂]
        simp [List.mem_append, nc_locked_mark]
      exact ((hclean₂ (nc_locked_mark (g := g) simRi k) hmem).1 simRi k rfl).elim
    · subst hemitLast
      have hmem : nc_locked_mark (g := g) simRi
          ((grule.input_L ++ [symbol.nonterminal grule.input_N] ++ grule.input_R).length - 1) ∈ s₁ := by
        rw [hs₁]
        simp [List.mem_append, nc_locked_mark]
      exact ((hclean₁
        (nc_locked_mark (g := g) simRi
          ((grule.input_L ++ [symbol.nonterminal grule.input_N] ++ grule.input_R).length - 1))
        hmem).1 simRi
          ((grule.input_L ++ [symbol.nonterminal grule.input_N] ++ grule.input_R).length - 1)
          rfl).elim
    · obtain ⟨k, _hk, rfl⟩ := hemitRest
      have hmem : nc_locked_mark (g := g) simRi k ∈ s₁ := by
        rw [hs₁]
        simp [List.mem_append, nc_locked_mark]
      exact ((hclean₁ (nc_locked_mark (g := g) simRi k) hmem).1 simRi k rfl).elim
    · obtain ⟨k, _hk, rfl⟩ := hcleanup
      have hmem : nc_locked_out (g := g) simRi k
          (grule.output_string.getD k (symbol.nonterminal grule.input_N)) ∈ s₁ := by
        rw [hs₁]
        simp [List.mem_append, nc_locked_out]
      exact ((hclean₁
        (nc_locked_out (g := g) simRi k
          (grule.output_string.getD k (symbol.nonterminal grule.input_N))) hmem).2
        simRi k (grule.output_string.getD k (symbol.nonterminal grule.input_N)) rfl).elim

lemma nc_locked_clean_step_grammar_derives (g : grammar T)
    (hg : grammar_noncontracting g)
    {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : CS_transforms (locked_csg_of_noncontracting g hg) s₁ s₂)
    (hclean₁ : nc_locked_is_clean g s₁) (hclean₂ : nc_locked_is_clean g s₂) :
    grammar_derives g (nc_locked_proj g s₁) (nc_locked_proj g s₂) := by
  rw [nc_locked_clean_step_proj_eq g hg h hclean₁ hclean₂]
  exact grammar_deri_self

lemma nc_locked_clean_step_dirty_mark_zero_shape (g : grammar T)
    (hg : grammar_noncontracting g)
    {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : CS_transforms (locked_csg_of_noncontracting g hg) s₁ s₂)
    (hclean : nc_locked_is_clean g s₁) (hdirty : ¬ nc_locked_is_clean g s₂) :
    ∃ simRi grule u v,
      (simRi, grule) ∈ (List.range g.rules.length).zip g.rules ∧
        let pattern := grule.input_L ++ [symbol.nonterminal grule.input_N] ++ grule.input_R
        let dflt : symbol T g.nt := symbol.nonterminal grule.input_N
        s₁ = u ++ [nc_locked_liftSym (pattern.getD 0 dflt)] ++
            (pattern.drop 1).map nc_locked_liftSym ++ v ∧
          s₂ = u ++ [nc_locked_mark (g := g) simRi 0] ++
            (pattern.drop 1).map nc_locked_liftSym ++ v := by
  obtain ⟨cr, u, v, hcr, hs₁, hs₂⟩ := h
  unfold locked_csg_of_noncontracting at hcr
  simp [nc_locked_allRules] at hcr
  rcases hcr with hcr_unlift | ⟨simRi, grule, hpair, hsim⟩
  · simp [nc_locked_unliftRules] at hcr_unlift
    obtain ⟨t, _ht, rfl⟩ := hcr_unlift
    have hu : nc_locked_is_clean g u := by
      refine nc_locked_is_clean_of_subset g hclean ?_
      intro x hx
      rw [hs₁]
      simp [List.mem_append, hx]
    have hv : nc_locked_is_clean g v := by
      refine nc_locked_is_clean_of_subset g hclean ?_
      intro x hx
      rw [hs₁]
      simp [List.mem_append, hx]
    exfalso
    apply hdirty
    intro x hx
    rw [hs₂] at hx
    simp [List.mem_append] at hx
    rcases hx with hx | hx | hx
    · exact hu x hx
    · subst x
      constructor <;> intro <;> simp
    · exact hv x hx
  · unfold nc_locked_simRules at hsim
    simp [List.mem_append, List.mem_map] at hsim
    rcases hsim with hmark | hemitLast | hemitRest | hcleanup
    · obtain ⟨k, _hk, rfl⟩ := hmark
      have hk_zero : k = 0 := by
        by_contra hne
        have hpos : 0 < k := Nat.pos_of_ne_zero hne
        have hctx : nc_locked_mark (g := g) simRi 0 ∈
            (List.range k).map (nc_locked_mark simRi) := by
          simp [List.mem_map]
          exact ⟨0, by simpa using hpos, rfl⟩
        have hsrc : nc_locked_mark (g := g) simRi 0 ∈ s₁ := by
          rw [hs₁]
          simp [List.mem_append, hctx]
        exact ((hclean (nc_locked_mark (g := g) simRi 0) hsrc).1 simRi 0 rfl).elim
      subst k
      refine ⟨simRi, grule, u, v, hpair, ?_⟩
      simp only
      constructor
      · rw [hs₁]
        simp [nc_locked_liftSym]
      · rw [hs₂]
        simp [nc_locked_mark]
    · subst hemitLast
      have hsrc : nc_locked_mark (g := g) simRi
          ((grule.input_L ++ [symbol.nonterminal grule.input_N] ++ grule.input_R).length - 1) ∈ s₁ := by
        rw [hs₁]
        simp [List.mem_append, nc_locked_mark]
      exact ((hclean
        (nc_locked_mark (g := g) simRi
          ((grule.input_L ++ [symbol.nonterminal grule.input_N] ++ grule.input_R).length - 1))
        hsrc).1 simRi
          ((grule.input_L ++ [symbol.nonterminal grule.input_N] ++ grule.input_R).length - 1)
          rfl).elim
    · obtain ⟨k, _hk, rfl⟩ := hemitRest
      have hsrc : nc_locked_mark (g := g) simRi k ∈ s₁ := by
        rw [hs₁]
        simp [List.mem_append, nc_locked_mark]
      exact ((hclean (nc_locked_mark (g := g) simRi k) hsrc).1 simRi k rfl).elim
    · obtain ⟨k, _hk, rfl⟩ := hcleanup
      have hsrc : nc_locked_out (g := g) simRi k
          (grule.output_string.getD k (symbol.nonterminal grule.input_N)) ∈ s₁ := by
        rw [hs₁]
        simp [List.mem_append, nc_locked_out]
      exact ((hclean
        (nc_locked_out (g := g) simRi k
          (grule.output_string.getD k (symbol.nonterminal grule.input_N))) hsrc).2
        simRi k (grule.output_string.getD k (symbol.nonterminal grule.input_N)) rfl).elim

lemma nc_locked_dirty_step_clean_cleanup_shape (g : grammar T)
    (hg : grammar_noncontracting g)
    {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : CS_transforms (locked_csg_of_noncontracting g hg) s₁ s₂)
    (hdirty : ¬ nc_locked_is_clean g s₁) (hclean : nc_locked_is_clean g s₂) :
    ∃ simRi grule k u v,
      (simRi, grule) ∈ (List.range g.rules.length).zip g.rules ∧
        k < grule.output_string.length ∧
        let dflt : symbol T g.nt := symbol.nonterminal grule.input_N
        s₁ = u ++ [nc_locked_out (g := g) simRi k (grule.output_string.getD k dflt)] ++ v ∧
          s₂ = u ++ [nc_locked_liftSym (grule.output_string.getD k dflt)] ++ v := by
  obtain ⟨cr, u, v, hcr, hs₁, hs₂⟩ := h
  unfold locked_csg_of_noncontracting at hcr
  simp [nc_locked_allRules] at hcr
  rcases hcr with hcr_unlift | ⟨simRi, grule, hpair, hsim⟩
  · simp [nc_locked_unliftRules] at hcr_unlift
    obtain ⟨t, _ht, rfl⟩ := hcr_unlift
    have hu : nc_locked_is_clean g u := by
      refine nc_locked_is_clean_of_subset g hclean ?_
      intro x hx
      rw [hs₂]
      simp [List.mem_append, hx]
    have hv : nc_locked_is_clean g v := by
      refine nc_locked_is_clean_of_subset g hclean ?_
      intro x hx
      rw [hs₂]
      simp [List.mem_append, hx]
    exfalso
    apply hdirty
    intro x hx
    rw [hs₁] at hx
    simp [List.mem_append] at hx
    rcases hx with hx | hx | hx
    · exact hu x hx
    · subst x
      constructor <;> intro <;> simp
    · exact hv x hx
  · unfold nc_locked_simRules at hsim
    simp [List.mem_append, List.mem_map] at hsim
    rcases hsim with hmark | hemitLast | hemitRest | hcleanup
    · obtain ⟨k, _hk, rfl⟩ := hmark
      have htarget : nc_locked_mark (g := g) simRi k ∈ s₂ := by
        rw [hs₂]
        simp [List.mem_append, nc_locked_mark]
      exact ((hclean (nc_locked_mark (g := g) simRi k) htarget).1 simRi k rfl).elim
    · subst hemitLast
      let last := grule.input_L.length + grule.input_R.length
      let dflt : symbol T g.nt := symbol.nonterminal grule.input_N
      have hout :
          nc_locked_out (g := g) simRi last
            (grule.output_string.getD last dflt) ∈
            nc_locked_outputFrom simRi grule.output_string dflt last := by
        simp [nc_locked_outputFrom, nc_locked_out]
      have htarget :
          nc_locked_out (g := g) simRi last
            (grule.output_string.getD last dflt) ∈ s₂ := by
        rw [hs₂]
        simp_all [List.mem_append, last, dflt]
      exact ((hclean
        (nc_locked_out (g := g) simRi last
          (grule.output_string.getD last dflt)) htarget).2
        simRi last (grule.output_string.getD last dflt) rfl).elim
    · obtain ⟨k, _hk, rfl⟩ := hemitRest
      have htarget : nc_locked_out (g := g) simRi k
          (grule.output_string.getD k (symbol.nonterminal grule.input_N)) ∈ s₂ := by
        rw [hs₂]
        simp [List.mem_append, nc_locked_out]
      exact ((hclean
        (nc_locked_out (g := g) simRi k
          (grule.output_string.getD k (symbol.nonterminal grule.input_N))) htarget).2
        simRi k (grule.output_string.getD k (symbol.nonterminal grule.input_N)) rfl).elim
    · obtain ⟨k, hk, hcr_eq⟩ := hcleanup
      subst cr
      refine ⟨simRi, grule, k, u, v, hpair, by simpa using hk, ?_⟩
      constructor
      · simpa [nc_locked_out, List.append_assoc] using hs₁
      · simpa [List.append_assoc] using hs₂

lemma nc_locked_rule_mem_cases (g : grammar T) (hg : grammar_noncontracting g)
    {cr : csrule T (NC_LockedNT g)}
    (hcr : cr ∈ (locked_csg_of_noncontracting g hg).rules) :
    (∃ t, t ∈ nc_grammarTerminals g ∧
      cr =
        { context_left := [],
          input_nonterminal := NC_LockedNT.term t,
          context_right := [],
          output_string := [symbol.terminal t] }) ∨
      ∃ simRi grule,
        (simRi, grule) ∈ (List.range g.rules.length).zip g.rules ∧
          (let pattern := grule.input_L ++ [symbol.nonterminal grule.input_N] ++
              grule.input_R
           let dflt : symbol T g.nt := symbol.nonterminal grule.input_N
           (∃ k, k < pattern.length ∧
              cr =
                { context_left := (List.range k).map (nc_locked_mark simRi),
                  input_nonterminal := nc_locked_symToNT (pattern.getD k dflt),
                  context_right := (pattern.drop (k + 1)).map nc_locked_liftSym,
                  output_string := [nc_locked_mark simRi k] }) ∨
            cr =
              { context_left := (List.range (pattern.length - 1)).map
                  (nc_locked_mark simRi),
                input_nonterminal := NC_LockedNT.mark simRi (pattern.length - 1),
                context_right := [],
                output_string :=
                  nc_locked_outputFrom simRi grule.output_string dflt
                    (pattern.length - 1) } ∨
            (∃ k, k < pattern.length - 1 ∧
              cr =
                { context_left := (List.range k).map (nc_locked_mark simRi),
                  input_nonterminal := NC_LockedNT.mark simRi k,
                  context_right :=
                    nc_locked_outputSuffix simRi grule.output_string dflt (k + 1),
                  output_string :=
                    [nc_locked_out simRi k (grule.output_string.getD k dflt)] }) ∨
            ∃ k, k < grule.output_string.length ∧
              cr =
                { context_left := [],
                  input_nonterminal :=
                    NC_LockedNT.out simRi k
                      (grule.output_string.getD k dflt),
                  context_right := [],
                  output_string :=
                    [nc_locked_liftSym (grule.output_string.getD k dflt)] }) := by
  unfold locked_csg_of_noncontracting at hcr
  simp [nc_locked_allRules] at hcr
  rcases hcr with hcr_unlift | ⟨simRi, grule, hpair, hsim⟩
  · simp [nc_locked_unliftRules] at hcr_unlift
    obtain ⟨t, ht, rfl⟩ := hcr_unlift
    exact Or.inl ⟨t, ht, rfl⟩
  · right
    refine ⟨simRi, grule, hpair, ?_⟩
    unfold nc_locked_simRules at hsim
    simp [List.mem_append, List.mem_map] at hsim
    rcases hsim with hmark | hemitLast | hemitRest | hcleanup
    · obtain ⟨k, hk, rfl⟩ := hmark
      refine Or.inl ⟨k, by simpa [List.length_append] using hk, ?_⟩
      simp [List.map_append, List.map_drop, List.append_assoc]
    · subst hemitLast
      refine Or.inr (Or.inl ?_)
      simp [List.length_append]
    · obtain ⟨k, hk, rfl⟩ := hemitRest
      refine Or.inr (Or.inr (Or.inl ⟨k, by simpa [List.length_append] using hk, ?_⟩))
      simp [List.length_append]
    · obtain ⟨k, hk, rfl⟩ := hcleanup
      exact Or.inr (Or.inr (Or.inr ⟨k, by simpa using hk, rfl⟩))

lemma nc_locked_rule_input_mark_shape (g : grammar T)
    (hg : grammar_noncontracting g)
    {cr : csrule T (NC_LockedNT g)}
    (hcr : cr ∈ (locked_csg_of_noncontracting g hg).rules)
    {ri k : ℕ} (hinput : cr.input_nonterminal = NC_LockedNT.mark ri k) :
    ∃ simRi grule,
      (simRi, grule) ∈ (List.range g.rules.length).zip g.rules ∧
        ri = simRi ∧
          (let pattern := grule.input_L ++ [symbol.nonterminal grule.input_N] ++
              grule.input_R
           let dflt : symbol T g.nt := symbol.nonterminal grule.input_N
           (k = pattern.length - 1 ∧
              cr =
                { context_left := (List.range (pattern.length - 1)).map
                    (nc_locked_mark simRi),
                  input_nonterminal := NC_LockedNT.mark simRi (pattern.length - 1),
                  context_right := [],
                  output_string :=
                    nc_locked_outputFrom simRi grule.output_string dflt
                      (pattern.length - 1) }) ∨
            (k < pattern.length - 1 ∧
              cr =
                { context_left := (List.range k).map (nc_locked_mark simRi),
                  input_nonterminal := NC_LockedNT.mark simRi k,
                  context_right :=
                    nc_locked_outputSuffix simRi grule.output_string dflt (k + 1),
                  output_string :=
                    [nc_locked_out simRi k (grule.output_string.getD k dflt)] })) := by
  unfold locked_csg_of_noncontracting at hcr
  simp [nc_locked_allRules] at hcr
  rcases hcr with hcr_unlift | ⟨simRi, grule, hpair, hsim⟩
  · simp [nc_locked_unliftRules] at hcr_unlift
    obtain ⟨t, _ht, rfl⟩ := hcr_unlift
    simp at hinput
  · unfold nc_locked_simRules at hsim
    simp [List.mem_append, List.mem_map] at hsim
    rcases hsim with hmark | hemitLast | hemitRest | hcleanup
    · obtain ⟨j, _hj, rfl⟩ := hmark
      let s :=
        (grule.input_L ++ [symbol.nonterminal grule.input_N] ++
          grule.input_R).getD j (symbol.nonterminal grule.input_N)
      have hinput' : nc_locked_symToNT s = NC_LockedNT.mark ri k := by
        simpa [s] using hinput
      exact (nc_locked_symToNT_ne_mark s ri k hinput').elim
    · subst hemitLast
      simp at hinput
      rcases hinput with ⟨hri, hk⟩
      refine ⟨simRi, grule, hpair, hri.symm, ?_⟩
      dsimp only
      refine Or.inl ⟨?_, ?_⟩
      · simp [List.length_append, hk.symm]
      · simp [List.length_append]
    · obtain ⟨j, hj, rfl⟩ := hemitRest
      simp at hinput
      rcases hinput with ⟨hri, hjk⟩
      subst j
      refine ⟨simRi, grule, hpair, hri.symm, ?_⟩
      dsimp only
      exact Or.inr ⟨by simpa [List.length_append] using hj, rfl⟩
    · obtain ⟨j, _hj, rfl⟩ := hcleanup
      simp [nc_locked_out] at hinput

lemma nc_locked_rule_input_out_shape (g : grammar T)
    (hg : grammar_noncontracting g)
    {cr : csrule T (NC_LockedNT g)}
    (hcr : cr ∈ (locked_csg_of_noncontracting g hg).rules)
    {ri k : ℕ} {a : symbol T g.nt}
    (hinput : cr.input_nonterminal = NC_LockedNT.out ri k a) :
    ∃ simRi grule,
      (simRi, grule) ∈ (List.range g.rules.length).zip g.rules ∧
        ri = simRi ∧ k < grule.output_string.length ∧
          a = grule.output_string.getD k (symbol.nonterminal grule.input_N) ∧
          cr =
            { context_left := [],
              input_nonterminal :=
                NC_LockedNT.out simRi k
                  (grule.output_string.getD k (symbol.nonterminal grule.input_N)),
              context_right := [],
              output_string :=
                [nc_locked_liftSym
                  (grule.output_string.getD k (symbol.nonterminal grule.input_N))] } := by
  unfold locked_csg_of_noncontracting at hcr
  simp [nc_locked_allRules] at hcr
  rcases hcr with hcr_unlift | ⟨simRi, grule, hpair, hsim⟩
  · simp [nc_locked_unliftRules] at hcr_unlift
    obtain ⟨t, _ht, rfl⟩ := hcr_unlift
    simp at hinput
  · unfold nc_locked_simRules at hsim
    simp [List.mem_append, List.mem_map] at hsim
    rcases hsim with hmark | hemitLast | hemitRest | hcleanup
    · obtain ⟨j, _hj, rfl⟩ := hmark
      let s :=
        (grule.input_L ++ [symbol.nonterminal grule.input_N] ++
          grule.input_R).getD j (symbol.nonterminal grule.input_N)
      have hinput' : nc_locked_symToNT s = NC_LockedNT.out ri k a := by
        simpa [s] using hinput
      exact (nc_locked_symToNT_ne_out s ri k a hinput').elim
    · subst hemitLast
      simp at hinput
    · obtain ⟨j, _hj, rfl⟩ := hemitRest
      simp [nc_locked_out] at hinput
    · obtain ⟨j, hj, rfl⟩ := hcleanup
      simp at hinput
      rcases hinput with ⟨hri, hjk, ha⟩
      subst j
      refine ⟨simRi, grule, hpair, hri.symm, by simpa using hj, ha.symm, ?_⟩
      simp

lemma nc_locked_rule_output_mark_shape (g : grammar T)
    (hg : grammar_noncontracting g)
    {cr : csrule T (NC_LockedNT g)}
    (hcr : cr ∈ (locked_csg_of_noncontracting g hg).rules)
    {ri k : ℕ} (hout : nc_locked_mark (g := g) ri k ∈ cr.output_string) :
    ∃ simRi grule,
      (simRi, grule) ∈ (List.range g.rules.length).zip g.rules ∧
        ri = simRi ∧
          (let pattern := grule.input_L ++ [symbol.nonterminal grule.input_N] ++
              grule.input_R
           let dflt : symbol T g.nt := symbol.nonterminal grule.input_N
           k < pattern.length ∧
             cr =
              { context_left := (List.range k).map (nc_locked_mark simRi),
                input_nonterminal := nc_locked_symToNT (pattern.getD k dflt),
                context_right := (pattern.drop (k + 1)).map nc_locked_liftSym,
                output_string := [nc_locked_mark simRi k] }) := by
  rcases nc_locked_rule_mem_cases g hg hcr with hcr_unlift | hcr_sim
  · obtain ⟨t, _ht, rfl⟩ := hcr_unlift
    simp [nc_locked_mark] at hout
  · obtain ⟨simRi, grule, hpair, hcases⟩ := hcr_sim
    dsimp only at hcases
    rcases hcases with hmark | hemitLast | hemitRest | hcleanup
    · obtain ⟨j, hj, hshape⟩ := hmark
      subst cr
      simp [nc_locked_mark] at hout
      rcases hout with ⟨hri, hk⟩
      subst ri
      subst k
      refine ⟨simRi, grule, hpair, rfl, ?_⟩
      dsimp only
      exact ⟨hj, rfl⟩
    · subst cr
      simp [nc_locked_outputFrom, nc_locked_outputSuffix, nc_locked_mark,
        nc_locked_out] at hout
    · obtain ⟨j, _hj, hshape⟩ := hemitRest
      subst cr
      simp [nc_locked_mark, nc_locked_out] at hout
    · obtain ⟨j, _hj, hshape⟩ := hcleanup
      subst cr
      have hclean :=
        nc_locked_liftSym_clean g
          (grule.output_string.getD j (symbol.nonterminal grule.input_N))
      exact ((hclean (nc_locked_mark (g := g) ri k) (by simpa using hout)).1
        ri k rfl).elim

lemma nc_locked_rule_output_out_shape (g : grammar T)
    (hg : grammar_noncontracting g)
    {cr : csrule T (NC_LockedNT g)}
    (hcr : cr ∈ (locked_csg_of_noncontracting g hg).rules)
    {ri k : ℕ} {a : symbol T g.nt}
    (hout : nc_locked_out (g := g) ri k a ∈ cr.output_string) :
    ∃ simRi grule,
      (simRi, grule) ∈ (List.range g.rules.length).zip g.rules ∧
        ri = simRi ∧ k < grule.output_string.length ∧
          a = grule.output_string.getD k (symbol.nonterminal grule.input_N) ∧
          (let pattern := grule.input_L ++ [symbol.nonterminal grule.input_N] ++
              grule.input_R
           let dflt : symbol T g.nt := symbol.nonterminal grule.input_N
           (pattern.length - 1 ≤ k ∧
              cr =
                { context_left := (List.range (pattern.length - 1)).map
                    (nc_locked_mark simRi),
                  input_nonterminal := NC_LockedNT.mark simRi (pattern.length - 1),
                  context_right := [],
                  output_string :=
                    nc_locked_outputFrom simRi grule.output_string dflt
                      (pattern.length - 1) }) ∨
            (k < pattern.length - 1 ∧
              cr =
                { context_left := (List.range k).map (nc_locked_mark simRi),
                  input_nonterminal := NC_LockedNT.mark simRi k,
                  context_right :=
                    nc_locked_outputSuffix simRi grule.output_string dflt (k + 1),
                  output_string :=
                    [nc_locked_out simRi k (grule.output_string.getD k dflt)] })) := by
  rcases nc_locked_rule_mem_cases g hg hcr with hcr_unlift | hcr_sim
  · obtain ⟨t, _ht, rfl⟩ := hcr_unlift
    simp [nc_locked_out] at hout
  · obtain ⟨simRi, grule, hpair, hcases⟩ := hcr_sim
    dsimp only at hcases
    rcases hcases with hmark | hemitLast | hemitRest | hcleanup
    · obtain ⟨j, _hj, hshape⟩ := hmark
      subst cr
      simp [nc_locked_mark, nc_locked_out] at hout
    · subst cr
      let pattern := grule.input_L ++ [symbol.nonterminal grule.input_N] ++
        grule.input_R
      let dflt : symbol T g.nt := symbol.nonterminal grule.input_N
      have hnpos : 0 < pattern.length := by
        simp [pattern, List.length_append]
      have hlast_lt : pattern.length - 1 < grule.output_string.length := by
        have hnc : pattern.length ≤ grule.output_string.length := by
          simpa [pattern, List.length_append, Nat.add_assoc, Nat.add_comm,
            Nat.add_left_comm] using hg grule (List.of_mem_zip hpair).2
        omega
      obtain ⟨hri, hle, hlt, ha⟩ :=
        nc_locked_outputFrom_mem_out_shape (g := g) hlast_lt hout
      subst ri
      refine ⟨simRi, grule, hpair, rfl, hlt, ha, ?_⟩
      dsimp only
      exact Or.inl ⟨hle, rfl⟩
    · obtain ⟨j, hj, hshape⟩ := hemitRest
      subst cr
      simp [nc_locked_out] at hout
      rcases hout with ⟨hri, hk, ha⟩
      subst ri
      subst k
      refine ⟨simRi, grule, hpair, rfl, ?_, ?_, ?_⟩
      · have hnc : (grule.input_L ++ [symbol.nonterminal grule.input_N] ++
            grule.input_R).length ≤ grule.output_string.length := by
          simpa [List.length_append, Nat.add_assoc, Nat.add_comm, Nat.add_left_comm]
            using hg grule (List.of_mem_zip hpair).2
        omega
      · simpa using ha
      · dsimp only
        exact Or.inr ⟨hj, rfl⟩
    · obtain ⟨j, _hj, hshape⟩ := hcleanup
      subst cr
      have hclean :=
        nc_locked_liftSym_clean g
          (grule.output_string.getD j (symbol.nonterminal grule.input_N))
      exact ((hclean (nc_locked_out (g := g) ri k a) (by simpa using hout)).2
        ri k a rfl).elim

lemma nc_locked_transform_added_mark_shape (g : grammar T)
    (hg : grammar_noncontracting g)
    {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : CS_transforms (locked_csg_of_noncontracting g hg) s₁ s₂)
    {ri k : ℕ}
    (htgt : nc_locked_mark (g := g) ri k ∈ s₂)
    (hsrc : nc_locked_mark (g := g) ri k ∉ s₁) :
    ∃ simRi grule,
      (simRi, grule) ∈ (List.range g.rules.length).zip g.rules ∧
        ri = simRi ∧
          (let pattern := grule.input_L ++ [symbol.nonterminal grule.input_N] ++
              grule.input_R
           let dflt : symbol T g.nt := symbol.nonterminal grule.input_N
           k < pattern.length ∧
             ∃ cr : csrule T (NC_LockedNT g),
               cr ∈ (locked_csg_of_noncontracting g hg).rules ∧
                 cr.context_left = (List.range k).map (nc_locked_mark simRi) ∧
                 cr.input_nonterminal = nc_locked_symToNT (pattern.getD k dflt) ∧
                 cr.context_right = (pattern.drop (k + 1)).map nc_locked_liftSym ∧
                 cr.output_string = [nc_locked_mark simRi k]) := by
  obtain ⟨cr, hcr, hout⟩ :=
    CS_transform_added_symbol_is_output_general h htgt hsrc
  obtain ⟨simRi, grule, hpair, hri, hshape⟩ :=
    nc_locked_rule_output_mark_shape g hg hcr hout
  refine ⟨simRi, grule, hpair, hri, ?_⟩
  dsimp only at hshape ⊢
  rcases hshape with ⟨hk, hcrshape⟩
  refine ⟨hk, cr, hcr, ?_, ?_, ?_, ?_⟩
  · rw [hcrshape]
  · rw [hcrshape]
  · rw [hcrshape]
  · rw [hcrshape]

/-- If a transform newly creates marker `k`, then the rule that creates it is a
phase-1 marking rule and all lower markers for that same simulation occur in the
source.  This records the context dependency of the locked input-marking phase. -/
lemma nc_locked_transform_added_mark_source_context_marks (g : grammar T)
    (hg : grammar_noncontracting g)
    {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : CS_transforms (locked_csg_of_noncontracting g hg) s₁ s₂)
    {ri k : ℕ}
    (htgt : nc_locked_mark (g := g) ri k ∈ s₂)
    (hsrc : nc_locked_mark (g := g) ri k ∉ s₁) :
    ∃ simRi grule,
      (simRi, grule) ∈ (List.range g.rules.length).zip g.rules ∧
        ri = simRi ∧
          (let pattern := grule.input_L ++ [symbol.nonterminal grule.input_N] ++
              grule.input_R
           k < pattern.length ∧
             ∀ j, j < k → nc_locked_mark (g := g) simRi j ∈ s₁) := by
  obtain ⟨cr, u, v, hcr, hs₁, hs₂⟩ := h
  have hout : nc_locked_mark (g := g) ri k ∈ cr.output_string := by
    rw [hs₁] at hsrc
    rw [hs₂] at htgt
    simp [List.mem_append] at hsrc htgt
    rcases htgt with htgt | htgt | htgt | htgt | htgt
    · exact (hsrc.1 htgt).elim
    · exact (hsrc.2.1 htgt).elim
    · exact htgt
    · exact (hsrc.2.2.2.1 htgt).elim
    · exact (hsrc.2.2.2.2 htgt).elim
  obtain ⟨simRi, grule, hpair, hri, hshape⟩ :=
    nc_locked_rule_output_mark_shape g hg hcr hout
  refine ⟨simRi, grule, hpair, hri, ?_⟩
  dsimp only at hshape ⊢
  obtain ⟨hk, hcrshape⟩ := hshape
  refine ⟨hk, ?_⟩
  intro j hj
  have hctx :
      nc_locked_mark (g := g) simRi j ∈
        (List.range k).map (nc_locked_mark simRi) := by
    simp [List.mem_map]
    exact ⟨j, hj, rfl⟩
  rw [hs₁, hcrshape]
  simp [List.mem_append, hctx]

lemma nc_locked_transform_added_mark_from_single_mark_source (g : grammar T)
    (hg : grammar_noncontracting g)
    {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : CS_transforms (locked_csg_of_noncontracting g hg) s₁ s₂)
    {baseRi targetRi targetK : ℕ}
    (htgt : nc_locked_mark (g := g) targetRi targetK ∈ s₂)
    (hsrc : nc_locked_mark (g := g) targetRi targetK ∉ s₁)
    (hmarks : ∀ ri k, nc_locked_mark (g := g) ri k ∈ s₁ ↔ (ri, k) = (baseRi, 0)) :
    ∃ simRi grule,
      (simRi, grule) ∈ (List.range g.rules.length).zip g.rules ∧
        targetRi = simRi ∧
        (let pattern := grule.input_L ++ [symbol.nonterminal grule.input_N] ++
            grule.input_R
         targetK < pattern.length ∧
           (targetK = 0 ∨ (simRi = baseRi ∧ targetK = 1))) := by
  obtain ⟨cr, u, v, hcr, hs₁, hs₂⟩ := h
  have hout : nc_locked_mark (g := g) targetRi targetK ∈ cr.output_string := by
    rw [hs₁] at hsrc
    rw [hs₂] at htgt
    simp [List.mem_append] at hsrc htgt
    rcases htgt with htgt | htgt | htgt | htgt | htgt
    · exact (hsrc.1 htgt).elim
    · exact (hsrc.2.1 htgt).elim
    · exact htgt
    · exact (hsrc.2.2.2.1 htgt).elim
    · exact (hsrc.2.2.2.2 htgt).elim
  obtain ⟨simRi, grule, hpair, hri, hshape⟩ :=
    nc_locked_rule_output_mark_shape g hg hcr hout
  refine ⟨simRi, grule, hpair, hri, ?_⟩
  dsimp only at hshape ⊢
  obtain ⟨hk, hcrshape⟩ := hshape
  refine ⟨hk, ?_⟩
  by_cases hk0 : targetK = 0
  · exact Or.inl hk0
  · right
    have hpos : 0 < targetK := Nat.pos_of_ne_zero hk0
    have hctx0 :
        nc_locked_mark (g := g) simRi 0 ∈ cr.context_left := by
      rw [hcrshape]
      simp [List.mem_map]
      exact ⟨0, hpos, rfl⟩
    have hsrc0 : nc_locked_mark (g := g) simRi 0 ∈ s₁ := by
      rw [hs₁]
      simp [List.mem_append, hctx0]
    have hsim_base : simRi = baseRi := by
      have hp := (hmarks simRi 0).1 hsrc0
      exact congrArg Prod.fst hp
    by_cases hk1 : targetK = 1
    · exact ⟨hsim_base, hk1⟩
    · have hgt1 : 1 < targetK := by omega
      have hctx1 :
          nc_locked_mark (g := g) simRi 1 ∈ cr.context_left := by
        rw [hcrshape]
        simp [List.mem_map]
        exact ⟨1, hgt1, rfl⟩
      have hsrc1 : nc_locked_mark (g := g) simRi 1 ∈ s₁ := by
        rw [hs₁]
        simp [List.mem_append, hctx1]
      have hp := (hmarks simRi 1).1 hsrc1
      have hsecond := congrArg Prod.snd hp
      omega

/-- If a step whose source contains a single phase-`0` marker creates the phase-`1`
marker for that same simulation, then the step is exactly the first continuation
marking rule for the corresponding original production. -/
lemma nc_locked_transform_added_base_one_mark_shape (g : grammar T)
    (hg : grammar_noncontracting g)
    {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : CS_transforms (locked_csg_of_noncontracting g hg) s₁ s₂)
    {baseRi : ℕ}
    (htgt : nc_locked_mark (g := g) baseRi 1 ∈ s₂)
    (hsrc : nc_locked_mark (g := g) baseRi 1 ∉ s₁)
    (_hmarks : ∀ ri k, nc_locked_mark (g := g) ri k ∈ s₁ ↔ (ri, k) = (baseRi, 0)) :
    ∃ grule,
      (baseRi, grule) ∈ (List.range g.rules.length).zip g.rules ∧
        (let pattern := grule.input_L ++ [symbol.nonterminal grule.input_N] ++
            grule.input_R
         let dflt : symbol T g.nt := symbol.nonterminal grule.input_N
         1 < pattern.length ∧
           ∃ cr : csrule T (NC_LockedNT g),
             cr ∈ (locked_csg_of_noncontracting g hg).rules ∧
               cr.context_left = [nc_locked_mark baseRi 0] ∧
               cr.input_nonterminal = nc_locked_symToNT (pattern.getD 1 dflt) ∧
               cr.context_right = (pattern.drop 2).map nc_locked_liftSym ∧
               cr.output_string = [nc_locked_mark baseRi 1]) := by
  obtain ⟨simRi, grule, hpair, hri, hshape⟩ :=
    nc_locked_transform_added_mark_shape g hg h htgt hsrc
  subst simRi
  refine ⟨grule, hpair, ?_⟩
  dsimp only at hshape ⊢
  obtain ⟨hpat, cr, hcr, hleft, hinput, hright, hout⟩ := hshape
  refine ⟨hpat, cr, hcr, ?_, ?_, ?_, ?_⟩
  · simpa using hleft
  · exact hinput
  · simpa using hright
  · exact hout

/-- Exact source and target shape for the first continuation marking step of a
locked simulation.  Once the boundary phase-`1` marker is newly created, the
whole step is forced to replace the second lifted input symbol by that marker,
with the original surrounding context unchanged. -/
lemma nc_locked_transform_added_base_one_mark_exact
    (g : grammar T) (hg : grammar_noncontracting g)
    {ri : ℕ} {r : grule T g.nt}
    {u v smid : List (symbol T (NC_LockedNT g))}
    (hpair : (ri, r) ∈ (List.range g.rules.length).zip g.rules)
    (hu : nc_locked_is_clean g u) (hv : nc_locked_is_clean g v)
    (hstep : CS_transforms (locked_csg_of_noncontracting g hg)
      ((u ++ [nc_locked_mark (g := g) ri 0] ++
        (((r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R).drop 1).map
          (nc_locked_liftSym (g := g))) ++ v) :
          List (symbol T (NC_LockedNT g)))
      smid)
    (hone : nc_locked_mark (g := g) ri 1 ∈ smid) :
    let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
    1 < pattern.length ∧
      smid =
        u ++ [nc_locked_mark (g := g) ri 0] ++
          [nc_locked_mark (g := g) ri 1] ++
          (pattern.drop 2).map (nc_locked_liftSym (g := g)) ++ v := by
  let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
  let dflt : symbol T g.nt := symbol.nonterminal r.input_N
  have hnot_u_one : nc_locked_mark (g := g) ri 1 ∉ u := by
    intro hmem
    exact ((hu (nc_locked_mark (g := g) ri 1) hmem).1 ri 1 rfl).elim
  have hnot_v_one : nc_locked_mark (g := g) ri 1 ∉ v := by
    intro hmem
    exact ((hv (nc_locked_mark (g := g) ri 1) hmem).1 ri 1 rfl).elim
  have hnot_drop_one :
      nc_locked_mark (g := g) ri 1 ∉
        (pattern.drop 1).map (nc_locked_liftSym (g := g)) := by
    intro hmem
    exact (((nc_locked_map_liftSym_clean g (pattern.drop 1))
      (nc_locked_mark (g := g) ri 1) hmem).1 ri 1 rfl).elim
  have hnot_drop_one_tail :
      nc_locked_mark (g := g) ri 1 ∉
        (pattern.map (nc_locked_liftSym (g := g))).tail := by
    simpa [List.map_drop] using hnot_drop_one
  have hsrc_one :
      nc_locked_mark (g := g) ri 1 ∉
        (u ++ [nc_locked_mark (g := g) ri 0] ++
          (pattern.drop 1).map (nc_locked_liftSym (g := g)) ++ v) := by
    intro hmem
    simp [List.mem_append, nc_locked_mark] at hmem
    rcases hmem with hmem | hmem | hmem
    · exact hnot_u_one hmem
    · exact hnot_drop_one_tail hmem
    · exact hnot_v_one hmem
  obtain ⟨cr, stepU, stepV, hcr, hs_src, hs_tgt⟩ := hstep
  change csrule T (NC_LockedNT g) at cr
  change List (symbol T (NC_LockedNT g)) at stepU
  change List (symbol T (NC_LockedNT g)) at stepV
  have hout : nc_locked_mark (g := g) ri 1 ∈ cr.output_string := by
    rw [hs_tgt] at hone
    rw [hs_src] at hsrc_one
    simp [List.mem_append] at hone hsrc_one
    rcases hone with hone | hone | hone | hone | hone
    · exact (hsrc_one.1 hone).elim
    · exact (hsrc_one.2.1 hone).elim
    · exact hone
    · exact (hsrc_one.2.2.2.1 hone).elim
    · exact (hsrc_one.2.2.2.2 hone).elim
  obtain ⟨simRi, grule, hpair', hri, hshape⟩ :=
    nc_locked_rule_output_mark_shape g hg hcr hout
  subst simRi
  have hgrule : grule = r := nc_rule_zip_rule_unique g hpair' hpair
  subst grule
  dsimp only at hshape
  obtain ⟨hpat, hcrshape⟩ := hshape
  have hs_src' :
      u ++ [nc_locked_mark (g := g) ri 0] ++
          (pattern.drop 1).map (nc_locked_liftSym (g := g)) ++ v =
        stepU ++ [nc_locked_mark (g := g) ri 0] ++
          [nc_locked_liftSym (pattern.getD 1 dflt)] ++
          (pattern.drop 2).map (nc_locked_liftSym (g := g)) ++ stepV := by
    rw [hs_src, hcrshape]
    simp [pattern, dflt, nc_locked_mark, nc_locked_liftSym, List.append_assoc]
  have hs_tgt' :
      smid =
        stepU ++ [nc_locked_mark (g := g) ri 0] ++
          [nc_locked_mark (g := g) ri 1] ++
          (pattern.drop 2).map (nc_locked_liftSym (g := g)) ++ stepV := by
    rw [hs_tgt, hcrshape]
    simp [pattern, nc_locked_mark, List.append_assoc]
  have hsplit :
      (pattern.drop 1).map (nc_locked_liftSym (g := g)) =
        [nc_locked_liftSym (pattern.getD 1 dflt)] ++
          (pattern.drop 2).map (nc_locked_liftSym (g := g)) := by
    rw [List.drop_eq_getElem_cons]
    · rw [List.getD_eq_getElem]
      · simp
      · simpa [pattern] using hpat
    · simpa [pattern] using hpat
  have hnot_u_zero : nc_locked_mark (g := g) ri 0 ∉ u := by
    intro hmem
    exact ((hu (nc_locked_mark (g := g) ri 0) hmem).1 ri 0 rfl).elim
  let rest :=
    [nc_locked_liftSym (pattern.getD 1 dflt)] ++
      (pattern.drop 2).map (nc_locked_liftSym (g := g)) ++ v
  have hnot_rest_zero : nc_locked_mark (g := g) ri 0 ∉ rest := by
    intro hmem
    have hnot_head :
        nc_locked_mark (g := g) ri 0 ≠
          nc_locked_liftSym (pattern.getD 1 dflt) := by
      intro h
      exact ((nc_locked_liftSym_clean g (pattern.getD 1 dflt)
        (nc_locked_mark (g := g) ri 0) (by simp [h])).1 ri 0 rfl).elim
    have hnot_drop :
        nc_locked_mark (g := g) ri 0 ∉
          (pattern.drop 2).map (nc_locked_liftSym (g := g)) := by
      intro hdrop
      exact (((nc_locked_map_liftSym_clean g (pattern.drop 2))
        (nc_locked_mark (g := g) ri 0) hdrop).1 ri 0 rfl).elim
    have hnot_drop_tail :
        nc_locked_mark (g := g) ri 0 ∉
          (pattern.map (nc_locked_liftSym (g := g))).drop 2 := by
      simpa [List.map_drop] using hnot_drop
    have hnot_v : nc_locked_mark (g := g) ri 0 ∉ v := by
      intro hv_mem
      exact ((hv (nc_locked_mark (g := g) ri 0) hv_mem).1 ri 0 rfl).elim
    simp [rest, List.mem_append] at hmem
    rcases hmem with hmem | hmem | hmem
    · exact hnot_head hmem
    · exact hnot_drop_tail hmem
    · exact hnot_v hmem
  have heq :
      u ++ [nc_locked_mark (g := g) ri 0] ++ rest =
        stepU ++ [nc_locked_mark (g := g) ri 0] ++
          ([nc_locked_liftSym (pattern.getD 1 dflt)] ++
            (pattern.drop 2).map (nc_locked_liftSym (g := g)) ++ stepV) := by
    rw [hsplit] at hs_src'
    simpa [rest, List.append_assoc] using hs_src'
  have hmark_not_stepU : nc_locked_mark (g := g) ri 0 ∉ stepU :=
    list_prefix_not_mem_of_unique_singleton_decomp hnot_u_zero hnot_rest_zero heq
  obtain ⟨hu_eq, hrest_eq⟩ :=
    list_append_singleton_eq_of_not_mem hnot_u_zero hmark_not_stepU heq
  have hv_eq : v = stepV := by
    have hrest_eq' :
        ([nc_locked_liftSym (pattern.getD 1 dflt)] ++
            (pattern.drop 2).map (nc_locked_liftSym (g := g))) ++ v =
          ([nc_locked_liftSym (pattern.getD 1 dflt)] ++
            (pattern.drop 2).map (nc_locked_liftSym (g := g))) ++ stepV := by
      simpa [rest, List.append_assoc] using hrest_eq
    exact List.append_cancel_left hrest_eq'
  refine ⟨hpat, ?_⟩
  simpa [pattern, hu_eq, hv_eq, List.append_assoc, List.map_drop, List.map_append] using hs_tgt'

lemma nc_locked_mark_not_mem_prior_range (g : grammar T) (ri n : ℕ) :
    nc_locked_mark (g := g) ri n ∉ (List.range n).map (nc_locked_mark ri) := by
  intro hmem
  simp [List.mem_map] at hmem
  obtain ⟨k, hk, heq⟩ := hmem
  have hkn : k = n := by
    simpa [nc_locked_mark] using heq
  omega

lemma nc_locked_mark_range_succ (g : grammar T) (ri k : ℕ) :
    (List.range (k + 1)).map (nc_locked_mark (g := g) ri) =
      (List.range k).map (nc_locked_mark (g := g) ri) ++
        [nc_locked_mark (g := g) ri k] := by
  simp [List.range_succ, List.map_append]

/-- Exact source and target shape for an arbitrary next marking step of a locked
simulation.  If phases `0..k` have already been marked and the next step creates
phase `k+1`, then the selected rule is forced to replace exactly the next lifted
input symbol, with the surrounding context unchanged. -/
lemma nc_locked_transform_added_next_mark_exact
    (g : grammar T) (hg : grammar_noncontracting g)
    {ri : ℕ} {r : grule T g.nt} {k : ℕ}
    {u v smid : List (symbol T (NC_LockedNT g))}
    (hpair : (ri, r) ∈ (List.range g.rules.length).zip g.rules)
    (hu : nc_locked_is_clean g u) (hv : nc_locked_is_clean g v)
    (hstep : CS_transforms (locked_csg_of_noncontracting g hg)
      ((u ++ (List.range (k + 1)).map (nc_locked_mark (g := g) ri) ++
        (((r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R).drop (k + 1)).map
          (nc_locked_liftSym (g := g))) ++ v) :
          List (symbol T (NC_LockedNT g)))
      smid)
    (hnext : nc_locked_mark (g := g) ri (k + 1) ∈ smid) :
    (let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R;
    k + 1 < pattern.length ∧
      smid =
        u ++ (List.range (k + 1)).map (nc_locked_mark (g := g) ri) ++
          [nc_locked_mark (g := g) ri (k + 1)] ++
          (pattern.drop (k + 2)).map (nc_locked_liftSym (g := g)) ++ v) := by
  let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
  let dflt : symbol T g.nt := symbol.nonterminal r.input_N
  let pref : List (symbol T (NC_LockedNT g)) :=
    (List.range (k + 1)).map (nc_locked_mark (g := g) ri)
  let prefBefore : List (symbol T (NC_LockedNT g)) :=
    (List.range k).map (nc_locked_mark (g := g) ri)
  have hnot_u_next : nc_locked_mark (g := g) ri (k + 1) ∉ u := by
    intro hmem
    exact ((hu (nc_locked_mark (g := g) ri (k + 1)) hmem).1 ri (k + 1) rfl).elim
  have hnot_v_next : nc_locked_mark (g := g) ri (k + 1) ∉ v := by
    intro hmem
    exact ((hv (nc_locked_mark (g := g) ri (k + 1)) hmem).1 ri (k + 1) rfl).elim
  have hnot_prefix_next :
      nc_locked_mark (g := g) ri (k + 1) ∉ pref := by
    dsimp [pref]
    exact nc_locked_mark_not_mem_prior_range g ri (k + 1)
  have hnot_drop_next :
      nc_locked_mark (g := g) ri (k + 1) ∉
        (pattern.drop (k + 1)).map (nc_locked_liftSym (g := g)) := by
    intro hmem
    exact (((nc_locked_map_liftSym_clean g (pattern.drop (k + 1)))
      (nc_locked_mark (g := g) ri (k + 1)) hmem).1 ri (k + 1) rfl).elim
  have hnot_drop_next_tail :
      nc_locked_mark (g := g) ri (k + 1) ∉
        (pattern.map (nc_locked_liftSym (g := g))).drop (k + 1) := by
    simpa [List.map_drop] using hnot_drop_next
  have hsrc_next :
      nc_locked_mark (g := g) ri (k + 1) ∉
        (u ++ pref ++
          (pattern.drop (k + 1)).map (nc_locked_liftSym (g := g)) ++ v) := by
    intro hmem
    simp [List.mem_append] at hmem
    rcases hmem with hmem | hmem | hmem | hmem
    · exact hnot_u_next hmem
    · exact hnot_prefix_next hmem
    · exact hnot_drop_next_tail hmem
    · exact hnot_v_next hmem
  obtain ⟨cr, stepU, stepV, hcr, hs_src, hs_tgt⟩ := hstep
  change csrule T (NC_LockedNT g) at cr
  change List (symbol T (NC_LockedNT g)) at stepU
  change List (symbol T (NC_LockedNT g)) at stepV
  have hout : nc_locked_mark (g := g) ri (k + 1) ∈ cr.output_string := by
    rw [hs_tgt] at hnext
    rw [hs_src] at hsrc_next
    simp [List.mem_append] at hnext hsrc_next
    rcases hnext with hnext | hnext | hnext | hnext | hnext
    · exact (hsrc_next.1 hnext).elim
    · exact (hsrc_next.2.1 hnext).elim
    · exact hnext
    · exact (hsrc_next.2.2.2.1 hnext).elim
    · exact (hsrc_next.2.2.2.2 hnext).elim
  obtain ⟨simRi, grule, hpair', hri, hshape⟩ :=
    nc_locked_rule_output_mark_shape g hg hcr hout
  subst simRi
  have hgrule : grule = r := nc_rule_zip_rule_unique g hpair' hpair
  subst grule
  dsimp only at hshape
  obtain ⟨hpat, hcrshape⟩ := hshape
  have hs_src' :
      u ++ pref ++
          (pattern.drop (k + 1)).map (nc_locked_liftSym (g := g)) ++ v =
        stepU ++ pref ++
          [nc_locked_liftSym (pattern.getD (k + 1) dflt)] ++
          (pattern.drop (k + 2)).map (nc_locked_liftSym (g := g)) ++ stepV := by
    rw [hs_src, hcrshape]
    simp [pattern, dflt, pref, nc_locked_mark, nc_locked_liftSym, List.append_assoc]
  have hs_tgt' :
      smid =
        stepU ++ pref ++
          [nc_locked_mark (g := g) ri (k + 1)] ++
          (pattern.drop (k + 2)).map (nc_locked_liftSym (g := g)) ++ stepV := by
    rw [hs_tgt, hcrshape]
  have hsplit :
      (pattern.drop (k + 1)).map (nc_locked_liftSym (g := g)) =
        [nc_locked_liftSym (pattern.getD (k + 1) dflt)] ++
          (pattern.drop (k + 2)).map (nc_locked_liftSym (g := g)) := by
    rw [List.drop_eq_getElem_cons]
    · rw [List.getD_eq_getElem]
      · simp
      · simpa [pattern] using hpat
    · simpa [pattern] using hpat
  have hprefix_succ : pref = prefBefore ++ [nc_locked_mark (g := g) ri k] := by
    dsimp [pref, prefBefore]
    exact nc_locked_mark_range_succ g ri k
  have hnot_u_sep : nc_locked_mark (g := g) ri k ∉ u := by
    intro hmem
    exact ((hu (nc_locked_mark (g := g) ri k) hmem).1 ri k rfl).elim
  have hnot_prefix_before_sep :
      nc_locked_mark (g := g) ri k ∉ prefBefore := by
    dsimp [prefBefore]
    exact nc_locked_mark_not_mem_prior_range g ri k
  have hnot_left_sep :
      nc_locked_mark (g := g) ri k ∉ u ++ prefBefore := by
    intro hmem
    simp [List.mem_append] at hmem
    cases hmem with
    | inl hmem => exact hnot_u_sep hmem
    | inr hmem => exact hnot_prefix_before_sep hmem
  let rest : List (symbol T (NC_LockedNT g)) :=
    [nc_locked_liftSym (pattern.getD (k + 1) dflt)] ++
      (pattern.drop (k + 2)).map (nc_locked_liftSym (g := g)) ++ v
  have hnot_rest_sep : nc_locked_mark (g := g) ri k ∉ rest := by
    intro hmem
    have hnot_head :
        nc_locked_mark (g := g) ri k ≠
          nc_locked_liftSym (pattern.getD (k + 1) dflt) := by
      intro h
      exact ((nc_locked_liftSym_clean g (pattern.getD (k + 1) dflt)
        (nc_locked_mark (g := g) ri k) (by simp [h])).1 ri k rfl).elim
    have hnot_drop :
        nc_locked_mark (g := g) ri k ∉
          (pattern.drop (k + 2)).map (nc_locked_liftSym (g := g)) := by
      intro hdrop
      exact (((nc_locked_map_liftSym_clean g (pattern.drop (k + 2)))
        (nc_locked_mark (g := g) ri k) hdrop).1 ri k rfl).elim
    have hnot_drop_tail :
        nc_locked_mark (g := g) ri k ∉
          (pattern.map (nc_locked_liftSym (g := g))).drop (k + 2) := by
      simpa [List.map_drop] using hnot_drop
    have hnot_v : nc_locked_mark (g := g) ri k ∉ v := by
      intro hv_mem
      exact ((hv (nc_locked_mark (g := g) ri k) hv_mem).1 ri k rfl).elim
    simp [rest, List.mem_append] at hmem
    rcases hmem with hmem | hmem | hmem
    · exact hnot_head hmem
    · exact hnot_drop_tail hmem
    · exact hnot_v hmem
  have heq :
      (u ++ prefBefore) ++ [nc_locked_mark (g := g) ri k] ++ rest =
        (stepU ++ prefBefore) ++ [nc_locked_mark (g := g) ri k] ++
          ([nc_locked_liftSym (pattern.getD (k + 1) dflt)] ++
            (pattern.drop (k + 2)).map (nc_locked_liftSym (g := g)) ++ stepV) := by
    rw [hsplit] at hs_src'
    rw [hprefix_succ] at hs_src'
    simpa [rest, List.append_assoc] using hs_src'
  have hmark_not_step_prefix :
      nc_locked_mark (g := g) ri k ∉ stepU ++ prefBefore :=
    list_prefix_not_mem_of_unique_singleton_decomp hnot_left_sep hnot_rest_sep heq
  obtain ⟨hprefix_eq, hrest_eq⟩ :=
    list_append_singleton_eq_of_not_mem hnot_left_sep hmark_not_step_prefix heq
  have hu_eq : u = stepU := by
    exact List.append_cancel_right hprefix_eq
  have hv_eq : v = stepV := by
    have hrest_eq' :
        ([nc_locked_liftSym (pattern.getD (k + 1) dflt)] ++
            (pattern.drop (k + 2)).map (nc_locked_liftSym (g := g))) ++ v =
          ([nc_locked_liftSym (pattern.getD (k + 1) dflt)] ++
            (pattern.drop (k + 2)).map (nc_locked_liftSym (g := g))) ++ stepV := by
      simpa [rest, List.append_assoc] using hrest_eq
    exact List.append_cancel_left hrest_eq'
  refine ⟨hpat, ?_⟩
  simpa [pattern, pref, hu_eq, hv_eq, List.append_assoc] using hs_tgt'

lemma nc_locked_transform_added_mark_preserves_source_mark (g : grammar T)
    (hg : grammar_noncontracting g)
    {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : CS_transforms (locked_csg_of_noncontracting g hg) s₁ s₂)
    {targetRi targetK ri k : ℕ}
    (htgt : nc_locked_mark (g := g) targetRi targetK ∈ s₂)
    (hsrc : nc_locked_mark (g := g) targetRi targetK ∉ s₁)
    (hmark : nc_locked_mark (g := g) ri k ∈ s₁) :
    nc_locked_mark (g := g) ri k ∈ s₂ := by
  obtain ⟨cr, u, v, hcr, hs₁, hs₂⟩ := h
  have hout : nc_locked_mark (g := g) targetRi targetK ∈ cr.output_string := by
    rw [hs₁] at hsrc
    rw [hs₂] at htgt
    simp [List.mem_append] at hsrc htgt
    rcases htgt with htgt | htgt | htgt | htgt | htgt
    · exact (hsrc.1 htgt).elim
    · exact (hsrc.2.1 htgt).elim
    · exact htgt
    · exact (hsrc.2.2.2.1 htgt).elim
    · exact (hsrc.2.2.2.2 htgt).elim
  obtain ⟨simRi, grule, _hpair, _hri, hshape⟩ :=
    nc_locked_rule_output_mark_shape g hg hcr hout
  dsimp only at hshape
  obtain ⟨_hk, hcrshape⟩ := hshape
  let pattern := grule.input_L ++ [symbol.nonterminal grule.input_N] ++
    grule.input_R
  let dflt : symbol T g.nt := symbol.nonterminal grule.input_N
  rw [hs₁] at hmark
  rw [hs₂]
  rw [hcrshape] at hmark ⊢
  simp [List.mem_append] at hmark ⊢
  rcases hmark with hmark | hmark | hmark | hmark | hmark
  · simp [hmark]
  · simp [hmark]
  · have hclean := nc_locked_liftSym_clean g (pattern.getD targetK dflt)
    exact ((hclean (nc_locked_mark (g := g) ri k) (by simpa [pattern, dflt] using hmark)).1
      ri k rfl).elim
  · have hclean := nc_locked_map_liftSym_clean g (pattern.drop (targetK + 1))
