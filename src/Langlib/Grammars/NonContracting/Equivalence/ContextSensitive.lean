            (nc_locked_liftSym (g := g))) ++ v) :
          List (symbol T (NC_LockedNT g)))
        smid := by
    simpa [hshape.2, List.append_assoc] using hstep
  exact nc_locked_transform_added_base_one_mark_exact g hg hpair hu hv hstep' hone

