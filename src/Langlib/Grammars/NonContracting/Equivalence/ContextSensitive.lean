  have hv : nc_locked_is_clean g v := by
    refine nc_locked_is_clean_of_subset g hclean ?_
    intro x hx
    rw [hs₁]
    simp [List.mem_append, hx]
  refine ⟨simRi, grule, u, v, hpair, hu, hv, ?_, ?_, ?_⟩
  · dsimp only
    exact ⟨hs₁, hs₂⟩
  · intro ri k
    constructor
