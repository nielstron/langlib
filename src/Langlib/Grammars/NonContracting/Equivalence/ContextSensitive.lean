      rcases hmem with hmem | hmem | hmem | hmem
      · exact ((hu (nc_locked_mark (g := g) ri k) hmem).1 ri k rfl).elim
      · simpa [nc_locked_mark] using hmem
      · have hmem' : nc_locked_mark (g := g) ri k ∈
            (pattern.drop 1).map nc_locked_liftSym := by
          simpa [pattern] using hmem
        exact ((nc_locked_map_liftSym_clean g (pattern.drop 1)
          (nc_locked_mark (g := g) ri k) hmem').1 ri k rfl).elim
      · exact ((hv (nc_locked_mark (g := g) ri k) hmem).1 ri k rfl).elim
