  obtain ⟨simRi, grule, markIdx, hpair, hri, hk, ha, hmark⟩ :=
    nc_locked_transform_added_out_source_mark g hg hintro hout_spost hnot_spre
  exact ⟨pre, rest, spre, spost, simRi, grule, markIdx, hn, hpre, hintro, hrest,
    hpair, hri, hk, ha, hmark⟩

