/-- Counted locked derivations whose every boundary state is dirty. -/
inductive NC_locked_dirty_derives_n (g : grammar T)
    (hg : grammar_noncontracting g) :
    ℕ → List (symbol T (NC_LockedNT g)) →
      List (symbol T (NC_LockedNT g)) → Prop
  | zero {s} :
      ¬ nc_locked_is_clean g s →
      NC_locked_dirty_derives_n g hg 0 s s
  | step {n s₁ s₂ s₃} :
      CS_transforms (locked_csg_of_noncontracting g hg) s₁ s₂ →
      ¬ nc_locked_is_clean g s₁ →
      ¬ nc_locked_is_clean g s₂ →
      NC_locked_dirty_derives_n g hg n s₂ s₃ →
      NC_locked_dirty_derives_n g hg (n + 1) s₁ s₃

lemma nc_locked_dirty_derives_n_to_derives_n (g : grammar T)
    (hg : grammar_noncontracting g)
    {n : ℕ} {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : NC_locked_dirty_derives_n g hg n s₁ s₂) :
    NC_locked_derives_n g hg n s₁ s₂ := by
  induction h with
  | zero _ =>
      exact NC_locked_derives_n.zero _
  | step hstep _ _ _ ih =>
      exact NC_locked_derives_n.step hstep ih

lemma nc_locked_dirty_derives_n_end_dirty (g : grammar T)
    (hg : grammar_noncontracting g)
    {n : ℕ} {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : NC_locked_dirty_derives_n g hg n s₁ s₂) :
    ¬ nc_locked_is_clean g s₂ := by
  induction h with
  | zero hdirty =>
      exact hdirty
  | step _ _ _ _ ih =>
      exact ih

lemma nc_locked_dirty_return_mark_event (g : grammar T)
    (hg : grammar_noncontracting g)
    {m : ℕ} {s_after s_dirty s_clean : List (symbol T (NC_LockedNT g))}
    (hdirty : NC_locked_dirty_derives_n g hg m s_after s_dirty)
    (hreturn : CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean)
    (hclean : nc_locked_is_clean g s_clean)
    {ri k : ℕ}
    (hmark : nc_locked_mark (g := g) ri k ∈ s_after) :
    ∃ pre rest smid simRi grule j,
      m + 1 = pre + rest ∧
        NC_locked_derives_n g hg pre s_after smid ∧
        NC_locked_derives_n g hg rest smid s_clean ∧
        (simRi, grule) ∈ (List.range g.rules.length).zip g.rules ∧
        ri = simRi ∧ j < grule.output_string.length ∧
        nc_locked_out (g := g) simRi j
          (grule.output_string.getD j (symbol.nonterminal grule.input_N)) ∈ smid := by
  have hderive : NC_locked_derives_n g hg (m + 1) s_after s_clean :=
    nc_locked_derives_n_append g hg
      (nc_locked_dirty_derives_n_to_derives_n g hg hdirty) hreturn
  exact nc_locked_derives_n_to_clean_mark_event g hg hderive hclean hmark

lemma nc_locked_dirty_return_mark_step_event (g : grammar T)
    (hg : grammar_noncontracting g)
    {m : ℕ} {s_after s_dirty s_clean : List (symbol T (NC_LockedNT g))}
    (hdirty : NC_locked_dirty_derives_n g hg m s_after s_dirty)
    (hreturn : CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean)
    (hclean : nc_locked_is_clean g s_clean)
    {ri k : ℕ}
    (hmark : nc_locked_mark (g := g) ri k ∈ s_after) :
    ∃ pre rest spre spost simRi grule j,
      m + 1 = pre + 1 + rest ∧
        NC_locked_derives_n g hg pre s_after spre ∧
        CS_transforms (locked_csg_of_noncontracting g hg) spre spost ∧
        NC_locked_derives_n g hg rest spost s_clean ∧
        (simRi, grule) ∈ (List.range g.rules.length).zip g.rules ∧
        ri = simRi ∧ j < grule.output_string.length ∧
        nc_locked_mark (g := g) ri k ∈ spre ∧
        nc_locked_mark (g := g) ri k ∉ spost ∧
        nc_locked_out (g := g) simRi j
          (grule.output_string.getD j (symbol.nonterminal grule.input_N)) ∈ spost := by
  have hderive : NC_locked_derives_n g hg (m + 1) s_after s_clean :=
    nc_locked_derives_n_append g hg
      (nc_locked_dirty_derives_n_to_derives_n g hg hdirty) hreturn
  exact nc_locked_derives_n_removed_mark_step_event g hg hderive hmark
    (fun htgt => (hclean (nc_locked_mark (g := g) ri k) htgt).1 ri k rfl)

lemma nc_locked_dirty_return_out_event (g : grammar T)
    (hg : grammar_noncontracting g)
    {m : ℕ} {s_after s_dirty s_clean : List (symbol T (NC_LockedNT g))}
    (hdirty : NC_locked_dirty_derives_n g hg m s_after s_dirty)
    (hreturn : CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean)
    (hclean : nc_locked_is_clean g s_clean)
    {ri k : ℕ} {a : symbol T g.nt}
    (hout : nc_locked_out (g := g) ri k a ∈ s_after) :
    ∃ pre rest smid simRi grule,
      m + 1 = pre + rest ∧
        NC_locked_derives_n g hg pre s_after smid ∧
        NC_locked_derives_n g hg rest smid s_clean ∧
        (simRi, grule) ∈ (List.range g.rules.length).zip g.rules ∧
        ri = simRi ∧ k < grule.output_string.length ∧
        a = grule.output_string.getD k (symbol.nonterminal grule.input_N) ∧
        nc_locked_liftSym a ∈ smid := by
  have hderive : NC_locked_derives_n g hg (m + 1) s_after s_clean :=
    nc_locked_derives_n_append g hg
      (nc_locked_dirty_derives_n_to_derives_n g hg hdirty) hreturn
  exact nc_locked_derives_n_to_clean_out_event g hg hderive hclean hout

/-- The initial marker introduced by a clean-to-dirty step must eventually produce
an output marker for the same indexed original rule before the interval can return
to a clean form. -/
lemma nc_locked_dirty_interval_start_rule_output_event (g : grammar T)
    (hg : grammar_noncontracting g)
    {m : ℕ} {s_start s_after s_dirty s_clean :
      List (symbol T (NC_LockedNT g))}
    (hstart : CS_transforms (locked_csg_of_noncontracting g hg) s_start s_after)
    (hclean_start : nc_locked_is_clean g s_start)
    (hdirty_after : ¬ nc_locked_is_clean g s_after)
    (hmid : NC_locked_dirty_derives_n g hg m s_after s_dirty)
    (hreturn : CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean)
    (hclean : nc_locked_is_clean g s_clean) :
    ∃ ri r u v pre rest smid j,
      (ri, r) ∈ (List.range g.rules.length).zip g.rules ∧
        (let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
         let dflt : symbol T g.nt := symbol.nonterminal r.input_N
         s_start = u ++ [nc_locked_liftSym (pattern.getD 0 dflt)] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v ∧
           s_after = u ++ [nc_locked_mark (g := g) ri 0] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v) ∧
        m + 1 = pre + rest ∧
        NC_locked_derives_n g hg pre s_after smid ∧
        NC_locked_derives_n g hg rest smid s_clean ∧
        j < r.output_string.length ∧
        nc_locked_out (g := g) ri j
          (r.output_string.getD j (symbol.nonterminal r.input_N)) ∈ smid := by
  obtain ⟨ri, r, u, v, hpair, _hu, _hv, hshape, hmarks, _houts⟩ :=
    nc_locked_clean_step_dirty_mark_zero_unique g hg hstart hclean_start hdirty_after
  have hmark : nc_locked_mark (g := g) ri 0 ∈ s_after := by
    exact (hmarks ri 0).2 rfl
  obtain ⟨pre, rest, smid, simRi, grule, j, hn, hpre, hrest, hpair', hri, hj, hout⟩ :=
    nc_locked_dirty_return_mark_event g hg hmid hreturn hclean hmark
  subst simRi
  have hgrule : grule = r := nc_rule_zip_rule_unique g hpair' hpair
  subst grule
  exact ⟨ri, r, u, v, pre, rest, smid, j, hpair, hshape, hn, hpre, hrest, hj, hout⟩

/-- In a dirty interval that starts from a clean form, the unique output marker
cleaned by the final dirty-to-clean step must have been introduced during the
dirty part of the interval. -/
lemma nc_locked_dirty_interval_final_cleanup_added_out_event (g : grammar T)
    (hg : grammar_noncontracting g)
    {m : ℕ} {s_start s_after s_dirty s_clean :
      List (symbol T (NC_LockedNT g))}
    (hstart : CS_transforms (locked_csg_of_noncontracting g hg) s_start s_after)
    (hclean_start : nc_locked_is_clean g s_start)
    (hdirty_after : ¬ nc_locked_is_clean g s_after)
    (hmid : NC_locked_dirty_derives_n g hg m s_after s_dirty)
    (hdirty : ¬ nc_locked_is_clean g s_dirty)
    (hreturn : CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean)
    (hclean : nc_locked_is_clean g s_clean) :
    ∃ ri r k u v pre rest smid,
      (ri, r) ∈ (List.range g.rules.length).zip g.rules ∧
        k < r.output_string.length ∧
        (let dflt : symbol T g.nt := symbol.nonterminal r.input_N
         s_dirty =
           u ++ [nc_locked_out (g := g) ri k (r.output_string.getD k dflt)] ++ v ∧
           s_clean = u ++ [nc_locked_liftSym (r.output_string.getD k dflt)] ++ v) ∧
        m = pre + rest ∧
        NC_locked_derives_n g hg pre s_after smid ∧
        NC_locked_derives_n g hg rest smid s_dirty ∧
        nc_locked_out (g := g) ri k
          (r.output_string.getD k (symbol.nonterminal r.input_N)) ∈ smid := by
  obtain ⟨_startRi, _startRule, _su, _sv, _hpair_start, _hu_start, _hv_start,
      _hshape_start, _hmarks_after, houts_after⟩ :=
    nc_locked_clean_step_dirty_mark_zero_unique g hg hstart hclean_start hdirty_after
  obtain ⟨ri, r, k, u, v, hpair, hk, _hu, _hv, hshape, _hmarks_dirty,
      houts_dirty⟩ :=
    nc_locked_dirty_step_clean_cleanup_unique g hg hreturn hdirty hclean
  let dflt : symbol T g.nt := symbol.nonterminal r.input_N
  have hout_dirty :
      nc_locked_out (g := g) ri k (r.output_string.getD k dflt) ∈ s_dirty := by
    exact (houts_dirty ri k (r.output_string.getD k dflt)).2 ⟨rfl, rfl, rfl⟩
  have hout_after :
      nc_locked_out (g := g) ri k (r.output_string.getD k dflt) ∉ s_after :=
    houts_after ri k (r.output_string.getD k dflt)
  obtain ⟨pre, rest, smid, simRi, grule, hm, hpre, hrest, hpair', hri, hk',
      ha, hout_smid⟩ :=
    nc_locked_derives_n_added_out_event g hg
      (nc_locked_dirty_derives_n_to_derives_n g hg hmid) hout_after hout_dirty
  subst simRi
  have hgrule : grule = r := nc_rule_zip_rule_unique g hpair' hpair
  subst grule
  refine ⟨ri, r, k, u, v, pre, rest, smid, hpair, hk, ?_, hm, hpre, hrest, ?_⟩
  · exact hshape
  · simpa [dflt] using hout_smid

/-- A step-split form of
`nc_locked_dirty_interval_final_cleanup_added_out_event`: the output marker cleaned
by the final return-to-clean step has a concrete introduction step inside the
dirty interval. -/
lemma nc_locked_dirty_interval_final_cleanup_added_out_step_event
    (g : grammar T) (hg : grammar_noncontracting g)
    {m : ℕ} {s_start s_after s_dirty s_clean :
      List (symbol T (NC_LockedNT g))}
    (hstart : CS_transforms (locked_csg_of_noncontracting g hg) s_start s_after)
    (hclean_start : nc_locked_is_clean g s_start)
    (hdirty_after : ¬ nc_locked_is_clean g s_after)
    (hmid : NC_locked_dirty_derives_n g hg m s_after s_dirty)
    (hdirty : ¬ nc_locked_is_clean g s_dirty)
    (hreturn : CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean)
    (hclean : nc_locked_is_clean g s_clean) :
    ∃ ri r k u v pre rest spre spost,
      (ri, r) ∈ (List.range g.rules.length).zip g.rules ∧
        k < r.output_string.length ∧
        (let dflt : symbol T g.nt := symbol.nonterminal r.input_N
         s_dirty =
           u ++ [nc_locked_out (g := g) ri k (r.output_string.getD k dflt)] ++ v ∧
           s_clean = u ++ [nc_locked_liftSym (r.output_string.getD k dflt)] ++ v) ∧
        m = pre + 1 + rest ∧
        NC_locked_derives_n g hg pre s_after spre ∧
        CS_transforms (locked_csg_of_noncontracting g hg) spre spost ∧
        NC_locked_derives_n g hg rest spost s_dirty ∧
        nc_locked_out (g := g) ri k
          (r.output_string.getD k (symbol.nonterminal r.input_N)) ∉ spre ∧
        nc_locked_out (g := g) ri k
          (r.output_string.getD k (symbol.nonterminal r.input_N)) ∈ spost := by
  obtain ⟨_startRi, _startRule, _su, _sv, _hpair_start, _hu_start, _hv_start,
      _hshape_start, _hmarks_after, houts_after⟩ :=
    nc_locked_clean_step_dirty_mark_zero_unique g hg hstart hclean_start hdirty_after
  obtain ⟨ri, r, k, u, v, hpair, hk, _hu, _hv, hshape, _hmarks_dirty,
      houts_dirty⟩ :=
    nc_locked_dirty_step_clean_cleanup_unique g hg hreturn hdirty hclean
  let dflt : symbol T g.nt := symbol.nonterminal r.input_N
  have hout_dirty :
      nc_locked_out (g := g) ri k (r.output_string.getD k dflt) ∈ s_dirty := by
    exact (houts_dirty ri k (r.output_string.getD k dflt)).2 ⟨rfl, rfl, rfl⟩
  have hout_after :
      nc_locked_out (g := g) ri k (r.output_string.getD k dflt) ∉ s_after :=
    houts_after ri k (r.output_string.getD k dflt)
  obtain ⟨pre, rest, spre, spost, simRi, grule, hm, hpre, hintro, hrest,
      hpair', hri, hk', ha, hnot_spre, hout_spost⟩ :=
    nc_locked_derives_n_added_out_step_event g hg
      (nc_locked_dirty_derives_n_to_derives_n g hg hmid) hout_after hout_dirty
  subst simRi
  have hgrule : grule = r := nc_rule_zip_rule_unique g hpair' hpair
  subst grule
  refine ⟨ri, r, k, u, v, pre, rest, spre, spost, hpair, hk, ?_,
    hm, hpre, hintro, hrest, ?_, ?_⟩
  · exact hshape
  · simpa [dflt] using hnot_spre
  · simpa [dflt] using hout_spost

/-- Source-mark form of
`nc_locked_dirty_interval_final_cleanup_added_out_step_event`: the output marker
cleaned by the final return-to-clean step is introduced by a step whose source
contains the corresponding locked input marker. -/
lemma nc_locked_dirty_interval_final_cleanup_source_mark_event
    (g : grammar T) (hg : grammar_noncontracting g)
    {m : ℕ} {s_start s_after s_dirty s_clean :
      List (symbol T (NC_LockedNT g))}
    (hstart : CS_transforms (locked_csg_of_noncontracting g hg) s_start s_after)
    (hclean_start : nc_locked_is_clean g s_start)
    (hdirty_after : ¬ nc_locked_is_clean g s_after)
    (hmid : NC_locked_dirty_derives_n g hg m s_after s_dirty)
    (hdirty : ¬ nc_locked_is_clean g s_dirty)
    (hreturn : CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean)
    (hclean : nc_locked_is_clean g s_clean) :
    ∃ ri r k u v pre rest spre spost markIdx,
      (ri, r) ∈ (List.range g.rules.length).zip g.rules ∧
        k < r.output_string.length ∧
        (let dflt : symbol T g.nt := symbol.nonterminal r.input_N
         s_dirty =
           u ++ [nc_locked_out (g := g) ri k (r.output_string.getD k dflt)] ++ v ∧
           s_clean = u ++ [nc_locked_liftSym (r.output_string.getD k dflt)] ++ v) ∧
        m = pre + 1 + rest ∧
        NC_locked_derives_n g hg pre s_after spre ∧
        CS_transforms (locked_csg_of_noncontracting g hg) spre spost ∧
        NC_locked_derives_n g hg rest spost s_dirty ∧
        (let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
         markIdx < pattern.length ∧
           ((pattern.length - 1 ≤ k ∧ markIdx = pattern.length - 1) ∨
             (k < pattern.length - 1 ∧ markIdx = k)) ∧
           nc_locked_mark (g := g) ri markIdx ∈ spre) := by
  obtain ⟨_startRi, _startRule, _su, _sv, _hpair_start, _hu_start, _hv_start,
      _hshape_start, _hmarks_after, houts_after⟩ :=
    nc_locked_clean_step_dirty_mark_zero_unique g hg hstart hclean_start hdirty_after
  obtain ⟨ri, r, k, u, v, hpair, hk, _hu, _hv, hshape, _hmarks_dirty,
      houts_dirty⟩ :=
    nc_locked_dirty_step_clean_cleanup_unique g hg hreturn hdirty hclean
  let dflt : symbol T g.nt := symbol.nonterminal r.input_N
  have hout_dirty :
      nc_locked_out (g := g) ri k (r.output_string.getD k dflt) ∈ s_dirty := by
    exact (houts_dirty ri k (r.output_string.getD k dflt)).2 ⟨rfl, rfl, rfl⟩
  have hout_after :
      nc_locked_out (g := g) ri k (r.output_string.getD k dflt) ∉ s_after :=
    houts_after ri k (r.output_string.getD k dflt)
  obtain ⟨pre, rest, spre, spost, simRi, grule, markIdx, hm, hpre, hintro, hrest,
      hpair', hri, hk', ha, hmark⟩ :=
    nc_locked_derives_n_added_out_step_source_mark_event g hg
      (nc_locked_dirty_derives_n_to_derives_n g hg hmid) hout_after hout_dirty
  subst simRi
  have hgrule : grule = r := nc_rule_zip_rule_unique g hpair' hpair
  subst grule
  refine ⟨ri, r, k, u, v, pre, rest, spre, spost, markIdx, hpair, hk, ?_,
    hm, hpre, hintro, hrest, ?_⟩
  · exact hshape
  · simpa [dflt] using hmark

/-- A dirty interval cannot return to a clean form immediately after its
clean-to-dirty start.  The start state contains a single input marker and no
output marker, while a dirty-to-clean step must clean a unique output marker. -/
lemma nc_locked_dirty_interval_mid_length_pos (g : grammar T)
    (hg : grammar_noncontracting g)
    {m : ℕ} {s_start s_after s_dirty s_clean :
      List (symbol T (NC_LockedNT g))}
    (hstart : CS_transforms (locked_csg_of_noncontracting g hg) s_start s_after)
    (hclean_start : nc_locked_is_clean g s_start)
    (hdirty_after : ¬ nc_locked_is_clean g s_after)
    (hmid : NC_locked_dirty_derives_n g hg m s_after s_dirty)
    (hdirty : ¬ nc_locked_is_clean g s_dirty)
    (hreturn : CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean)
    (hclean : nc_locked_is_clean g s_clean) :
    0 < m := by
  cases hmid with
  | zero _ =>
      obtain ⟨_startRi, _startRule, _su, _sv, _hpair_start, _hu_start, _hv_start,
          _hshape_start, _hmarks_after, houts_after⟩ :=
        nc_locked_clean_step_dirty_mark_zero_unique g hg hstart hclean_start hdirty_after
      obtain ⟨ri, r, k, _u, _v, _hpair, _hk, _hu, _hv, _hshape, _hmarks_dirty,
          houts_dirty⟩ :=
        nc_locked_dirty_step_clean_cleanup_unique g hg hreturn hdirty hclean
      let dflt : symbol T g.nt := symbol.nonterminal r.input_N
      have hout_dirty :
          nc_locked_out (g := g) ri k (r.output_string.getD k dflt) ∈ s_after := by
        exact (houts_dirty ri k (r.output_string.getD k dflt)).2 ⟨rfl, rfl, rfl⟩
      exact (houts_after ri k (r.output_string.getD k dflt) hout_dirty).elim
  | step _ _ _ =>
      omega

lemma nc_locked_dirty_derives_n_step_split_of_pos (g : grammar T)
    (hg : grammar_noncontracting g)
    {m : ℕ} {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (hpos : 0 < m)
    (h : NC_locked_dirty_derives_n g hg m s₁ s₂) :
    ∃ m' smid,
      m = m' + 1 ∧
        CS_transforms (locked_csg_of_noncontracting g hg) s₁ smid ∧
        ¬ nc_locked_is_clean g smid ∧
        NC_locked_dirty_derives_n g hg m' smid s₂ := by
  cases h with
  | zero _ =>
      omega
  | step hstep _ hdirty_mid htail =>
      exact ⟨_, _, rfl, hstep, hdirty_mid, htail⟩

/-- Nondegenerate dirty intervals expose their first dirty-to-dirty step. -/
lemma nc_locked_dirty_interval_first_dirty_step (g : grammar T)
    (hg : grammar_noncontracting g)
    {m : ℕ} {s_start s_after s_dirty s_clean :
      List (symbol T (NC_LockedNT g))}
    (hstart : CS_transforms (locked_csg_of_noncontracting g hg) s_start s_after)
    (hclean_start : nc_locked_is_clean g s_start)
    (hdirty_after : ¬ nc_locked_is_clean g s_after)
    (hmid : NC_locked_dirty_derives_n g hg m s_after s_dirty)
    (hdirty : ¬ nc_locked_is_clean g s_dirty)
    (hreturn : CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean)
    (hclean : nc_locked_is_clean g s_clean) :
    ∃ m' smid,
      m = m' + 1 ∧
        CS_transforms (locked_csg_of_noncontracting g hg) s_after smid ∧
        ¬ nc_locked_is_clean g smid ∧
        NC_locked_dirty_derives_n g hg m' smid s_dirty := by
  exact nc_locked_dirty_derives_n_step_split_of_pos g hg
    (nc_locked_dirty_interval_mid_length_pos g hg hstart hclean_start hdirty_after
      hmid hdirty hreturn hclean)
    hmid

/-- In the first dirty-to-dirty step after a clean start, any newly introduced
marker is either a fresh `0` marker for some simulation, or the `1` marker for
the simulation opened by the clean-to-dirty step. -/
lemma nc_locked_dirty_interval_first_step_added_mark_shape
    (g : grammar T) (hg : grammar_noncontracting g)
    {m : ℕ} {s_start s_after s_dirty s_clean :
      List (symbol T (NC_LockedNT g))}
    (hstart : CS_transforms (locked_csg_of_noncontracting g hg) s_start s_after)
    (hclean_start : nc_locked_is_clean g s_start)
