        (let pattern := grule.input_L ++ [symbol.nonterminal grule.input_N] ++ grule.input_R
         let dflt : symbol T g.nt := symbol.nonterminal grule.input_N
         s₁ = u ++ [nc_locked_liftSym (pattern.getD 0 dflt)] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v ∧
