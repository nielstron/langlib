    rw [hs₂] at hmem
    simp [List.mem_append] at hmem
    rcases hmem with hmem | hmem | hmem | hmem
    · exact ((hu (nc_locked_out (g := g) ri k a) hmem).2 ri k a rfl).elim
    · simp [nc_locked_mark, nc_locked_out] at hmem
    · have hmem' : nc_locked_out (g := g) ri k a ∈
          (pattern.drop 1).map nc_locked_liftSym := by
        simpa [pattern] using hmem
      exact ((nc_locked_map_liftSym_clean g (pattern.drop 1)
        (nc_locked_out (g := g) ri k a) hmem').2 ri k a rfl).elim
    · exact ((hv (nc_locked_out (g := g) ri k a) hmem).2 ri k a rfl).elim

lemma nc_locked_dirty_step_clean_cleanup_unique (g : grammar T)
