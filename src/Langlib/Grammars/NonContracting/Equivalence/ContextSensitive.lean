/-- First-step case split for a dirty interval.  Either the marker opened by the
clean-to-dirty boundary is still present after the first dirty-to-dirty step, or
that first step is the complete consumed-boundary branch summarized above. -/
lemma nc_locked_dirty_interval_first_step_split_summary
    (g : grammar T) (hg : grammar_noncontracting g)
    {m : ℕ} {s_start s_after s_dirty s_clean :
      List (symbol T (NC_LockedNT g))}
    (hstart : CS_transforms (locked_csg_of_noncontracting g hg) s_start s_after)
    (hclean_start : nc_locked_is_clean g s_start)
    (hdirty_after : ¬ nc_locked_is_clean g s_after)
    (hmid : NC_locked_dirty_derives_n g hg m s_after s_dirty)
    (hdirty : ¬ nc_locked_is_clean g s_dirty)
    (hreturn : CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean)
    (hclean : nc_locked_is_clean g s_clean) :
    ∃ ri r u v m' smid,
      (ri, r) ∈ (List.range g.rules.length).zip g.rules ∧
        (let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
         let dflt : symbol T g.nt := symbol.nonterminal r.input_N
         s_start = u ++ [nc_locked_liftSym (pattern.getD 0 dflt)] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v ∧
           s_after = u ++ [nc_locked_mark (g := g) ri 0] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v) ∧
        m = m' + 1 ∧
        CS_transforms (locked_csg_of_noncontracting g hg) s_after smid ∧
        ¬ nc_locked_is_clean g smid ∧
        NC_locked_dirty_derives_n g hg m' smid s_dirty ∧
        (nc_locked_mark (g := g) ri 0 ∈ smid ∨
          (r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R).length = 1 ∧
            (∀ targetRi targetK,
              nc_locked_mark (g := g) targetRi targetK ∉ smid) ∧
            ∃ j, j < r.output_string.length ∧
              nc_locked_out (g := g) ri j
                (r.output_string.getD j (symbol.nonterminal r.input_N)) ∈ smid) := by
  obtain ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
      htail, hsummary⟩ :=
    nc_locked_dirty_interval_first_step_removed_start_mark_summary g hg
      hstart hclean_start hdirty_after hmid hdirty hreturn hclean
  refine ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
    htail, ?_⟩
  by_cases hmark : nc_locked_mark (g := g) ri 0 ∈ smid
  · exact Or.inl hmark
  · exact Or.inr (hsummary hmark)

/-- In the consumed-boundary branch, the first dirty-to-dirty step is the
last-marker emission rule for the opened simulation, specialized to a unit
input pattern.  This records the actual CS rule shape, which is the next piece
needed to turn the branch into a clean macro simulation. -/
lemma nc_locked_dirty_interval_first_step_removed_start_mark_emit_rule
    (g : grammar T) (hg : grammar_noncontracting g)
    {m : ℕ} {s_start s_after s_dirty s_clean :
      List (symbol T (NC_LockedNT g))}
    (hstart : CS_transforms (locked_csg_of_noncontracting g hg) s_start s_after)
    (hclean_start : nc_locked_is_clean g s_start)
    (hdirty_after : ¬ nc_locked_is_clean g s_after)
    (hmid : NC_locked_dirty_derives_n g hg m s_after s_dirty)
    (hdirty : ¬ nc_locked_is_clean g s_dirty)
    (hreturn : CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean)
    (hclean : nc_locked_is_clean g s_clean) :
    ∃ ri r u v m' smid,
      (ri, r) ∈ (List.range g.rules.length).zip g.rules ∧
        (let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
         let dflt : symbol T g.nt := symbol.nonterminal r.input_N
         s_start = u ++ [nc_locked_liftSym (pattern.getD 0 dflt)] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v ∧
           s_after = u ++ [nc_locked_mark (g := g) ri 0] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v) ∧
        m = m' + 1 ∧
        CS_transforms (locked_csg_of_noncontracting g hg) s_after smid ∧
        ¬ nc_locked_is_clean g smid ∧
        NC_locked_dirty_derives_n g hg m' smid s_dirty ∧
        (nc_locked_mark (g := g) ri 0 ∉ smid →
          ∃ cr : csrule T (NC_LockedNT g),
            cr ∈ (locked_csg_of_noncontracting g hg).rules ∧
              cr.context_left = [] ∧
              cr.input_nonterminal = NC_LockedNT.mark ri 0 ∧
              cr.context_right = [] ∧
              cr.output_string =
                nc_locked_outputFrom ri r.output_string
                  (symbol.nonterminal r.input_N) 0) := by
  obtain ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
      htail, hsummary⟩ :=
    nc_locked_dirty_interval_first_step_removed_start_mark_summary g hg
      hstart hclean_start hdirty_after hmid hdirty hreturn hclean
  refine ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
    htail, ?_⟩
  intro hgone
  obtain ⟨hlen, _hno_marks, _hout⟩ := hsummary hgone
  dsimp only at hshape
  have hmark_src : nc_locked_mark (g := g) ri 0 ∈ s_after := by
    rw [hshape.2]
    simp [List.mem_append, nc_locked_mark]
  obtain ⟨simRi, grule, hpair', hri, hremoved⟩ :=
    nc_locked_transform_removed_mark_shape g hg hstep hmark_src hgone
  subst simRi
  have hgrule : grule = r := nc_rule_zip_rule_unique g hpair' hpair
  subst grule
  dsimp only at hremoved
  rcases hremoved with hlast | hrest
  · rcases hlast with ⟨_hk, cr, hcr, hinput, hleft, hright, hout⟩
    have hlast_zero : r.input_L.length + r.input_R.length = 0 := by
      simp [List.length_append] at hlen
      omega
    refine ⟨cr, hcr, ?_, ?_, ?_, ?_⟩
    · simpa [hlast_zero] using hleft
    · simpa [hlast_zero] using hinput
    · simpa using hright
    · simpa [hlast_zero] using hout
  · rcases hrest with ⟨hk, _cr, _hcr, _hinput, _hleft, _hright, _hout⟩
    omega

/-- The consumed-boundary branch can only happen for an original rule whose
contextual input has no left or right side: the whole input pattern is the
distinguished nonterminal. -/
lemma nc_locked_dirty_interval_first_step_removed_start_mark_empty_context
    (g : grammar T) (hg : grammar_noncontracting g)
    {m : ℕ} {s_start s_after s_dirty s_clean :
      List (symbol T (NC_LockedNT g))}
    (hstart : CS_transforms (locked_csg_of_noncontracting g hg) s_start s_after)
    (hclean_start : nc_locked_is_clean g s_start)
    (hdirty_after : ¬ nc_locked_is_clean g s_after)
    (hmid : NC_locked_dirty_derives_n g hg m s_after s_dirty)
    (hdirty : ¬ nc_locked_is_clean g s_dirty)
    (hreturn : CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean)
    (hclean : nc_locked_is_clean g s_clean) :
    ∃ ri r u v m' smid,
      (ri, r) ∈ (List.range g.rules.length).zip g.rules ∧
        (let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
         let dflt : symbol T g.nt := symbol.nonterminal r.input_N
         s_start = u ++ [nc_locked_liftSym (pattern.getD 0 dflt)] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v ∧
           s_after = u ++ [nc_locked_mark (g := g) ri 0] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v) ∧
        m = m' + 1 ∧
        CS_transforms (locked_csg_of_noncontracting g hg) s_after smid ∧
        ¬ nc_locked_is_clean g smid ∧
        NC_locked_dirty_derives_n g hg m' smid s_dirty ∧
        (nc_locked_mark (g := g) ri 0 ∉ smid →
          r.input_L = [] ∧ r.input_R = []) := by
  obtain ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
      htail, hsummary⟩ :=
    nc_locked_dirty_interval_first_step_removed_start_mark_summary g hg
      hstart hclean_start hdirty_after hmid hdirty hreturn hclean
  refine ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
    htail, ?_⟩
  intro hgone
  obtain ⟨hlen, _hno_marks, _hout⟩ := hsummary hgone
  have hsum : r.input_L.length + r.input_R.length = 0 := by
    simp [List.length_append] at hlen
    omega
  have hleft_len : r.input_L.length = 0 := by omega
  have hright_len : r.input_R.length = 0 := by omega
  have hleft_nil : r.input_L = [] := List.length_eq_zero_iff.mp hleft_len
  have hright_nil : r.input_R = [] := List.length_eq_zero_iff.mp hright_len
  exact ⟨hleft_nil, hright_nil⟩

/-- In the consumed-boundary branch, the first dirty-to-dirty step has exactly
the clean macro target for the opened original rule. -/
lemma nc_locked_dirty_interval_first_step_removed_start_mark_endpoint
    (g : grammar T) (hg : grammar_noncontracting g)
    {m : ℕ} {s_start s_after s_dirty s_clean :
      List (symbol T (NC_LockedNT g))}
    (hstart : CS_transforms (locked_csg_of_noncontracting g hg) s_start s_after)
    (hclean_start : nc_locked_is_clean g s_start)
    (hdirty_after : ¬ nc_locked_is_clean g s_after)
    (hmid : NC_locked_dirty_derives_n g hg m s_after s_dirty)
    (hdirty : ¬ nc_locked_is_clean g s_dirty)
    (hreturn : CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean)
    (hclean : nc_locked_is_clean g s_clean) :
    ∃ ri r u v m' smid,
      (ri, r) ∈ (List.range g.rules.length).zip g.rules ∧
        (let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
         let dflt : symbol T g.nt := symbol.nonterminal r.input_N
         s_start = u ++ [nc_locked_liftSym (pattern.getD 0 dflt)] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v ∧
           s_after = u ++ [nc_locked_mark (g := g) ri 0] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v) ∧
        m = m' + 1 ∧
        CS_transforms (locked_csg_of_noncontracting g hg) s_after smid ∧
        ¬ nc_locked_is_clean g smid ∧
        NC_locked_dirty_derives_n g hg m' smid s_dirty ∧
        (nc_locked_mark (g := g) ri 0 ∉ smid →
          smid = u ++
            nc_locked_outputFrom ri r.output_string
              (symbol.nonterminal r.input_N) 0 ++ v) := by
  obtain ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
      htail, hsummary⟩ :=
    nc_locked_dirty_interval_first_step_removed_start_mark_summary g hg
      hstart hclean_start hdirty_after hmid hdirty hreturn hclean
  refine ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
    htail, ?_⟩
  intro hgone
  obtain ⟨hlen, _hno_marks, _hout⟩ := hsummary hgone
  have hsum : r.input_L.length + r.input_R.length = 0 := by
    simp [List.length_append] at hlen
    omega
  have hleft : r.input_L = [] := by
    exact List.length_eq_zero_iff.mp (by omega)
  have hright : r.input_R = [] := by
    exact List.length_eq_zero_iff.mp (by omega)
  dsimp only at hshape
  have hs_after_start : s_after = u ++ [nc_locked_mark (g := g) ri 0] ++ v := by
    rw [hshape.2, hleft, hright]
    simp
  have hu_clean : nc_locked_is_clean g u := by
    refine nc_locked_is_clean_of_subset g hclean_start ?_
    intro x hx
    rw [hshape.1]
    simp [List.mem_append, hx]
  have hmark_not_u : nc_locked_mark (g := g) ri 0 ∉ u := by
    intro hmem
    exact ((hu_clean (nc_locked_mark (g := g) ri 0) hmem).1 ri 0 rfl).elim
  have hmark_src : nc_locked_mark (g := g) ri 0 ∈ s_after := by
    rw [hs_after_start]
    simp [List.mem_append, nc_locked_mark]
  obtain ⟨cr, stepU, stepV, hcr, hs_src, hs_tgt, hinput⟩ :=
    CS_transform_removed_symbol_actual_input hstep hmark_src hgone
  change csrule T (NC_LockedNT g) at cr
  change List (symbol T (NC_LockedNT g)) at stepU
  change List (symbol T (NC_LockedNT g)) at stepV
  have hinput_cr : cr.input_nonterminal = NC_LockedNT.mark ri 0 := by
    simpa [nc_locked_mark] using hinput.symm
  obtain ⟨simRi, grule, hpair', hri, hremoved⟩ :=
    nc_locked_rule_input_mark_shape g hg hcr hinput_cr
  subst simRi
  have hgrule : grule = r := nc_rule_zip_rule_unique g hpair' hpair
  subst grule
  dsimp only at hremoved
  rcases hremoved with hlast | hrest
  · rcases hlast with ⟨_hk, hcrshape⟩
    have hcrshape' :
        cr =
          { context_left := [],
            input_nonterminal := NC_LockedNT.mark ri 0,
            context_right := [],
            output_string :=
              nc_locked_outputFrom ri r.output_string
                (symbol.nonterminal r.input_N) 0 } := by
      simpa [List.length_append, hsum] using hcrshape
    have hs_src' : s_after = stepU ++ [nc_locked_mark (g := g) ri 0] ++ stepV := by
      rw [hs_src, hcrshape']
      simp [nc_locked_mark]
    have hs_tgt' :
        smid = stepU ++
          nc_locked_outputFrom ri r.output_string
            (symbol.nonterminal r.input_N) 0 ++ stepV := by
      rw [hs_tgt, hcrshape']
      simp
    have hmark_not_stepU : nc_locked_mark (g := g) ri 0 ∉ stepU := by
      intro hmem
      apply hgone
      rw [hs_tgt']
      simp [List.mem_append, hmem]
    have heq : u ++ [nc_locked_mark (g := g) ri 0] ++ v =
        stepU ++ [nc_locked_mark (g := g) ri 0] ++ stepV := by
      rw [← hs_after_start, hs_src']
    obtain ⟨hu_eq, hv_eq⟩ :=
      list_append_singleton_eq_of_not_mem hmark_not_u hmark_not_stepU heq
    rw [hs_tgt', ← hu_eq, ← hv_eq]
  · rcases hrest with ⟨hk, _hcrshape⟩
    have hpattern_len :
        (r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R).length = 1 := by
      simpa using hlen
    omega

lemma nc_locked_dirty_trace_first_clean_step (g : grammar T)
    (hg : grammar_noncontracting g)
    {n : ℕ} {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : NC_locked_derives_n g hg n s₁ s₂)
    (hdirty₁ : ¬ nc_locked_is_clean g s₁) (hclean₂ : nc_locked_is_clean g s₂) :
    ∃ m s_dirty s_clean,
      NC_locked_derives_n g hg m s₁ s_dirty ∧
        ¬ nc_locked_is_clean g s_dirty ∧
        CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean ∧
        nc_locked_is_clean g s_clean := by
  induction h with
  | zero s =>
      exact (hdirty₁ hclean₂).elim
  | step hstep htail ih =>
      rename_i n s₁ smid s₂
      by_cases hclean_mid : nc_locked_is_clean g smid
      · exact ⟨0, s₁, smid, NC_locked_derives_n.zero s₁,
          hdirty₁, hstep, hclean_mid⟩
      · obtain ⟨m, s_dirty, s_clean, hprefix, hdirty, hcleanStep, hclean⟩ :=
          ih hclean_mid hclean₂
        exact ⟨m + 1, s_dirty, s_clean,
          NC_locked_derives_n.step hstep hprefix, hdirty, hcleanStep, hclean⟩

lemma nc_locked_dirty_trace_first_clean_step_split (g : grammar T)
    (hg : grammar_noncontracting g)
    {n : ℕ} {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : NC_locked_derives_n g hg n s₁ s₂)
    (hdirty₁ : ¬ nc_locked_is_clean g s₁) (hclean₂ : nc_locked_is_clean g s₂) :
    ∃ m rest s_dirty s_clean,
      n = m + 1 + rest ∧
        NC_locked_derives_n g hg m s₁ s_dirty ∧
        ¬ nc_locked_is_clean g s_dirty ∧
        CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean ∧
        nc_locked_is_clean g s_clean ∧
        NC_locked_derives_n g hg rest s_clean s₂ := by
  induction h with
  | zero s =>
      exact (hdirty₁ hclean₂).elim
  | step hstep htail ih =>
      rename_i n s₁ smid s₂
      by_cases hclean_mid : nc_locked_is_clean g smid
      · exact ⟨0, n, s₁, smid, by omega,
          NC_locked_derives_n.zero s₁, hdirty₁, hstep, hclean_mid, htail⟩
      · obtain ⟨m, rest, s_dirty, s_clean, hn, hprefix, hdirty, hreturn,
          hs_clean, hrest⟩ := ih hclean_mid hclean₂
        refine ⟨m + 1, rest, s_dirty, s_clean, ?_,
          NC_locked_derives_n.step hstep hprefix, hdirty, hreturn, hs_clean, hrest⟩
        omega

lemma nc_locked_dirty_trace_first_clean_step_dirty_split (g : grammar T)
    (hg : grammar_noncontracting g)
    {n : ℕ} {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : NC_locked_derives_n g hg n s₁ s₂)
    (hdirty₁ : ¬ nc_locked_is_clean g s₁) (hclean₂ : nc_locked_is_clean g s₂) :
    ∃ m rest s_dirty s_clean,
      n = m + 1 + rest ∧
        NC_locked_dirty_derives_n g hg m s₁ s_dirty ∧
        CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean ∧
        nc_locked_is_clean g s_clean ∧
        NC_locked_derives_n g hg rest s_clean s₂ := by
  induction h with
  | zero s =>
      exact (hdirty₁ hclean₂).elim
  | step hstep htail ih =>
      rename_i n s₁ smid s₂
      by_cases hclean_mid : nc_locked_is_clean g smid
      · exact ⟨0, n, s₁, smid, by omega,
          NC_locked_dirty_derives_n.zero hdirty₁, hstep, hclean_mid, htail⟩
      · obtain ⟨m, rest, s_dirty, s_clean, hn, hprefix, hreturn,
          hs_clean, hrest⟩ := ih hclean_mid hclean₂
        refine ⟨m + 1, rest, s_dirty, s_clean, ?_,
          NC_locked_dirty_derives_n.step hstep hdirty₁ hclean_mid hprefix,
          hreturn, hs_clean, hrest⟩
        · omega

/-! ### Locked clean reverse traces -/

/-- Clean macro steps in the locked construction.  The `sim` constructor is the
macro endpoint for one complete locked simulation of an original
non-contracting rule under arbitrary surrounding context. -/
inductive NC_locked_clean_macro_step (g : grammar T)
    (hg : grammar_noncontracting g) :
    List (symbol T (NC_LockedNT g)) →
      List (symbol T (NC_LockedNT g)) → Prop
  | clean {s₁ s₂} :
      CS_transforms (locked_csg_of_noncontracting g hg) s₁ s₂ →
      nc_locked_is_clean g s₁ →
      nc_locked_is_clean g s₂ →
      NC_locked_clean_macro_step g hg s₁ s₂
  | sim {ri : ℕ} {r : grule T g.nt}
      {u v : List (symbol T (NC_LockedNT g))} :
      (ri, r) ∈ (List.range g.rules.length).zip g.rules →
      NC_locked_clean_macro_step g hg
        (u ++ (r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R).map
          nc_locked_liftSym ++ v)
        (u ++ r.output_string.map nc_locked_liftSym ++ v)

/-- Every locked clean macro step projects to an unrestricted derivation in the
original grammar. -/
lemma nc_locked_clean_macro_step_grammar_derives (g : grammar T)
    (hg : grammar_noncontracting g)
    {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : NC_locked_clean_macro_step g hg s₁ s₂) :
    grammar_derives g (nc_locked_proj g s₁) (nc_locked_proj g s₂) := by
  cases h with
  | clean hstep hclean₁ hclean₂ =>
      exact nc_locked_clean_step_grammar_derives g hg hstep hclean₁ hclean₂
  | sim hpair =>
      rename_i ri r u v
      apply grammar_deri_of_tran
      refine ⟨r, (List.of_mem_zip hpair).2, nc_locked_proj g u, nc_locked_proj g v,
        ?_, ?_⟩
      · simp [nc_locked_proj, List.map_append, Function.comp_def,
          nc_locked_proj_liftSym]
      · simp [nc_locked_proj, List.map_append, Function.comp_def,
          nc_locked_proj_liftSym]

/-- Step-counted traces of locked clean macro steps. -/
inductive NC_locked_clean_macro_derives_n (g : grammar T)
    (hg : grammar_noncontracting g) :
    ℕ → List (symbol T (NC_LockedNT g)) →
      List (symbol T (NC_LockedNT g)) → Prop
  | zero {s} :
      nc_locked_is_clean g s →
      NC_locked_clean_macro_derives_n g hg 0 s s
  | step {n s₁ s₂ s₃} :
      NC_locked_clean_macro_step g hg s₁ s₂ →
      NC_locked_clean_macro_derives_n g hg n s₂ s₃ →
      NC_locked_clean_macro_derives_n g hg (n + 1) s₁ s₃

/-- Locked clean macro traces project to unrestricted derivations in the
original grammar. -/
lemma nc_locked_clean_macro_trace_grammar_derives (g : grammar T)
    (hg : grammar_noncontracting g)
    {n : ℕ} {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : NC_locked_clean_macro_derives_n g hg n s₁ s₂) :
    grammar_derives g (nc_locked_proj g s₁) (nc_locked_proj g s₂) := by
  induction h with
  | zero _ =>
      exact grammar_deri_self
  | step hstep _ ih =>
      exact grammar_deri_of_deri_deri
        (nc_locked_clean_macro_step_grammar_derives g hg hstep)
        ih

lemma nc_locked_clean_macro_derives_n_append (g : grammar T)
    (hg : grammar_noncontracting g)
    {n : ℕ} {s₁ s₂ s₃ : List (symbol T (NC_LockedNT g))}
    (h : NC_locked_clean_macro_derives_n g hg n s₁ s₂)
    (hstep : NC_locked_clean_macro_step g hg s₂ s₃)
    (hclean₃ : nc_locked_is_clean g s₃) :
    NC_locked_clean_macro_derives_n g hg (n + 1) s₁ s₃ := by
  induction h generalizing s₃ with
  | zero _ =>
      exact NC_locked_clean_macro_derives_n.step hstep
        (NC_locked_clean_macro_derives_n.zero hclean₃)
  | step hfirst _ ih =>
      exact NC_locked_clean_macro_derives_n.step hfirst (ih hstep hclean₃)

lemma nc_locked_clean_macro_derives_n_trans (g : grammar T)
    (hg : grammar_noncontracting g)
    {m n : ℕ} {s₁ s₂ s₃ : List (symbol T (NC_LockedNT g))}
    (h₁ : NC_locked_clean_macro_derives_n g hg m s₁ s₂)
    (h₂ : NC_locked_clean_macro_derives_n g hg n s₂ s₃) :
    NC_locked_clean_macro_derives_n g hg (m + n) s₁ s₃ := by
  induction h₁ with
  | zero _ =>
      simpa using h₂
  | step hstep _ ih =>
      convert NC_locked_clean_macro_derives_n.step hstep (ih h₂) using 1
      omega

lemma nc_locked_clean_macro_derives_n_cons (g : grammar T)
    (hg : grammar_noncontracting g)
    {n : ℕ} {s₁ s₂ s₃ : List (symbol T (NC_LockedNT g))}
    (hstep : NC_locked_clean_macro_step g hg s₁ s₂)
    (htail : NC_locked_clean_macro_derives_n g hg n s₂ s₃) :
    NC_locked_clean_macro_derives_n g hg (n + 1) s₁ s₃ := by
  exact NC_locked_clean_macro_derives_n.step hstep htail

/-- A finite locked CS derivation trace whose adjacent endpoints are all clean. -/
inductive NC_locked_clean_derives_n (g : grammar T)
    (hg : grammar_noncontracting g) :
    ℕ → List (symbol T (NC_LockedNT g)) →
      List (symbol T (NC_LockedNT g)) → Prop
  | zero {s} :
      nc_locked_is_clean g s →
      NC_locked_clean_derives_n g hg 0 s s
  | step {n s₁ s₂ s₃} :
      CS_transforms (locked_csg_of_noncontracting g hg) s₁ s₂ →
      nc_locked_is_clean g s₁ →
      nc_locked_is_clean g s₂ →
      NC_locked_clean_derives_n g hg n s₂ s₃ →
      NC_locked_clean_derives_n g hg (n + 1) s₁ s₃

lemma nc_locked_clean_trace_or_first_dirty_segment (g : grammar T)
    (hg : grammar_noncontracting g)
    {n : ℕ} {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : NC_locked_derives_n g hg n s₁ s₂)
    (hclean₁ : nc_locked_is_clean g s₁) (hclean₂ : nc_locked_is_clean g s₂) :
    NC_locked_clean_derives_n g hg n s₁ s₂ ∨
      ∃ (pre m rest : ℕ)
          (s_start s_after s_dirty s_clean : List (symbol T (NC_LockedNT g))),
        n = pre + 1 + m + 1 + rest ∧
          NC_locked_clean_derives_n g hg pre s₁ s_start ∧
          nc_locked_is_clean g s_start ∧
          CS_transforms (locked_csg_of_noncontracting g hg) s_start s_after ∧
          ¬ nc_locked_is_clean g s_after ∧
          NC_locked_derives_n g hg m s_after s_dirty ∧
          ¬ nc_locked_is_clean g s_dirty ∧
          CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean ∧
          nc_locked_is_clean g s_clean ∧
          NC_locked_derives_n g hg rest s_clean s₂ := by
  induction h with
  | zero s =>
      exact Or.inl (NC_locked_clean_derives_n.zero hclean₁)
  | step hstep htail ih =>
      rename_i n s₁ smid s₂
      by_cases hclean_mid : nc_locked_is_clean g smid
      · cases ih hclean_mid hclean₂ with
        | inl hclean_tail =>
            exact Or.inl
              (NC_locked_clean_derives_n.step hstep hclean₁ hclean_mid hclean_tail)
        | inr hseg =>
            rcases hseg with
              ⟨pre, m, rest, s_start, s_after, s_dirty, s_clean, hn,
                hpre, hs_start, hstart, hs_after, hmid, hs_dirty, hreturn,
                hs_clean, hrest⟩
            refine Or.inr
              ⟨pre + 1, m, rest, s_start, s_after, s_dirty, s_clean,
                ?_, ?_, hs_start, hstart, hs_after, hmid, hs_dirty, hreturn,
                hs_clean, hrest⟩
            · omega
            · exact NC_locked_clean_derives_n.step hstep hclean₁ hclean_mid hpre
      · obtain ⟨m, rest, s_dirty, s_clean, hn, hprefix, hs_dirty, hreturn,
          hs_clean, hrest⟩ :=
          nc_locked_dirty_trace_first_clean_step_split g hg htail hclean_mid hclean₂
        refine Or.inr
          ⟨0, m, rest, s₁, smid, s_dirty, s_clean, ?_,
            NC_locked_clean_derives_n.zero hclean₁, hclean₁, hstep, hclean_mid,
            hprefix, hs_dirty, hreturn, hs_clean, hrest⟩
        · omega

lemma nc_locked_clean_trace_or_first_dirty_segment_dirty (g : grammar T)
    (hg : grammar_noncontracting g)
    {n : ℕ} {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : NC_locked_derives_n g hg n s₁ s₂)
    (hclean₁ : nc_locked_is_clean g s₁) (hclean₂ : nc_locked_is_clean g s₂) :
    NC_locked_clean_derives_n g hg n s₁ s₂ ∨
      ∃ (pre m rest : ℕ)
          (s_start s_after s_dirty s_clean : List (symbol T (NC_LockedNT g))),
        n = pre + 1 + m + 1 + rest ∧
          NC_locked_clean_derives_n g hg pre s₁ s_start ∧
          nc_locked_is_clean g s_start ∧
          CS_transforms (locked_csg_of_noncontracting g hg) s_start s_after ∧
          ¬ nc_locked_is_clean g s_after ∧
          NC_locked_dirty_derives_n g hg m s_after s_dirty ∧
          ¬ nc_locked_is_clean g s_dirty ∧
          CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean ∧
          nc_locked_is_clean g s_clean ∧
          NC_locked_derives_n g hg rest s_clean s₂ := by
  induction h with
  | zero s =>
      exact Or.inl (NC_locked_clean_derives_n.zero hclean₁)
  | step hstep htail ih =>
      rename_i n s₁ smid s₂
      by_cases hclean_mid : nc_locked_is_clean g smid
      · cases ih hclean_mid hclean₂ with
        | inl hclean_tail =>
            exact Or.inl
              (NC_locked_clean_derives_n.step hstep hclean₁ hclean_mid hclean_tail)
        | inr hseg =>
            rcases hseg with
              ⟨pre, m, rest, s_start, s_after, s_dirty, s_clean, hn,
                hpre, hs_start, hstart, hs_after, hmid, hs_dirty, hreturn,
                hs_clean, hrest⟩
            refine Or.inr
              ⟨pre + 1, m, rest, s_start, s_after, s_dirty, s_clean,
                ?_, ?_, hs_start, hstart, hs_after, hmid, hs_dirty, hreturn,
                hs_clean, hrest⟩
            · omega
            · exact NC_locked_clean_derives_n.step hstep hclean₁ hclean_mid hpre
      · obtain ⟨m, rest, s_dirty, s_clean, hn, hprefix, hreturn,
          hs_clean, hrest⟩ :=
          nc_locked_dirty_trace_first_clean_step_dirty_split g hg htail hclean_mid hclean₂
        refine Or.inr
          ⟨0, m, rest, s₁, smid, s_dirty, s_clean, ?_,
            NC_locked_clean_derives_n.zero hclean₁, hclean₁, hstep, hclean_mid,
            hprefix, ?_, hreturn, hs_clean, hrest⟩
        · omega
        · exact nc_locked_dirty_derives_n_end_dirty g hg hprefix

lemma nc_locked_clean_trace_or_first_dirty_segment_shapes (g : grammar T)
    (hg : grammar_noncontracting g)
    {n : ℕ} {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : NC_locked_derives_n g hg n s₁ s₂)
    (hclean₁ : nc_locked_is_clean g s₁) (hclean₂ : nc_locked_is_clean g s₂) :
    NC_locked_clean_derives_n g hg n s₁ s₂ ∨
      ∃ (pre m rest : ℕ)
          (s_start s_after s_dirty s_clean : List (symbol T (NC_LockedNT g))),
        n = pre + 1 + m + 1 + rest ∧
          NC_locked_clean_derives_n g hg pre s₁ s_start ∧
          nc_locked_is_clean g s_start ∧
          CS_transforms (locked_csg_of_noncontracting g hg) s_start s_after ∧
          ¬ nc_locked_is_clean g s_after ∧
          NC_locked_derives_n g hg m s_after s_dirty ∧
          ¬ nc_locked_is_clean g s_dirty ∧
          CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean ∧
          nc_locked_is_clean g s_clean ∧
          NC_locked_derives_n g hg rest s_clean s₂ ∧
          (∃ simRi grule u v,
            (simRi, grule) ∈ (List.range g.rules.length).zip g.rules ∧
              nc_locked_is_clean g u ∧ nc_locked_is_clean g v ∧
              (let pattern := grule.input_L ++ [symbol.nonterminal grule.input_N] ++
                    grule.input_R
               let dflt : symbol T g.nt := symbol.nonterminal grule.input_N
               s_start = u ++ [nc_locked_liftSym (pattern.getD 0 dflt)] ++
                   (pattern.drop 1).map nc_locked_liftSym ++ v ∧
                 s_after = u ++ [nc_locked_mark (g := g) simRi 0] ++
                   (pattern.drop 1).map nc_locked_liftSym ++ v) ∧
              (∀ ri k, nc_locked_mark (g := g) ri k ∈ s_after ↔
                (ri, k) = (simRi, 0)) ∧
              (∀ ri k a, nc_locked_out (g := g) ri k a ∉ s_after)) ∧
          (∃ simRi grule k u v,
            (simRi, grule) ∈ (List.range g.rules.length).zip g.rules ∧
              k < grule.output_string.length ∧
              nc_locked_is_clean g u ∧ nc_locked_is_clean g v ∧
              (let dflt : symbol T g.nt := symbol.nonterminal grule.input_N
               s_dirty =
                 u ++
                   [nc_locked_out (g := g) simRi k (grule.output_string.getD k dflt)] ++
                   v ∧
                 s_clean = u ++ [nc_locked_liftSym (grule.output_string.getD k dflt)] ++ v) ∧
              (∀ ri j, nc_locked_mark (g := g) ri j ∉ s_dirty) ∧
              (∀ ri j a, nc_locked_out (g := g) ri j a ∈ s_dirty ↔
                (ri = simRi ∧ j = k ∧
                  a = grule.output_string.getD k (symbol.nonterminal grule.input_N)))) := by
  cases nc_locked_clean_trace_or_first_dirty_segment g hg h hclean₁ hclean₂ with
  | inl hclean =>
      exact Or.inl hclean
  | inr hseg =>
      rcases hseg with
        ⟨pre, m, rest, s_start, s_after, s_dirty, s_clean, hn, hpre,
          hs_start, hstart, hs_after, hmid, hs_dirty, hreturn, hs_clean, hrest⟩
      exact Or.inr
        ⟨pre, m, rest, s_start, s_after, s_dirty, s_clean, hn, hpre,
          hs_start, hstart, hs_after, hmid, hs_dirty, hreturn, hs_clean, hrest,
          nc_locked_clean_step_dirty_mark_zero_unique g hg hstart hs_start hs_after,
          nc_locked_dirty_step_clean_cleanup_unique g hg hreturn hs_dirty hs_clean⟩

lemma nc_locked_clean_trace_or_first_dirty_segment_dirty_shapes (g : grammar T)
    (hg : grammar_noncontracting g)
    {n : ℕ} {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : NC_locked_derives_n g hg n s₁ s₂)
    (hclean₁ : nc_locked_is_clean g s₁) (hclean₂ : nc_locked_is_clean g s₂) :
    NC_locked_clean_derives_n g hg n s₁ s₂ ∨
      ∃ (pre m rest : ℕ)
          (s_start s_after s_dirty s_clean : List (symbol T (NC_LockedNT g))),
        n = pre + 1 + m + 1 + rest ∧
          NC_locked_clean_derives_n g hg pre s₁ s_start ∧
          nc_locked_is_clean g s_start ∧
          CS_transforms (locked_csg_of_noncontracting g hg) s_start s_after ∧
          ¬ nc_locked_is_clean g s_after ∧
          NC_locked_dirty_derives_n g hg m s_after s_dirty ∧
          ¬ nc_locked_is_clean g s_dirty ∧
          CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean ∧
          nc_locked_is_clean g s_clean ∧
          NC_locked_derives_n g hg rest s_clean s₂ ∧
          (∃ simRi grule u v,
            (simRi, grule) ∈ (List.range g.rules.length).zip g.rules ∧
              nc_locked_is_clean g u ∧ nc_locked_is_clean g v ∧
              (let pattern := grule.input_L ++ [symbol.nonterminal grule.input_N] ++
                    grule.input_R
               let dflt : symbol T g.nt := symbol.nonterminal grule.input_N
               s_start = u ++ [nc_locked_liftSym (pattern.getD 0 dflt)] ++
                   (pattern.drop 1).map nc_locked_liftSym ++ v ∧
                 s_after = u ++ [nc_locked_mark (g := g) simRi 0] ++
                   (pattern.drop 1).map nc_locked_liftSym ++ v) ∧
              (∀ ri k, nc_locked_mark (g := g) ri k ∈ s_after ↔
                (ri, k) = (simRi, 0)) ∧
              (∀ ri k a, nc_locked_out (g := g) ri k a ∉ s_after)) ∧
          (∃ simRi grule k u v,
            (simRi, grule) ∈ (List.range g.rules.length).zip g.rules ∧
              k < grule.output_string.length ∧
              nc_locked_is_clean g u ∧ nc_locked_is_clean g v ∧
              (let dflt : symbol T g.nt := symbol.nonterminal grule.input_N
               s_dirty =
                 u ++
                   [nc_locked_out (g := g) simRi k (grule.output_string.getD k dflt)] ++
                   v ∧
                 s_clean = u ++ [nc_locked_liftSym (grule.output_string.getD k dflt)] ++ v) ∧
              (∀ ri j, nc_locked_mark (g := g) ri j ∉ s_dirty) ∧
              (∀ ri j a, nc_locked_out (g := g) ri j a ∈ s_dirty ↔
                (ri = simRi ∧ j = k ∧
                  a = grule.output_string.getD k (symbol.nonterminal grule.input_N)))) := by
  cases nc_locked_clean_trace_or_first_dirty_segment_dirty g hg h hclean₁ hclean₂ with
  | inl hclean =>
      exact Or.inl hclean
  | inr hseg =>
      rcases hseg with
        ⟨pre, m, rest, s_start, s_after, s_dirty, s_clean, hn, hpre,
          hs_start, hstart, hs_after, hmid, hs_dirty, hreturn, hs_clean, hrest⟩
      exact Or.inr
        ⟨pre, m, rest, s_start, s_after, s_dirty, s_clean, hn, hpre,
          hs_start, hstart, hs_after, hmid, hs_dirty, hreturn, hs_clean, hrest,
          nc_locked_clean_step_dirty_mark_zero_unique g hg hstart hs_start hs_after,
          nc_locked_dirty_step_clean_cleanup_unique g hg hreturn hs_dirty hs_clean⟩

/-- Ordinary locked clean traces are a special case of locked clean macro traces. -/
lemma nc_locked_clean_trace_to_macro_trace (g : grammar T)
    (hg : grammar_noncontracting g)
    {n : ℕ} {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : NC_locked_clean_derives_n g hg n s₁ s₂) :
    NC_locked_clean_macro_derives_n g hg n s₁ s₂ := by
  induction h with
  | zero hclean =>
      exact NC_locked_clean_macro_derives_n.zero hclean
  | step hstep hclean₁ hclean₂ _ ih =>
      exact NC_locked_clean_macro_derives_n.step
        (NC_locked_clean_macro_step.clean hstep hclean₁ hclean₂)
        ih

/-- Locked clean-only traces project to unrestricted derivations in the original
grammar. -/
lemma nc_locked_clean_trace_grammar_derives (g : grammar T)
    (hg : grammar_noncontracting g)
    {n : ℕ} {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : NC_locked_clean_derives_n g hg n s₁ s₂) :
    grammar_derives g (nc_locked_proj g s₁) (nc_locked_proj g s₂) :=
  nc_locked_clean_macro_trace_grammar_derives g hg
    (nc_locked_clean_trace_to_macro_trace g hg h)

/-- The remaining local grouping property for the locked construction: any
dirty interval bracketed by one clean-to-dirty step and one dirty-to-clean step
compresses to some clean macro trace. -/
def NC_locked_dirty_interval_macro_property
    (g : grammar T) (hg : grammar_noncontracting g) : Prop :=
  ∀ {m : ℕ} {s_start s_after s_dirty s_clean :
      List (symbol T (NC_LockedNT g))},
    CS_transforms (locked_csg_of_noncontracting g hg) s_start s_after →
    nc_locked_is_clean g s_start →
    ¬ nc_locked_is_clean g s_after →
    NC_locked_dirty_derives_n g hg m s_after s_dirty →
    ¬ nc_locked_is_clean g s_dirty →
    CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean →
    nc_locked_is_clean g s_clean →
    ∃ k, NC_locked_clean_macro_derives_n g hg k s_start s_clean

/-- Abstract compression principle for locked traces.  Once every dirty interval
between clean endpoints can be replaced by a clean macro trace, every clean-to-clean
locked derivation can be compressed to a clean macro trace. -/
lemma nc_locked_clean_endpoints_to_macro_trace_of_dirty_interval_macro
    (g : grammar T) (hg : grammar_noncontracting g)
    {n : ℕ} {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : NC_locked_derives_n g hg n s₁ s₂)
    (hclean₁ : nc_locked_is_clean g s₁)
    (hclean₂ : nc_locked_is_clean g s₂)
    (hgroup : NC_locked_dirty_interval_macro_property g hg) :
    ∃ k, NC_locked_clean_macro_derives_n g hg k s₁ s₂ := by
  revert s₁ s₂
  induction n using Nat.strong_induction_on with
  | h n ih =>
      intro s₁ s₂ h hclean₁ hclean₂
      cases nc_locked_clean_trace_or_first_dirty_segment_dirty g hg h hclean₁ hclean₂ with
      | inl hclean =>
          exact ⟨n, nc_locked_clean_trace_to_macro_trace g hg hclean⟩
      | inr hseg =>
          rcases hseg with
            ⟨pre, m, rest, s_start, s_after, s_dirty, s_clean, hn, hpre,
              hs_start, hstart, hs_after, hmid, hs_dirty, hreturn, hs_clean,
              hrest⟩
          obtain ⟨kseg, hsegmacro⟩ :=
            hgroup hstart hs_start hs_after hmid hs_dirty hreturn hs_clean
          have hrest_lt : rest < n := by omega
          obtain ⟨krest, hrestmacro⟩ :=
            ih rest hrest_lt hrest hs_clean hclean₂
          let hpremacro := nc_locked_clean_trace_to_macro_trace g hg hpre
          refine ⟨(pre + kseg) + krest, ?_⟩
          exact nc_locked_clean_macro_derives_n_trans g hg
            (nc_locked_clean_macro_derives_n_trans g hg hpremacro hsegmacro)
            hrestmacro

/-- Reverse language inclusion for the locked construction, assuming the local
dirty-interval grouping property. -/
lemma CS_language_subset_locked_csg_of_noncontracting_of_dirty_interval_macro
    (g : grammar T) (hg : grammar_noncontracting g)
    (hgroup : NC_locked_dirty_interval_macro_property g hg) :
    ∀ w, w ∈ CS_language (locked_csg_of_noncontracting g hg) →
      w ∈ grammar_language g := by
  intro w hw
  obtain ⟨n, hn⟩ := nc_locked_derives_to_derives_n g hg hw
  obtain ⟨k, hmacro⟩ :=
    nc_locked_clean_endpoints_to_macro_trace_of_dirty_interval_macro g hg hn
      (nc_locked_initial_clean g) (nc_locked_terminal_clean g w) hgroup
  have hproj := nc_locked_clean_macro_trace_grammar_derives g hg hmacro
  have hproj' :
      grammar_derives g [symbol.nonterminal g.initial] (w.map symbol.terminal) := by
    simpa [locked_csg_of_noncontracting, nc_locked_proj_initial,
      nc_locked_proj_terminal] using hproj
  simpa [grammar_language, grammar_generates] using hproj'

/-- Language equality for the locked construction, reduced to the local
dirty-interval grouping property. -/
lemma locked_csg_of_noncontracting_language_eq_of_dirty_interval_macro
    (g : grammar T) (hg : grammar_noncontracting g)
    (hgroup : NC_locked_dirty_interval_macro_property g hg) :
    CS_language (locked_csg_of_noncontracting g hg) = grammar_language g := by
  ext w
  constructor
  · exact CS_language_subset_locked_csg_of_noncontracting_of_dirty_interval_macro
      g hg hgroup w
  · exact grammar_language_subset_locked_csg_of_noncontracting g hg w

/-- Class-level reverse inclusion, reduced to the local dirty-interval grouping
property for the locked construction. -/
lemma is_noncontracting_implies_is_CS_of_locked_dirty_interval_macro
    {L : Language T} (hL : is_noncontracting L)
    (hgroup : ∀ (g : grammar T) (hg : grammar_noncontracting g),
      NC_locked_dirty_interval_macro_property g hg) :
    is_CS L := by
  obtain ⟨g, hg, hLg⟩ := hL
  let G := locked_csg_of_noncontracting g hg
  refine ⟨grammar_of_csg G, grammar_of_csg_context_sensitive G, ?_⟩
  rw [← CS_language_eq_grammar_language G]
  exact (locked_csg_of_noncontracting_language_eq_of_dirty_interval_macro
    g hg (hgroup g hg)).trans hLg

lemma nc_locked_proj_sim_source_head_drop (g : grammar T)
    (r : grule T g.nt) (u v : List (symbol T (NC_LockedNT g))) :
    let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
    let dflt : symbol T g.nt := symbol.nonterminal r.input_N
    nc_locked_proj g
      (u ++ [nc_locked_liftSym (pattern.getD 0 dflt)] ++
        (pattern.drop 1).map nc_locked_liftSym ++ v) =
      nc_locked_proj g u ++ pattern ++ nc_locked_proj g v := by
  dsimp only
  cases r.input_L <;>
    simp [nc_locked_proj, List.map_append, Function.comp_def,
      nc_locked_proj_liftSym]

lemma nc_locked_lifted_pattern_eq_head_drop (g : grammar T)
    (r : grule T g.nt) :
    let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
    let dflt : symbol T g.nt := symbol.nonterminal r.input_N
    [nc_locked_liftSym (pattern.getD 0 dflt)] ++
      (pattern.drop 1).map nc_locked_liftSym =
        pattern.map nc_locked_liftSym := by
  dsimp only
  cases r.input_L <;> simp [nc_locked_liftSym]

lemma nc_locked_proj_sim_target (g : grammar T)
    (r : grule T g.nt) (u v : List (symbol T (NC_LockedNT g))) :
    nc_locked_proj g (u ++ r.output_string.map nc_locked_liftSym ++ v) =
      nc_locked_proj g u ++ r.output_string ++ nc_locked_proj g v := by
  simp [nc_locked_proj, List.map_append, Function.comp_def,
    nc_locked_proj_liftSym]

lemma nc_locked_boundary_macro_step_grammar_derives (g : grammar T)
    {ri : ℕ} {r : grule T g.nt}
    {u v s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (hpair : (ri, r) ∈ (List.range g.rules.length).zip g.rules)
    (hs₁ :
      let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
      let dflt : symbol T g.nt := symbol.nonterminal r.input_N
      s₁ = u ++ [nc_locked_liftSym (pattern.getD 0 dflt)] ++
        (pattern.drop 1).map nc_locked_liftSym ++ v)
    (hs₂ : s₂ = u ++ r.output_string.map nc_locked_liftSym ++ v) :
    grammar_derives g (nc_locked_proj g s₁) (nc_locked_proj g s₂) := by
  subst s₁
  subst s₂
  apply grammar_deri_of_tran
  refine ⟨r, (List.of_mem_zip hpair).2, nc_locked_proj g u, nc_locked_proj g v,
    ?_, ?_⟩
  · simpa [List.append_assoc] using nc_locked_proj_sim_source_head_drop g r u v
  · simpa [List.append_assoc] using nc_locked_proj_sim_target g r u v

lemma nc_locked_boundary_macro_step (g : grammar T)
    (hg : grammar_noncontracting g)
    {ri : ℕ} {r : grule T g.nt}
    {u v s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (hpair : (ri, r) ∈ (List.range g.rules.length).zip g.rules)
    (hs₁ :
      let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
      let dflt : symbol T g.nt := symbol.nonterminal r.input_N
      s₁ = u ++ [nc_locked_liftSym (pattern.getD 0 dflt)] ++
        (pattern.drop 1).map nc_locked_liftSym ++ v)
    (hs₂ : s₂ = u ++ r.output_string.map nc_locked_liftSym ++ v) :
    NC_locked_clean_macro_step g hg s₁ s₂ := by
  subst s₁
  subst s₂
  convert
    (NC_locked_clean_macro_step.sim (g := g) (hg := hg) (u := u) (v := v) hpair)
    using 1
  simpa [List.append_assoc] using
    congrArg (fun mid => u ++ mid ++ v) (nc_locked_lifted_pattern_eq_head_drop g r)

/-- The first dirty step out of a clean locked form identifies the complete
original-rule macro step that it begins. -/
lemma nc_locked_clean_step_dirty_begins_macro_step (g : grammar T)
    (hg : grammar_noncontracting g)
    {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (h : CS_transforms (locked_csg_of_noncontracting g hg) s₁ s₂)
    (hclean : nc_locked_is_clean g s₁) (hdirty : ¬ nc_locked_is_clean g s₂) :
    ∃ ri r u v,
      (ri, r) ∈ (List.range g.rules.length).zip g.rules ∧
        (let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
         let dflt : symbol T g.nt := symbol.nonterminal r.input_N
         s₁ = u ++ [nc_locked_liftSym (pattern.getD 0 dflt)] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v ∧
           s₂ = u ++ [nc_locked_mark (g := g) ri 0] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v) ∧
        NC_locked_clean_macro_step g hg s₁ (u ++ r.output_string.map nc_locked_liftSym ++ v) := by
  obtain ⟨ri, r, u, v, hpair, _hu, _hv, hshape, _hmarks, _houts⟩ :=
    nc_locked_clean_step_dirty_mark_zero_unique g hg h hclean hdirty
  refine ⟨ri, r, u, v, hpair, hshape, ?_⟩
  exact nc_locked_boundary_macro_step g hg hpair hshape.1 rfl

/-- The consumed-boundary first-step case has the expected macro endpoint: the
dirty state produced by consuming the boundary marker is the locked output block,
that block cleans to the macro target, and the original clean boundary step
already determines the corresponding clean macro simulation. -/
lemma nc_locked_dirty_interval_consumed_boundary_macro_target
    (g : grammar T) (hg : grammar_noncontracting g)
    {m : ℕ} {s_start s_after s_dirty s_clean :
      List (symbol T (NC_LockedNT g))}
    (hstart : CS_transforms (locked_csg_of_noncontracting g hg) s_start s_after)
    (hclean_start : nc_locked_is_clean g s_start)
    (hdirty_after : ¬ nc_locked_is_clean g s_after)
    (hmid : NC_locked_dirty_derives_n g hg m s_after s_dirty)
    (hdirty : ¬ nc_locked_is_clean g s_dirty)
    (hreturn : CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean)
    (hclean : nc_locked_is_clean g s_clean) :
    ∃ ri r u v m' smid,
      (ri, r) ∈ (List.range g.rules.length).zip g.rules ∧
        (let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
         let dflt : symbol T g.nt := symbol.nonterminal r.input_N
         s_start = u ++ [nc_locked_liftSym (pattern.getD 0 dflt)] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v ∧
           s_after = u ++ [nc_locked_mark (g := g) ri 0] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v) ∧
        m = m' + 1 ∧
        CS_transforms (locked_csg_of_noncontracting g hg) s_after smid ∧
        ¬ nc_locked_is_clean g smid ∧
        NC_locked_dirty_derives_n g hg m' smid s_dirty ∧
        (nc_locked_mark (g := g) ri 0 ∉ smid →
          smid =
              u ++ nc_locked_outputFrom ri r.output_string
                (symbol.nonterminal r.input_N) 0 ++ v ∧
            CS_derives (locked_csg_of_noncontracting g hg) smid
              (u ++ r.output_string.map nc_locked_liftSym ++ v) ∧
            NC_locked_clean_macro_step g hg s_start
              (u ++ r.output_string.map nc_locked_liftSym ++ v)) := by
  obtain ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
      htail, hendpoint⟩ :=
    nc_locked_dirty_interval_first_step_removed_start_mark_endpoint g hg
      hstart hclean_start hdirty_after hmid hdirty hreturn hclean
  refine ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
    htail, ?_⟩
  intro hgone
  have hsmid := hendpoint hgone
  have hcleanup :=
    nc_locked_cleanup_outputFrom_with_context g hg hpair u v
  have hmacro :
      NC_locked_clean_macro_step g hg s_start
        (u ++ r.output_string.map nc_locked_liftSym ++ v) :=
    nc_locked_boundary_macro_step g hg hpair hshape.1 rfl
  refine ⟨hsmid, ?_, hmacro⟩
  simpa [hsmid] using hcleanup

/-- Counted clean-macro pref for the consumed-boundary branch.  This is the
canonical first macro segment that will later be concatenated with whatever
clean behavior remains after all dirty markers have disappeared. -/
lemma nc_locked_dirty_interval_consumed_boundary_macro_prefix
    (g : grammar T) (hg : grammar_noncontracting g)
    {m : ℕ} {s_start s_after s_dirty s_clean :
      List (symbol T (NC_LockedNT g))}
    (hstart : CS_transforms (locked_csg_of_noncontracting g hg) s_start s_after)
    (hclean_start : nc_locked_is_clean g s_start)
    (hdirty_after : ¬ nc_locked_is_clean g s_after)
    (hmid : NC_locked_dirty_derives_n g hg m s_after s_dirty)
    (hdirty : ¬ nc_locked_is_clean g s_dirty)
    (hreturn : CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean)
    (hclean : nc_locked_is_clean g s_clean) :
    ∃ ri r u v m' smid,
      (ri, r) ∈ (List.range g.rules.length).zip g.rules ∧
        (let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
         let dflt : symbol T g.nt := symbol.nonterminal r.input_N
         s_start = u ++ [nc_locked_liftSym (pattern.getD 0 dflt)] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v ∧
           s_after = u ++ [nc_locked_mark (g := g) ri 0] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v) ∧
        m = m' + 1 ∧
        CS_transforms (locked_csg_of_noncontracting g hg) s_after smid ∧
        ¬ nc_locked_is_clean g smid ∧
        NC_locked_dirty_derives_n g hg m' smid s_dirty ∧
        (nc_locked_mark (g := g) ri 0 ∉ smid →
          let target := u ++ r.output_string.map nc_locked_liftSym ++ v
          CS_derives (locked_csg_of_noncontracting g hg) smid target ∧
            nc_locked_is_clean g target ∧
            NC_locked_clean_macro_derives_n g hg 1 s_start target) := by
  obtain ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
      htail, htarget⟩ :=
    nc_locked_dirty_interval_consumed_boundary_macro_target g hg
      hstart hclean_start hdirty_after hmid hdirty hreturn hclean
  refine ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
    htail, ?_⟩
  intro hgone
  obtain ⟨_hsmid, hcleanup, hmacro⟩ := htarget hgone
  have hu : nc_locked_is_clean g u := by
    refine nc_locked_is_clean_of_subset g hclean_start ?_
    intro x hx
    rw [hshape.1]
    simp [List.mem_append, hx]
  have hv : nc_locked_is_clean g v := by
    refine nc_locked_is_clean_of_subset g hclean_start ?_
    intro x hx
    rw [hshape.1]
    simp [List.mem_append, hx]
  have hout_clean : nc_locked_is_clean g (r.output_string.map nc_locked_liftSym) :=
    nc_locked_map_liftSym_clean g r.output_string
  have htarget_clean :
      nc_locked_is_clean g (u ++ r.output_string.map nc_locked_liftSym ++ v) := by
    exact nc_locked_is_clean_append g
      (nc_locked_is_clean_append g hu hout_clean) hv
  refine ⟨hcleanup, htarget_clean, ?_⟩
  exact NC_locked_clean_macro_derives_n.step hmacro
    (NC_locked_clean_macro_derives_n.zero htarget_clean)

/-- First-step dichotomy for dirty intervals, in a form suitable for the final
grouping induction.  After the first dirty-to-dirty step, either the marker
opened by the clean-to-dirty boundary is still present, or that first step has
already completed the boundary simulation and yields a canonical one-step clean
macro pref. -/
lemma nc_locked_dirty_interval_first_step_macro_prefix_or_mark_retained
    (g : grammar T) (hg : grammar_noncontracting g)
    {m : ℕ} {s_start s_after s_dirty s_clean :
      List (symbol T (NC_LockedNT g))}
    (hstart : CS_transforms (locked_csg_of_noncontracting g hg) s_start s_after)
    (hclean_start : nc_locked_is_clean g s_start)
    (hdirty_after : ¬ nc_locked_is_clean g s_after)
    (hmid : NC_locked_dirty_derives_n g hg m s_after s_dirty)
    (hdirty : ¬ nc_locked_is_clean g s_dirty)
    (hreturn : CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean)
    (hclean : nc_locked_is_clean g s_clean) :
    ∃ ri r u v m' smid,
      (ri, r) ∈ (List.range g.rules.length).zip g.rules ∧
        (let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
         let dflt : symbol T g.nt := symbol.nonterminal r.input_N
         s_start = u ++ [nc_locked_liftSym (pattern.getD 0 dflt)] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v ∧
           s_after = u ++ [nc_locked_mark (g := g) ri 0] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v) ∧
        m = m' + 1 ∧
        CS_transforms (locked_csg_of_noncontracting g hg) s_after smid ∧
        ¬ nc_locked_is_clean g smid ∧
        NC_locked_dirty_derives_n g hg m' smid s_dirty ∧
        (nc_locked_mark (g := g) ri 0 ∈ smid ∨
          let target := u ++ r.output_string.map nc_locked_liftSym ++ v
          CS_derives (locked_csg_of_noncontracting g hg) smid target ∧
            nc_locked_is_clean g target ∧
            NC_locked_clean_macro_derives_n g hg 1 s_start target) := by
  obtain ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
      htail, hprefix⟩ :=
    nc_locked_dirty_interval_consumed_boundary_macro_prefix g hg
      hstart hclean_start hdirty_after hmid hdirty hreturn hclean
  refine ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
    htail, ?_⟩
  by_cases hmark : nc_locked_mark (g := g) ri 0 ∈ smid
  · exact Or.inl hmark
  · exact Or.inr (hprefix hmark)

/-- First-step dichotomy with the retained branch expanded to its eventual output
event.  If the marker opened by the clean-to-dirty boundary survives the first
dirty step, then the remaining dirty interval must later emit an output marker
for the same original rule before it can return to a clean form. -/
lemma nc_locked_dirty_interval_first_step_event_or_macro_prefix
    (g : grammar T) (hg : grammar_noncontracting g)
    {m : ℕ} {s_start s_after s_dirty s_clean :
      List (symbol T (NC_LockedNT g))}
    (hstart : CS_transforms (locked_csg_of_noncontracting g hg) s_start s_after)
    (hclean_start : nc_locked_is_clean g s_start)
    (hdirty_after : ¬ nc_locked_is_clean g s_after)
    (hmid : NC_locked_dirty_derives_n g hg m s_after s_dirty)
    (hdirty : ¬ nc_locked_is_clean g s_dirty)
    (hreturn : CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean)
    (hclean : nc_locked_is_clean g s_clean) :
    ∃ ri r u v m' smid,
      (ri, r) ∈ (List.range g.rules.length).zip g.rules ∧
        (let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
         let dflt : symbol T g.nt := symbol.nonterminal r.input_N
         s_start = u ++ [nc_locked_liftSym (pattern.getD 0 dflt)] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v ∧
           s_after = u ++ [nc_locked_mark (g := g) ri 0] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v) ∧
        m = m' + 1 ∧
        CS_transforms (locked_csg_of_noncontracting g hg) s_after smid ∧
        ¬ nc_locked_is_clean g smid ∧
        NC_locked_dirty_derives_n g hg m' smid s_dirty ∧
        ((nc_locked_mark (g := g) ri 0 ∈ smid ∧
            ∃ pre rest sevent j,
              m' + 1 = pre + rest ∧
                NC_locked_derives_n g hg pre smid sevent ∧
                NC_locked_derives_n g hg rest sevent s_clean ∧
                j < r.output_string.length ∧
                nc_locked_out (g := g) ri j
                  (r.output_string.getD j (symbol.nonterminal r.input_N)) ∈ sevent) ∨
          let target := u ++ r.output_string.map nc_locked_liftSym ++ v
          CS_derives (locked_csg_of_noncontracting g hg) smid target ∧
            nc_locked_is_clean g target ∧
            NC_locked_clean_macro_derives_n g hg 1 s_start target) := by
  obtain ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
      htail, hcase⟩ :=
    nc_locked_dirty_interval_first_step_macro_prefix_or_mark_retained g hg
      hstart hclean_start hdirty_after hmid hdirty hreturn hclean
  refine ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
    htail, ?_⟩
  cases hcase with
  | inl hmark =>
      obtain ⟨pre, rest, sevent, simRi, grule, j, hlen, hpre, hrest, hpair',
          hri, hj, hout⟩ :=
        nc_locked_dirty_return_mark_event g hg htail hreturn hclean hmark
      subst simRi
      have hgrule : grule = r := nc_rule_zip_rule_unique g hpair' hpair
      subst grule
      exact Or.inl ⟨hmark, pre, rest, sevent, j, hlen, hpre, hrest, hj, hout⟩
  | inr hmacro =>
      exact Or.inr hmacro

/-- Step-split version of
`nc_locked_dirty_interval_first_step_event_or_macro_prefix`.  In the retained
branch this records the exact later transform that removes the start marker and
emits an output marker for the same original rule. -/
lemma nc_locked_dirty_interval_first_step_emit_step_or_macro_prefix
    (g : grammar T) (hg : grammar_noncontracting g)
    {m : ℕ} {s_start s_after s_dirty s_clean :
      List (symbol T (NC_LockedNT g))}
    (hstart : CS_transforms (locked_csg_of_noncontracting g hg) s_start s_after)
    (hclean_start : nc_locked_is_clean g s_start)
    (hdirty_after : ¬ nc_locked_is_clean g s_after)
    (hmid : NC_locked_dirty_derives_n g hg m s_after s_dirty)
    (hdirty : ¬ nc_locked_is_clean g s_dirty)
    (hreturn : CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean)
    (hclean : nc_locked_is_clean g s_clean) :
    ∃ ri r u v m' smid,
      (ri, r) ∈ (List.range g.rules.length).zip g.rules ∧
        (let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
         let dflt : symbol T g.nt := symbol.nonterminal r.input_N
         s_start = u ++ [nc_locked_liftSym (pattern.getD 0 dflt)] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v ∧
           s_after = u ++ [nc_locked_mark (g := g) ri 0] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v) ∧
        m = m' + 1 ∧
        CS_transforms (locked_csg_of_noncontracting g hg) s_after smid ∧
        ¬ nc_locked_is_clean g smid ∧
        NC_locked_dirty_derives_n g hg m' smid s_dirty ∧
        ((nc_locked_mark (g := g) ri 0 ∈ smid ∧
            ∃ pre rest spre spost j,
              m' + 1 = pre + 1 + rest ∧
                NC_locked_derives_n g hg pre smid spre ∧
                CS_transforms (locked_csg_of_noncontracting g hg) spre spost ∧
                NC_locked_derives_n g hg rest spost s_clean ∧
                j < r.output_string.length ∧
                nc_locked_mark (g := g) ri 0 ∈ spre ∧
                nc_locked_mark (g := g) ri 0 ∉ spost ∧
                nc_locked_out (g := g) ri j
                  (r.output_string.getD j (symbol.nonterminal r.input_N)) ∈ spost) ∨
          let target := u ++ r.output_string.map nc_locked_liftSym ++ v
          CS_derives (locked_csg_of_noncontracting g hg) smid target ∧
            nc_locked_is_clean g target ∧
            NC_locked_clean_macro_derives_n g hg 1 s_start target) := by
  obtain ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
      htail, hcase⟩ :=
    nc_locked_dirty_interval_first_step_macro_prefix_or_mark_retained g hg
      hstart hclean_start hdirty_after hmid hdirty hreturn hclean
  refine ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
    htail, ?_⟩
  cases hcase with
  | inl hmark =>
      obtain ⟨pre, rest, spre, spost, simRi, grule, j, hlen, hpre, hremove,
          hsuf, hpair', hri, hj, hmark_spre, hmark_spost, hout⟩ :=
        nc_locked_dirty_return_mark_step_event g hg htail hreturn hclean hmark
      subst simRi
      have hgrule : grule = r := nc_rule_zip_rule_unique g hpair' hpair
      subst grule
      exact Or.inl
        ⟨hmark, pre, rest, spre, spost, j, hlen, hpre, hremove, hsuf, hj,
          hmark_spre, hmark_spost, hout⟩
  | inr hmacro =>
      exact Or.inr hmacro

/-- If a step removes the phase-`0` marker for a fixed original rule, then it is
one of exactly two emit steps.  For a unit input pattern it is the `emitLast`
rule and exposes the whole marked output block; otherwise it is the `emitRest`
rule at index `0` and requires the already-emitted output suffix as right
context. -/
lemma nc_locked_removed_zero_mark_step_shape
    (g : grammar T) (hg : grammar_noncontracting g)
    {ri : ℕ} {r : grule T g.nt}
    {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (hpair : (ri, r) ∈ (List.range g.rules.length).zip g.rules)
    (h : CS_transforms (locked_csg_of_noncontracting g hg) s₁ s₂)
    (hsrc : nc_locked_mark (g := g) ri 0 ∈ s₁)
    (htgt : nc_locked_mark (g := g) ri 0 ∉ s₂) :
    let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
    let dflt : symbol T g.nt := symbol.nonterminal r.input_N
    (pattern.length = 1 ∧
      ∃ u v,
        s₁ = u ++ [nc_locked_mark (g := g) ri 0] ++ v ∧
        s₂ =
          u ++ nc_locked_outputFrom ri r.output_string dflt 0 ++ v) ∨
    (1 < pattern.length ∧
      ∃ u v,
        s₁ =
          u ++ [nc_locked_mark (g := g) ri 0] ++
            nc_locked_outputSuffix ri r.output_string dflt 1 ++ v ∧
        s₂ =
          u ++
            [nc_locked_out (g := g) ri 0
              (r.output_string.getD 0 dflt)] ++
            nc_locked_outputSuffix ri r.output_string dflt 1 ++ v) := by
  obtain ⟨cr, u, v, hcr, hs₁, hs₂, hinput⟩ :=
    CS_transform_removed_symbol_actual_input h hsrc htgt
  have hinput' : cr.input_nonterminal = NC_LockedNT.mark ri 0 := by
    simpa [nc_locked_mark] using hinput.symm
  obtain ⟨simRi, grule, hpair', hri, hshape⟩ :=
    nc_locked_rule_input_mark_shape g hg hcr hinput'
  subst simRi
  have hgrule : grule = r := nc_rule_zip_rule_unique g hpair' hpair
  subst grule
  let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
  let dflt : symbol T g.nt := symbol.nonterminal r.input_N
  dsimp only at hshape ⊢
  cases hshape with
  | inl hlast =>
      rcases hlast with ⟨hk, hcrshape⟩
      have hk' : 0 = pattern.length - 1 := by
        simpa [pattern] using hk
      have hpat_pos : 0 < pattern.length := by
        simp [pattern, List.length_append]
      have hpat_len : pattern.length = 1 := by omega
      have hctx_len_zero : r.input_L.length + r.input_R.length = 0 := by
        have hlen :
            pattern.length = r.input_L.length + r.input_R.length + 1 := by
          simp [pattern, List.length_append, Nat.add_assoc]
        omega
      rw [hcrshape] at hs₁ hs₂
      refine Or.inl ⟨hpat_len, u, v, ?_, ?_⟩
      · simpa [pattern, dflt, hctx_len_zero, nc_locked_mark, List.append_assoc] using hs₁
      · simpa [pattern, dflt, hctx_len_zero, List.append_assoc] using hs₂
  | inr hrest =>
      rcases hrest with ⟨hk, hcrshape⟩
      have hk' : 0 < pattern.length - 1 := by
        simpa [pattern] using hk
      have hpat_gt : 1 < pattern.length := by
        omega
      rw [hcrshape] at hs₁ hs₂
      refine Or.inr ⟨hpat_gt, u, v, ?_, ?_⟩
      · simpa [pattern, dflt, nc_locked_mark, List.append_assoc] using hs₁
      · simpa [pattern, dflt, nc_locked_out, List.append_assoc] using hs₂

/-- The target of any step that removes a phase-`0` marker can be locally cleaned
to a lifted copy of the corresponding original rule output. -/
lemma nc_locked_removed_zero_mark_step_cleanup_target
    (g : grammar T) (hg : grammar_noncontracting g)
    {ri : ℕ} {r : grule T g.nt}
    {s₁ s₂ : List (symbol T (NC_LockedNT g))}
    (hpair : (ri, r) ∈ (List.range g.rules.length).zip g.rules)
    (h : CS_transforms (locked_csg_of_noncontracting g hg) s₁ s₂)
    (hsrc : nc_locked_mark (g := g) ri 0 ∈ s₁)
    (htgt : nc_locked_mark (g := g) ri 0 ∉ s₂) :
    ∃ u v : List (symbol T (NC_LockedNT g)),
      CS_derives (locked_csg_of_noncontracting g hg) s₂
        (u ++ r.output_string.map nc_locked_liftSym ++ v) := by
  obtain hshape :=
    nc_locked_removed_zero_mark_step_shape g hg hpair h hsrc htgt
  cases hshape with
  | inl hunit =>
      rcases hunit with ⟨_hlen, u, v, _hs₁, hs₂⟩
      refine ⟨u, v, ?_⟩
      simpa [hs₂] using
        nc_locked_cleanup_outputFrom_with_context g hg hpair u v
  | inr hlong =>
      rcases hlong with ⟨_hlen, u, v, _hs₁, hs₂⟩
      refine ⟨u, v, ?_⟩
      simpa [hs₂, nc_locked_outputFrom, List.append_assoc] using
        nc_locked_cleanup_outputFrom_with_context g hg hpair u v

/-- First-step dichotomy with the retained branch expanded to the local shape of
the later emit step.  This is the form needed by the eventual grouping argument:
the branch where the boundary marker survives the first dirty step now carries
the exact source and target decomposition of the step that finally removes that
marker. -/
lemma nc_locked_dirty_interval_first_step_emit_shape_or_macro_prefix
    (g : grammar T) (hg : grammar_noncontracting g)
    {m : ℕ} {s_start s_after s_dirty s_clean :
      List (symbol T (NC_LockedNT g))}
    (hstart : CS_transforms (locked_csg_of_noncontracting g hg) s_start s_after)
    (hclean_start : nc_locked_is_clean g s_start)
    (hdirty_after : ¬ nc_locked_is_clean g s_after)
    (hmid : NC_locked_dirty_derives_n g hg m s_after s_dirty)
    (hdirty : ¬ nc_locked_is_clean g s_dirty)
    (hreturn : CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean)
    (hclean : nc_locked_is_clean g s_clean) :
    ∃ ri r u v m' smid,
      (ri, r) ∈ (List.range g.rules.length).zip g.rules ∧
        (let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
         let dflt : symbol T g.nt := symbol.nonterminal r.input_N
         s_start = u ++ [nc_locked_liftSym (pattern.getD 0 dflt)] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v ∧
           s_after = u ++ [nc_locked_mark (g := g) ri 0] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v) ∧
        m = m' + 1 ∧
        CS_transforms (locked_csg_of_noncontracting g hg) s_after smid ∧
        ¬ nc_locked_is_clean g smid ∧
        NC_locked_dirty_derives_n g hg m' smid s_dirty ∧
        ((nc_locked_mark (g := g) ri 0 ∈ smid ∧
            ∃ pre rest spre spost j,
              m' + 1 = pre + 1 + rest ∧
                NC_locked_derives_n g hg pre smid spre ∧
                CS_transforms (locked_csg_of_noncontracting g hg) spre spost ∧
                NC_locked_derives_n g hg rest spost s_clean ∧
                j < r.output_string.length ∧
                nc_locked_mark (g := g) ri 0 ∈ spre ∧
                nc_locked_mark (g := g) ri 0 ∉ spost ∧
                nc_locked_out (g := g) ri j
                  (r.output_string.getD j (symbol.nonterminal r.input_N)) ∈ spost ∧
                (let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++
                    r.input_R
                 let dflt : symbol T g.nt := symbol.nonterminal r.input_N
                 (pattern.length = 1 ∧
                    ∃ eu ev,
                      spre = eu ++ [nc_locked_mark (g := g) ri 0] ++ ev ∧
                      spost =
                        eu ++ nc_locked_outputFrom ri r.output_string dflt 0 ++ ev) ∨
                  (1 < pattern.length ∧
                    ∃ eu ev,
                      spre =
                        eu ++ [nc_locked_mark (g := g) ri 0] ++
                          nc_locked_outputSuffix ri r.output_string dflt 1 ++ ev ∧
                      spost =
                        eu ++
                          [nc_locked_out (g := g) ri 0
                            (r.output_string.getD 0 dflt)] ++
                          nc_locked_outputSuffix ri r.output_string dflt 1 ++ ev))) ∨
          let target := u ++ r.output_string.map nc_locked_liftSym ++ v
          CS_derives (locked_csg_of_noncontracting g hg) smid target ∧
            nc_locked_is_clean g target ∧
            NC_locked_clean_macro_derives_n g hg 1 s_start target) := by
  obtain ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
      htail, hcase⟩ :=
    nc_locked_dirty_interval_first_step_emit_step_or_macro_prefix g hg
      hstart hclean_start hdirty_after hmid hdirty hreturn hclean
  refine ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
    htail, ?_⟩
  cases hcase with
  | inl hretained =>
      obtain ⟨hmark, pre, rest, spre, spost, j, hlen, hpre, hremove,
          hsuf, hj, hmark_spre, hmark_spost, hout⟩ := hretained
      have hemit_shape :=
        nc_locked_removed_zero_mark_step_shape g hg hpair hremove
          hmark_spre hmark_spost
      exact Or.inl
        ⟨hmark, pre, rest, spre, spost, j, hlen, hpre, hremove, hsuf, hj,
          hmark_spre, hmark_spost, hout, hemit_shape⟩
  | inr hmacro =>
      exact Or.inr hmacro

/-- First-step dichotomy plus the marker-introduction invariant for that same
first dirty step.  In the retained branch this keeps the later emit-step shape,
while also recording that the first dirty step can only introduce a fresh
phase-`0` marker or the phase-`1` marker for the boundary simulation. -/
lemma nc_locked_dirty_interval_first_step_emit_shape_or_macro_prefix_with_added_mark_shape
    (g : grammar T) (hg : grammar_noncontracting g)
    {m : ℕ} {s_start s_after s_dirty s_clean :
      List (symbol T (NC_LockedNT g))}
    (hstart : CS_transforms (locked_csg_of_noncontracting g hg) s_start s_after)
    (hclean_start : nc_locked_is_clean g s_start)
    (hdirty_after : ¬ nc_locked_is_clean g s_after)
    (hmid : NC_locked_dirty_derives_n g hg m s_after s_dirty)
    (hdirty : ¬ nc_locked_is_clean g s_dirty)
    (hreturn : CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean)
    (hclean : nc_locked_is_clean g s_clean) :
    ∃ ri r u v m' smid,
      (ri, r) ∈ (List.range g.rules.length).zip g.rules ∧
        (let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
         let dflt : symbol T g.nt := symbol.nonterminal r.input_N
         s_start = u ++ [nc_locked_liftSym (pattern.getD 0 dflt)] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v ∧
           s_after = u ++ [nc_locked_mark (g := g) ri 0] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v) ∧
        m = m' + 1 ∧
        CS_transforms (locked_csg_of_noncontracting g hg) s_after smid ∧
        ¬ nc_locked_is_clean g smid ∧
        NC_locked_dirty_derives_n g hg m' smid s_dirty ∧
        (∀ targetRi targetK,
          nc_locked_mark (g := g) targetRi targetK ∈ smid →
          nc_locked_mark (g := g) targetRi targetK ∉ s_after →
            ∃ simRi grule,
              (simRi, grule) ∈ (List.range g.rules.length).zip g.rules ∧
                targetRi = simRi ∧
                (let pattern := grule.input_L ++ [symbol.nonterminal grule.input_N] ++
                    grule.input_R
                 targetK < pattern.length ∧
                   (targetK = 0 ∨ (simRi = ri ∧ targetK = 1)))) ∧
        ((nc_locked_mark (g := g) ri 0 ∈ smid ∧
            ∃ pre rest spre spost j,
              m' + 1 = pre + 1 + rest ∧
                NC_locked_derives_n g hg pre smid spre ∧
                CS_transforms (locked_csg_of_noncontracting g hg) spre spost ∧
                NC_locked_derives_n g hg rest spost s_clean ∧
                j < r.output_string.length ∧
                nc_locked_mark (g := g) ri 0 ∈ spre ∧
                nc_locked_mark (g := g) ri 0 ∉ spost ∧
                nc_locked_out (g := g) ri j
                  (r.output_string.getD j (symbol.nonterminal r.input_N)) ∈ spost ∧
                (let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++
                    r.input_R
                 let dflt : symbol T g.nt := symbol.nonterminal r.input_N
                 (pattern.length = 1 ∧
                    ∃ eu ev,
                      spre = eu ++ [nc_locked_mark (g := g) ri 0] ++ ev ∧
                      spost =
                        eu ++ nc_locked_outputFrom ri r.output_string dflt 0 ++ ev) ∨
                  (1 < pattern.length ∧
                    ∃ eu ev,
                      spre =
                        eu ++ [nc_locked_mark (g := g) ri 0] ++
                          nc_locked_outputSuffix ri r.output_string dflt 1 ++ ev ∧
                      spost =
                        eu ++
                          [nc_locked_out (g := g) ri 0
                            (r.output_string.getD 0 dflt)] ++
                          nc_locked_outputSuffix ri r.output_string dflt 1 ++ ev))) ∨
          let target := u ++ r.output_string.map nc_locked_liftSym ++ v
          CS_derives (locked_csg_of_noncontracting g hg) smid target ∧
            nc_locked_is_clean g target ∧
            NC_locked_clean_macro_derives_n g hg 1 s_start target) := by
  obtain ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
      htail, hcase⟩ :=
    nc_locked_dirty_interval_first_step_emit_shape_or_macro_prefix g hg
      hstart hclean_start hdirty_after hmid hdirty hreturn hclean
  obtain ⟨baseRi, _baseRule, _baseU, _baseV, _hbasePair, _hbaseUclean,
      _hbaseVclean, _hbaseShape, hmarks, _houts⟩ :=
    nc_locked_clean_step_dirty_mark_zero_unique g hg hstart hclean_start
      hdirty_after
  have hri_mark : nc_locked_mark (g := g) ri 0 ∈ s_after := by
    dsimp only at hshape
    rw [hshape.2]
    simp [List.mem_append]
  have hri_base : ri = baseRi := by
    have hp := (hmarks ri 0).1 hri_mark
    exact congrArg Prod.fst hp
  have hadded :
      ∀ targetRi targetK,
        nc_locked_mark (g := g) targetRi targetK ∈ smid →
        nc_locked_mark (g := g) targetRi targetK ∉ s_after →
          ∃ simRi grule,
            (simRi, grule) ∈ (List.range g.rules.length).zip g.rules ∧
              targetRi = simRi ∧
              (let pattern := grule.input_L ++ [symbol.nonterminal grule.input_N] ++
                  grule.input_R
               targetK < pattern.length ∧
                 (targetK = 0 ∨ (simRi = ri ∧ targetK = 1))) := by
    intro targetRi targetK htgt hsrc
    obtain ⟨simRi, grule, hpair', htarget, hshape'⟩ :=
      nc_locked_transform_added_mark_from_single_mark_source g hg hstep
        htgt hsrc hmarks
    refine ⟨simRi, grule, hpair', htarget, ?_⟩
    dsimp only at hshape' ⊢
    rcases hshape' with ⟨hk, hphase⟩
    refine ⟨hk, ?_⟩
    cases hphase with
    | inl hk0 =>
        exact Or.inl hk0
    | inr hbase =>
        exact Or.inr ⟨hbase.1.trans hri_base.symm, hbase.2⟩
  exact ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
    htail, hadded, hcase⟩

/-- Dirty-interval first-step data specialized to the case where the step creates
the boundary simulation's phase-`1` marker.  This identifies that branch as the
first continuation marking rule of the same original production. -/
lemma nc_locked_dirty_interval_first_step_base_one_mark_shape
    (g : grammar T) (hg : grammar_noncontracting g)
    {m : ℕ} {s_start s_after s_dirty s_clean :
      List (symbol T (NC_LockedNT g))}
    (hstart : CS_transforms (locked_csg_of_noncontracting g hg) s_start s_after)
    (hclean_start : nc_locked_is_clean g s_start)
    (hdirty_after : ¬ nc_locked_is_clean g s_after)
    (hmid : NC_locked_dirty_derives_n g hg m s_after s_dirty)
    (hdirty : ¬ nc_locked_is_clean g s_dirty)
    (hreturn : CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean)
    (hclean : nc_locked_is_clean g s_clean) :
    ∃ ri r u v m' smid,
      (ri, r) ∈ (List.range g.rules.length).zip g.rules ∧
        (let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
         let dflt : symbol T g.nt := symbol.nonterminal r.input_N
         s_start = u ++ [nc_locked_liftSym (pattern.getD 0 dflt)] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v ∧
           s_after = u ++ [nc_locked_mark (g := g) ri 0] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v) ∧
        m = m' + 1 ∧
        CS_transforms (locked_csg_of_noncontracting g hg) s_after smid ∧
        ¬ nc_locked_is_clean g smid ∧
        NC_locked_dirty_derives_n g hg m' smid s_dirty ∧
        (nc_locked_mark (g := g) ri 1 ∈ smid →
          (let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++
              r.input_R
           let dflt : symbol T g.nt := symbol.nonterminal r.input_N
           1 < pattern.length ∧
             ∃ cr : csrule T (NC_LockedNT g),
               cr ∈ (locked_csg_of_noncontracting g hg).rules ∧
                 cr.context_left = [nc_locked_mark ri 0] ∧
                 cr.input_nonterminal = nc_locked_symToNT (pattern.getD 1 dflt) ∧
                 cr.context_right = (pattern.drop 2).map nc_locked_liftSym ∧
                 cr.output_string = [nc_locked_mark ri 1])) := by
  obtain ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
      htail, _hadded, _hcase⟩ :=
    nc_locked_dirty_interval_first_step_emit_shape_or_macro_prefix_with_added_mark_shape
      g hg hstart hclean_start hdirty_after hmid hdirty hreturn hclean
  obtain ⟨baseRi, _baseRule, _baseU, _baseV, _hbasePair, _hbaseUclean,
      _hbaseVclean, _hbaseShape, hmarks, _houts⟩ :=
    nc_locked_clean_step_dirty_mark_zero_unique g hg hstart hclean_start
      hdirty_after
  have hri_mark : nc_locked_mark (g := g) ri 0 ∈ s_after := by
    dsimp only at hshape
    rw [hshape.2]
    simp [List.mem_append]
  have hri_base : ri = baseRi := by
    have hp := (hmarks ri 0).1 hri_mark
    exact congrArg Prod.fst hp
  have hmarks_ri :
      ∀ ri' k, nc_locked_mark (g := g) ri' k ∈ s_after ↔ (ri', k) = (ri, 0) := by
    intro ri' k
    rw [hmarks, hri_base]
  refine ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
    htail, ?_⟩
  intro hone
  have hnot_after : nc_locked_mark (g := g) ri 1 ∉ s_after := by
    intro hmem
    have hp := (hmarks_ri ri 1).1 hmem
    have hsnd := congrArg Prod.snd hp
    omega
  obtain ⟨grule, hpair', hcont⟩ :=
    nc_locked_transform_added_base_one_mark_shape g hg hstep hone hnot_after
      hmarks_ri
  have hgrule : grule = r := nc_rule_zip_rule_unique g hpair' hpair
  subst grule
  exact hcont

/-- Dirty-interval first-step data specialized to the case where the step creates
the boundary simulation's phase-`1` marker, with the exact resulting sentential
form.  This strengthens `nc_locked_dirty_interval_first_step_base_one_mark_shape`
from the rule that fired to the whole target shape of that first dirty step. -/
lemma nc_locked_dirty_interval_first_step_base_one_mark_exact
    (g : grammar T) (hg : grammar_noncontracting g)
    {m : ℕ} {s_start s_after s_dirty s_clean :
      List (symbol T (NC_LockedNT g))}
    (hstart : CS_transforms (locked_csg_of_noncontracting g hg) s_start s_after)
    (hclean_start : nc_locked_is_clean g s_start)
    (hdirty_after : ¬ nc_locked_is_clean g s_after)
    (hmid : NC_locked_dirty_derives_n g hg m s_after s_dirty)
    (hdirty : ¬ nc_locked_is_clean g s_dirty)
    (hreturn : CS_transforms (locked_csg_of_noncontracting g hg) s_dirty s_clean)
    (hclean : nc_locked_is_clean g s_clean) :
    ∃ ri r u v m' smid,
      (ri, r) ∈ (List.range g.rules.length).zip g.rules ∧
        (let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
         let dflt : symbol T g.nt := symbol.nonterminal r.input_N
         s_start = u ++ [nc_locked_liftSym (pattern.getD 0 dflt)] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v ∧
           s_after = u ++ [nc_locked_mark (g := g) ri 0] ++
             (pattern.drop 1).map nc_locked_liftSym ++ v) ∧
        m = m' + 1 ∧
        CS_transforms (locked_csg_of_noncontracting g hg) s_after smid ∧
        ¬ nc_locked_is_clean g smid ∧
        NC_locked_dirty_derives_n g hg m' smid s_dirty ∧
        (nc_locked_mark (g := g) ri 1 ∈ smid →
          (let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
           1 < pattern.length ∧
             smid =
               ((u ++ [nc_locked_mark (g := g) ri 0] ++
                 [nc_locked_mark (g := g) ri 1] ++
                 (pattern.drop 2).map (nc_locked_liftSym (g := g)) ++ v) :
                   List (symbol T (NC_LockedNT g))))) := by
  obtain ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
      htail, _hbase_one_shape⟩ :=
    nc_locked_dirty_interval_first_step_base_one_mark_shape
      g hg hstart hclean_start hdirty_after hmid hdirty hreturn hclean
  refine ⟨ri, r, u, v, m', smid, hpair, hshape, hm, hstep, hdirty_mid,
    htail, ?_⟩
  intro hone
  let pattern := r.input_L ++ [symbol.nonterminal r.input_N] ++ r.input_R
  have hu : nc_locked_is_clean g u := by
    refine nc_locked_is_clean_of_subset g hclean_start ?_
    intro x hx
    rw [hshape.1]
    simp [List.mem_append, hx]
  have hv : nc_locked_is_clean g v := by
