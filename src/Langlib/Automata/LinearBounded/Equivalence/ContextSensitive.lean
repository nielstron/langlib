/-!
# Context-Sensitive Languages = LBA Languages

This file states the MyhillÔÇôLandweberÔÇôKuroda theorem in its set-level form,

  `CS = LBA`  (`CS_eq_LBA`),

the equality of the class of context-sensitive languages (`CS`, languages generated by
an unrestricted grammar that is non-contracting up to an optional `S ÔåÆ ╬Á` rule) and the
class of languages recognised by a nondeterministic linearly bounded automaton (`LBA`).

The proof is the conjunction of two inclusions:

* `LBA_subset_CS` ÔÇö Myhill's construction: a CS grammar simulates the LBA's bounded
  computation (`Automata/LinearBounded/Equivalence/LBAToCSG.lean` builds the grammar and
  proves rule membership; the remaining work is the language equality).
* `CS_subset_LBA` ÔÇö Kuroda's construction: an LBA nondeterministically simulates a
  derivation of the grammar within the linear space provided by the input.

## On the empty word

`LBA.LanguageRecognized` decides membership of `╬Á` via an explicit `acceptEmpty : Bool`
(the bounded tape has no natural notion of "running on the empty input"). This mirrors the
optional `S ÔåÆ ╬Á` rule in the definition of a context-sensitive grammar, and is precisely
what makes the two classes *equal* rather than merely "equal up to `╬Á`": both sides decide
`╬Á` by a finite flag and agree on every non-empty word.

## References

* Kuroda, S.-Y. (1964), "Classes of languages and linear-bounded automata".
* Myhill, J. (1960), "Linear bounded automata".
* Hopcroft, Motwani, Ullman, *Introduction to Automata Theory, Languages, and Computation*,
  Chapter 9.
-/

open MyhillConstruction

variable {T : Type}

/-! ## LBA Ôèå CS (Myhill) -/

/-- **Myhill's construction (core).** The context-sensitive grammar built from an LBA in
`LBAToCSG.lean` generates exactly the non-empty language recognised by the automaton.

This is the genuine content of the LBA ÔåÆ CS direction. The grammar and all of its rule
membership lemmas are already established in `LBAToCSG.lean`; what remains is the
bisimulation between cell-sentential-forms and LBA configurations:

* **completeness** (`Ôèç`): an accepting LBA run on `w` is mirrored by a derivation
  `start ÔçÆ* map terminal w` ÔÇö the start rules lay down one `cell` per input symbol, the
  simulation rules track each LBA step (interior moves use the 3-step `cellPending`
  protocol), and the cleanup rules recover the terminals once an accepting state appears;
* **soundness** (`Ôèå`): conversely every terminal string derivable from `start` arises this
  way, by an invariant stating that every reachable sentential form of `cell`s decodes to a
  configuration reachable by `M` from the initial configuration on `w`. -/
theorem myhill_language_eq
    {╬ô ╬ø : Type} [Fintype T] [Fintype ╬ô] [Fintype ╬ø]
    [DecidableEq T] [DecidableEq ╬ô] [DecidableEq ╬ø]
    (M : LBA.Machine ╬ô ╬ø) (embed : T Ôå¬ ╬ô) :
    CS_language (myhillGrammar M embed) = LBA.LanguageViaEmbed M embed := by
  funext w
  apply propext
  constructor
  ┬À -- soundness (Ôèå): every derived terminal word is accepted
    exact MyhillConstruction.myhill_sound M embed w
  ┬À -- completeness (Ôèç): every accepted word is derived
    exact MyhillConstruction.myhill_complete M embed w

variable [Fintype T] [DecidableEq T]

/-- **LBA Ôèå CS.** Every LBA language is context-sensitive.

The empty word is handled by `is_CS_insert_empty_of_CS_grammar`
(`Classes/ContextSensitive/Closure/EmptyWord.lean`), proved separately. -/
theorem LBA_subset_CS : (LBA : Set (Language T)) Ôèå CS := by
  rintro L Ôş¿╬ô, ╬ø, h╬ô, h╬ø, hd╬ô, hd╬ø, acceptEmpty, M, rflÔş®
  haveI := h╬ô; haveI := h╬ø; haveI := hd╬ô; haveI := hd╬ø
  -- The canonical input map `some Ôêİ Sum.inl` as an embedding into the sum tape alphabet.
  let emb : T Ôå¬ Option (T Ôèò ╬ô) := Ôş¿fun t => some (Sum.inl t), fun _ _ h => by simpa using hÔş®
  -- The non-empty fragment is exactly the Myhill CS-grammar's language.
  have hcore : LBA.LanguageViaEmbed M Ôçæemb = CS_language (myhillGrammar M emb) :=
    (myhill_language_eq M emb).symm
  -- `LanguageRecognized = (acceptEmpty Ôêğ ┬À=[]) Ôê¿ LanguageViaEmbed`. Split on the flag.
  show is_CS (LBA.LanguageRecognized M Ôçæemb acceptEmpty)
  cases acceptEmpty with
  | false =>
      -- `acceptEmpty = false`: the language is exactly the (╬Á-free) Myhill language.
      have : LBA.LanguageRecognized M Ôçæemb false = CS_language (myhillGrammar M emb) := by
        funext w
        simp only [LBA.LanguageRecognized, Bool.false_eq_true, false_and, false_or, hcore]
      rw [this]
      exact is_CS_via_csg_implies_is_CS Ôş¿_, rflÔş®
  | true =>
      -- `acceptEmpty = true`: add `╬Á` to the Myhill language.
      have : LBA.LanguageRecognized M Ôçæemb true
          = (fun w => w = [] Ôê¿ CS_language (myhillGrammar M emb) w) := by
        funext w
        simp only [LBA.LanguageRecognized]
        rw [show LBA.LanguageViaEmbed M Ôçæemb w = CS_language (myhillGrammar M emb) w
              from congrFun hcore w]
        apply propext
        constructor
        ┬À rintro (Ôş¿_, hÔş® | h)
          ┬À exact Or.inl h
          ┬À exact Or.inr h
        ┬À rintro (h | h)
          ┬À exact Or.inl Ôş¿trivial, hÔş®
          ┬À exact Or.inr h
      rw [this]
      exact is_CS_insert_empty_of_CS_grammar _

/-! ## CS Ôèå LBA (Kuroda) -/

/-- **Kuroda's construction (core).** Every context-sensitive language is recognised by a
nondeterministic LBA.

The genuine content of the CS ÔåÆ LBA direction. Given `is_CS L`, restrict to the
non-contracting core (`Grammars/NonContracting`) with finitely many nonterminals
(`Grammars/ContextSensitive/Basic/FiniteNT.lean`). On input `w` of length `n`, an LBA with a
two-track tape ÔÇö track 1 the frozen input, track 2 a working sentential form over the
finite grammar-symbol alphabet ÔÇö nondeterministically applies grammar rules to track 2 and
accepts when track 2 equals track 1. Non-contraction guarantees that every sentential form
of a derivation of `w` has length `Ôëñ n`, so the bounded tape suffices, giving both
directions of the language equality. The empty word is decided by `acceptEmpty`. -/
theorem CS_subset_LBA : (CS : Set (Language T)) Ôèå LBA := by
  sorry

/-! ## The theorem -/

/-- **Context-sensitive languages are exactly the LBA languages.** -/
theorem CS_eq_LBA : (CS : Set (Language T)) = LBA :=
  Set.Subset.antisymm CS_subset_LBA LBA_subset_CS
