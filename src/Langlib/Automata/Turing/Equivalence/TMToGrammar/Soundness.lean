theorem sim_rule_move_left_boundary_case (M : Turing.TM0.Machine (Option T) Λ)
    (tc : @TwoTrackConfig T Λ) (tc' : @TwoTrackConfig T Λ)
    (q' : Λ)
    (hMqa : M tc.headState tc.headCur = some (q', Turing.TM0.Stmt.move Dir.left))
    (h_step : stepTwoTrack M tc = some tc')
    (u v : List (symbol T (TMtoGrammarNT T Λ)))
    (heq : encodeTwoTrack tc = u ++ [symbol.nonterminal leftBound] ++ [symbol.nonterminal (headCell tc.headState tc.headOrig tc.headCur)] ++ [] ++ v) :
    u ++ [symbol.nonterminal leftBound, symbol.nonterminal (headCell q' none none), symbol.nonterminal (cell tc.headOrig tc.headCur)] ++ v = encodeTwoTrack tc' := by
  have := encodeTwoTrack_unique_split tc;
  specialize this ( u ++ [ symbol.nonterminal leftBound ] ) v ; simp +decide [ heq ] at this ⊢;
  cases u <;> simp_all +decide [ encodeTwoTrack ];
  · unfold stepTwoTrack at h_step; aesop;
  · cases h : tc.leftCells.reverse <;> aesop

