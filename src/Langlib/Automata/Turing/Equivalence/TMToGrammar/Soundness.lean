/-- Detailed classification of simulation rules matching headCell q orig cur
when M q cur = some (q', action). -/
theorem sim_rule_detailed_classification (M : Turing.TM0.Machine (Option T) Λ)
    (r : grule T (TMtoGrammarNT T Λ))
    (hr : r ∈ (tmToGrammar T Λ M).rules)
    (q : Λ) (orig cur : Option T)
    (hN : r.input_N = headCell q orig cur)
    (q' : Λ) (action : Turing.TM0.Stmt (Option T))
    (hMqa : M q cur = some (q', action)) :
    -- Write
    (∃ γ', action = Turing.TM0.Stmt.write γ' ∧
      r.input_L = [] ∧ r.input_R = [] ∧
      r.output_string = [symbol.nonterminal (headCell q' orig γ')]) ∨
    -- Move right with neighbor
    (action = Turing.TM0.Stmt.move Dir.right ∧
      ∃ o' c', r.input_L = [] ∧
        r.input_R = [symbol.nonterminal (cell o' c')] ∧
        r.output_string = [symbol.nonterminal (cell orig cur),
                           symbol.nonterminal (headCell q' o' c')]) ∨
    -- Move right at boundary
    (action = Turing.TM0.Stmt.move Dir.right ∧
      r.input_L = [] ∧
      r.input_R = [symbol.nonterminal rightBound] ∧
      r.output_string = [symbol.nonterminal (cell orig cur),
                         symbol.nonterminal (headCell q' none none),
                         symbol.nonterminal rightBound]) ∨
    -- Move left with neighbor
    (action = Turing.TM0.Stmt.move Dir.left ∧
      ∃ o'' c'', r.input_L = [symbol.nonterminal (cell o'' c'')] ∧
        r.input_R = [] ∧
        r.output_string = [symbol.nonterminal (headCell q' o'' c''),
                           symbol.nonterminal (cell orig cur)]) ∨
    -- Move left at boundary
    (action = Turing.TM0.Stmt.move Dir.left ∧
      r.input_L = [symbol.nonterminal leftBound] ∧
      r.input_R = [] ∧
      r.output_string = [symbol.nonterminal leftBound,
                         symbol.nonterminal (headCell q' none none),
                         symbol.nonterminal (cell orig cur)]) := by
  revert r;
  simp [tmToGrammar];
  intro r hr hN;
  rcases hr with ( hr | hr | hr );
  · unfold generationRules at hr;
    grind;
  · unfold simulationRules at hr; aesop;
  · unfold cleanupRules at hr; aesop;

