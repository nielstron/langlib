[LB] ++ LC.map cell ++ [headCell(q, o, c)] ++ RC.map cell ++ [RB] = u ++ [headCell(q, o, c)] ++ v

where LC = tc.leftCells, RC = tc.rightCells, q = tc.headState, o = tc.headOrig, c = tc.headCur.

