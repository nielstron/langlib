import Mathlib
import Langlib.Classes.RecursivelyEnumerable.Definition
import Langlib.Automata.Turing.Definition
import Langlib.Automata.Turing.Equivalence.GrammarToTM.GrammarSearch

/-! # Unrestricted Grammars → Turing Machines

This file proves that every language generated by an unrestricted grammar
is TM-recognizable (internally): `RE ⊆ TM_internal`.

The result produces a TM0 over the Partrec chain's internal `Fintype`
alphabet. Converting to the standard `Option T` alphabet (to get `is_TM`)
requires the alphabet simulation theorem, which is a separate concern.

## Main results

- `re_implies_tm_internal` — `is_RE L → is_TM_internal_weak L`
  (TM-recognizable with internal alphabet, possibly infinite state type)

## Note on `is_TM`

The full `is_TM` result (with `Option T` tape alphabet and `Fintype` states)
requires two additional steps:
1. **Finite state restriction**: using `TM0.restrict` with the chain's support
2. **Alphabet simulation**: converting from internal alphabet to `Option T`

Both are standard results. Step 1 uses Mathlib's `TM0.Supports` / `TM1to0.tr_supports`
chain. Step 2 requires block encoding of tape symbols.
-/

open Turing

/-- A language is **weakly internally TM-recognizable** if there exists
a TM0 machine (with a `Fintype` tape alphabet, but possibly infinite
state type) that halts on `enc w` iff `w ∈ L`. -/
def is_TM_internal_weak {T : Type} (L : Language T) : Prop :=
  ∃ (Γ : Type) (_ : Inhabited Γ) (_ : Fintype Γ)
    (Λ : Type) (_ : Inhabited Λ)
    (M : TM0.Machine Γ Λ)
    (enc : List T → List Γ),
    ∀ w : List T, w ∈ L ↔ (TM0.eval M (enc w)).Dom

/-- `is_TM L → is_TM_internal_weak L` (trivial embedding). -/
theorem is_TM_to_internal_weak {T : Type} [Fintype T] (L : Language T) :
    is_TM L → is_TM_internal_weak L := by
  intro ⟨Λ, hΛ, _, M, hM⟩
  exact ⟨Option T, inferInstance, inferInstance, Λ, hΛ, M, fun w => w.map some, hM⟩

/-- Every recursively enumerable language (generated by an unrestricted grammar)
is weakly internally TM-recognizable.

Note: This requires `Fintype g.nt` for the grammar's nonterminal type.
This is always satisfiable in practice since every grammar uses only
finitely many nonterminals. -/
theorem re_implies_tm_internal {T : Type} [DecidableEq T] [Fintype T]
    (L : Language T) (hL : is_RE L) : is_TM_internal_weak L := by
  obtain ⟨g, hg⟩ := hL
  haveI : DecidableEq g.nt := Classical.decEq _
  haveI : Fintype g.nt := by sorry
  rw [← hg]
  exact grammar_language_is_TM_internal g
